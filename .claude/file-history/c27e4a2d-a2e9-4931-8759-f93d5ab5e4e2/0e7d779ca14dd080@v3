'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import { createClient } from '@/lib/supabase/client';
import Button from '@/components/ui/Button';
import Input from '@/components/ui/Input';
import Card from '@/components/ui/Card';
import { toast } from 'sonner';
import type { LoyaltyProgram } from '@/lib/supabase/types';

interface RewardFormProps {
  programs: LoyaltyProgram[];
}

export default function RewardForm({ programs }: RewardFormProps) {
  const router = useRouter();
  const [loading, setLoading] = useState(false);
  const [form, setForm] = useState({
    program_id: programs[0]?.id || '',
    name: '',
    discount_type: 'freebie' as 'percentage' | 'fixed' | 'freebie',
    discount_value: 0,
    points_cost: 0,
    stamps_required: 0,
  });

  const update = (key: string, value: string | number) => setForm(prev => ({ ...prev, [key]: value }));

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!form.program_id) { toast.error('Sélectionnez un programme.'); return; }
    if (!form.name.trim()) { toast.error('Entrez un nom de récompense.'); return; }

    setLoading(true);
    const supabase = createClient();

    const selectedProg = programs.find(p => p.id === form.program_id);
    const { error } = await supabase.from('rewards').insert({
      program_id: form.program_id,
      name: form.name,
      discount_type: form.discount_type,
      discount_value: form.discount_type === 'freebie' ? 0 : form.discount_value,
      points_cost: selectedProg?.type === 'points' ? form.points_cost : null,
      stamps_required: selectedProg?.type === 'stamp' ? form.stamps_required : null,
    });

    if (error) { toast.error(error.message); setLoading(false); return; }
    toast.success('Récompense créée !');
    router.refresh();
    setForm(prev => ({ ...prev, name: '', discount_value: 0, points_cost: 0, stamps_required: 0 }));
    setLoading(false);
  };

  if (programs.length === 0) {
    return (
      <Card className="text-center py-8">
        <p className="text-[var(--text-tertiary)] text-[13px]">Créez d&apos;abord un programme pour ajouter des récompenses.</p>
      </Card>
    );
  }

  return (
    <Card padding="lg" className="max-w-lg">
      <h3 className="text-[15px] font-semibold text-[var(--text-primary)] mb-4">Nouvelle récompense</h3>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div className="space-y-1.5">
          <label className="text-[13px] font-medium text-[var(--text-secondary)]">Programme</label>
          <select
            value={form.program_id}
            onChange={e => update('program_id', e.target.value)}
            className="w-full px-3 py-2 text-sm rounded-lg border border-[var(--border-default)] bg-[var(--bg-surface)] text-[var(--text-primary)]"
          >
            {programs.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
          </select>
        </div>

        <Input label="Nom de la récompense" value={form.name} onChange={e => update('name', e.target.value)} required placeholder="ex: Café offert" />

        <div className="space-y-1.5">
          <label className="text-[13px] font-medium text-[var(--text-secondary)]">Type de réduction</label>
          <div className="flex gap-2">
            {([
              { value: 'freebie', label: 'Gratuit' },
              { value: 'percentage', label: '%' },
              { value: 'fixed', label: '€' },
            ] as const).map(t => (
              <button key={t.value} type="button" onClick={() => update('discount_type', t.value)}
                className={`flex-1 px-3 py-2 rounded-lg text-sm border transition-all ${
                  form.discount_type === t.value
                    ? 'border-[var(--accent)] bg-[var(--accent-subtle)] text-[var(--accent-text)] font-medium'
                    : 'border-[var(--border-default)] text-[var(--text-secondary)] hover:border-[var(--border-strong)]'
                }`}
              >
                {t.label}
              </button>
            ))}
          </div>
        </div>

        {form.discount_type !== 'freebie' && (
          <Input
            label={form.discount_type === 'percentage' ? 'Pourcentage (%)' : 'Montant (€)'}
            type="number" min={0}
            value={String(form.discount_value)}
            onChange={e => update('discount_value', parseFloat(e.target.value) || 0)}
          />
        )}

        {(() => {
          const selectedProg = programs.find(p => p.id === form.program_id);
          if (selectedProg?.type === 'stamp') {
            return (
              <Input
                label="Tampons requis pour cette recompense"
                type="number" min={0}
                value={String(form.stamps_required)}
                onChange={e => update('stamps_required', parseInt(e.target.value) || 0)}
              />
            );
          } else if (selectedProg?.type === 'points') {
            return (
              <Input
                label="Points requis pour cette recompense"
                type="number" min={0}
                value={String(form.points_cost)}
                onChange={e => update('points_cost', parseInt(e.target.value) || 0)}
              />
            );
          }
          return null;
        })()}

        <Button type="submit" loading={loading}>Ajouter la récompense</Button>
      </form>
    </Card>
  );
}
