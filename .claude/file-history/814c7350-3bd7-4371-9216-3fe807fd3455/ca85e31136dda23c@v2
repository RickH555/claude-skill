import React from 'react';
import { X } from 'lucide-react';

interface RightPanelProps {
  isOpen: boolean;
  onClose: () => void;
  title?: string;
  children: React.ReactNode;
}

export default function RightPanel({ isOpen, onClose, title, children }: RightPanelProps) {
  if (!isOpen) return null;

  return (
    <>
      {/* Backdrop on mobile */}
      <div
        className="md:hidden fixed inset-0 z-40 bg-black/30 backdrop-blur-sm"
        onClick={onClose}
      />

      {/* Panel */}
      <aside className={`
        fixed md:relative top-0 right-0 bottom-0 z-50 md:z-auto
        w-80 shrink-0
        bg-[var(--bg-surface)] border-l border-[var(--border-default)]
        flex flex-col overflow-hidden
        slide-in-right
      `}>
        {/* Header */}
        {title && (
          <div className="flex items-center justify-between px-4 h-12 border-b border-[var(--border-default)] shrink-0">
            <h3 className="text-sm font-semibold text-[var(--text-primary)]">{title}</h3>
            <button
              onClick={onClose}
              className="p-1 rounded-md text-[var(--text-tertiary)] hover:text-[var(--text-primary)] hover:bg-[var(--glass-active)] transition-all"
            >
              <X size={16} />
            </button>
          </div>
        )}

        {/* Content */}
        <div className="flex-1 overflow-y-auto p-4">
          {children}
        </div>
      </aside>
    </>
  );
}
