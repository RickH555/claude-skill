// Analyze sentiment from AI response
function analyzeSentiment(response: string, brandName: string): { sentiment: "positive" | "neutral" | "negative"; score: number } {
  const lower = response.toLowerCase()
  const brand = brandName.toLowerCase()

  if (!lower.includes(brand)) {
    return { sentiment: "neutral", score: 0 }
  }

  const positiveSignals = [
    "excellent", "meilleur", "recommande", "leader", "innovant", "performant",
    "best", "recommended", "leading", "innovative", "powerful", "top",
    "fiable", "efficace", "complet", "unique", "reliable", "effective"
  ]
  const negativeSignals = [
    "probleme", "limite", "cher", "manque", "faible", "decu",
    "problem", "limited", "expensive", "lacking", "weak", "disappointing",
    "bug", "lent", "complexe", "slow", "complex"
  ]

  let positiveCount = 0
  let negativeCount = 0

  // Check signals near brand mentions (within 200 chars)
  const brandIndex = lower.indexOf(brand)
  const context = lower.substring(Math.max(0, brandIndex - 200), Math.min(lower.length, brandIndex + 200))

  positiveSignals.forEach(s => { if (context.includes(s)) positiveCount++ })
  negativeSignals.forEach(s => { if (context.includes(s)) negativeCount++ })

  if (positiveCount > negativeCount + 1) return { sentiment: "positive", score: Math.min(1, positiveCount * 0.2) }
  if (negativeCount > positiveCount + 1) return { sentiment: "negative", score: Math.max(-1, -negativeCount * 0.2) }
  return { sentiment: "neutral", score: 0 }
}

// Find which competitors are mentioned
function findCompetitorMentions(response: string, competitors: string[]): string[] {
  const lower = response.toLowerCase()
  return competitors.filter(c => lower.includes(c.toLowerCase()))
}

