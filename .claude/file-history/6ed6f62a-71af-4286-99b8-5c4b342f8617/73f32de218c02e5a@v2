import React, { useState } from 'react';
import { User, AnalysisResult } from '../types';
import { generateLlmsTxt } from '../services/llms-txt-generator';
import { generateLlmJson } from '../services/llm-json-generator';
import {
  ArrowLeft, FileText, FileJson, Plus, Trash2, Loader2, Copy, Check,
  Download, Sparkles, Zap, Globe, Mail, Phone, MapPin, Link, Braces,
} from 'lucide-react';

interface Props {
  onBack: () => void;
  user: User | null;
  onDeductCredits: (amount: number) => boolean;
  history?: AnalysisResult[];
}

const CREDIT_COST_TXT = 3;
const CREDIT_COST_JSON = 5;

type ActiveTab = 'llms-txt' | 'llm-json';

const LlmsTxtGenerator: React.FC<Props> = ({ onBack, user, onDeductCredits, history }) => {
  // Active tab
  const [activeTab, setActiveTab] = useState<ActiveTab>('llms-txt');

  // Form state (shared between both tabs)
  const [siteName, setSiteName] = useState('');
  const [siteUrl, setSiteUrl] = useState('');
  const [description, setDescription] = useState('');
  const [entity, setEntity] = useState('Organization');
  const [contactEmail, setContactEmail] = useState('');
  const [contactPhone, setContactPhone] = useState('');
  const [contactAddress, setContactAddress] = useState('');
  const [targetAudience, setTargetAudience] = useState('');
  const [industry, setIndustry] = useState('');
  const [foundedYear, setFoundedYear] = useState('');
  const [services, setServices] = useState<Array<{ name: string; description: string; url: string }>>([
    { name: '', description: '', url: '' },
  ]);
  const [keyPages, setKeyPages] = useState<Array<{ title: string; url: string; description: string }>>([
    { title: '', url: '', description: '' },
  ]);
  const [socialLinks, setSocialLinks] = useState('');

  // Result state for llms.txt
  const [isGeneratingTxt, setIsGeneratingTxt] = useState(false);
  const [txtResult, setTxtResult] = useState<{ content: string; sections: number; wordCount: number } | null>(null);
  const [copiedTxt, setCopiedTxt] = useState(false);

  // Result state for llm.json
  const [isGeneratingJson, setIsGeneratingJson] = useState(false);
  const [jsonResult, setJsonResult] = useState<{ content: string; fieldCount: number; byteSize: number } | null>(null);
  const [copiedJson, setCopiedJson] = useState(false);

  const isValid = siteName && siteUrl && description && contactEmail;
  const isGenerating = isGeneratingTxt || isGeneratingJson;

  const buildCommonConfig = () => ({
    siteName,
    siteUrl: siteUrl.replace(/\/$/, ''),
    description,
    entity,
    services: services.filter(s => s.name),
    keyPages: keyPages.filter(p => p.title && p.url),
    contact: {
      email: contactEmail,
      ...(contactPhone ? { phone: contactPhone } : {}),
      ...(contactAddress ? { address: contactAddress } : {}),
    },
    socialLinks: socialLinks.split('\n').map(s => s.trim()).filter(Boolean),
    targetAudience: targetAudience || undefined,
  });

  const handleGenerateTxt = async () => {
    if (!isValid) return;
    const canProceed = onDeductCredits(CREDIT_COST_TXT);
    if (!canProceed) return;

    // Check pre-generated cache
    const cachedTxt = history && history.length > 0 ? history[0]?.preGenerated?.llmsTxt : undefined;
    if (cachedTxt?.content) {
      setTxtResult(cachedTxt);
      return;
    }

    setIsGeneratingTxt(true);
    try {
      const output = await generateLlmsTxt(buildCommonConfig());
      setTxtResult(output);
    } catch (err) {
      console.error('TXT generation failed:', err);
    } finally {
      setIsGeneratingTxt(false);
    }
  };

  const handleGenerateJson = async () => {
    if (!isValid) return;
    const canProceed = onDeductCredits(CREDIT_COST_JSON);
    if (!canProceed) return;

    // Check pre-generated cache
    const cachedJson = history && history.length > 0 ? history[0]?.preGenerated?.llmJson : undefined;
    if (cachedJson?.content) {
      setJsonResult(cachedJson);
      return;
    }

    setIsGeneratingJson(true);
    try {
      const output = await generateLlmJson({
        ...buildCommonConfig(),
        industry: industry || undefined,
        foundedYear: foundedYear || undefined,
      });
      setJsonResult(output);
    } catch (err) {
      console.error('JSON generation failed:', err);
    } finally {
      setIsGeneratingJson(false);
    }
  };

  const handleCopyTxt = () => {
    if (!txtResult) return;
    navigator.clipboard.writeText(txtResult.content);
    setCopiedTxt(true);
    setTimeout(() => setCopiedTxt(false), 2000);
  };

  const handleCopyJson = () => {
    if (!jsonResult) return;
    navigator.clipboard.writeText(jsonResult.content);
    setCopiedJson(true);
    setTimeout(() => setCopiedJson(false), 2000);
  };

  const handleDownloadTxt = () => {
    if (!txtResult) return;
    const blob = new Blob([txtResult.content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'llms.txt';
    a.click();
    URL.revokeObjectURL(url);
  };

  const handleDownloadJson = () => {
    if (!jsonResult) return;
    const blob = new Blob([jsonResult.content], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'llm.json';
    a.click();
    URL.revokeObjectURL(url);
  };

  const currentResult = activeTab === 'llms-txt' ? txtResult : jsonResult;
  const currentIsGenerating = activeTab === 'llms-txt' ? isGeneratingTxt : isGeneratingJson;

  return (
    <div className="w-full px-6 py-8 animate-in fade-in duration-500">
      {/* Header */}
      <div className="flex items-center gap-4 mb-6">
        <button onClick={onBack} className="p-2 rounded-xl hover:bg-white/[0.04] transition-colors">
          <ArrowLeft size={20} className="text-gray-400" />
        </button>
        <div className="flex-1">
          <div className="flex items-center gap-3">
            <h1 className="text-2xl font-bold text-white">Générateur <span className="gradient-text">LLM Files</span></h1>
            <span className="bg-emerald-500/10 text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full border border-emerald-500/20 flex items-center gap-1">
              <Sparkles size={10} /> NOUVEAU
            </span>
          </div>
          <p className="text-sm text-gray-500 mt-1">Créez vos fichiers llms.txt et llm.json pour contrôler comment les IA vous référencent</p>
        </div>
      </div>

      {/* Tab switcher */}
      <div className="flex items-center gap-1 mb-6 bg-white/[0.03] rounded-2xl p-1 w-fit border border-white/[0.06]">
        <button
          onClick={() => setActiveTab('llms-txt')}
          className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 ${
            activeTab === 'llms-txt'
              ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/30 shadow-lg shadow-emerald-900/20'
              : 'text-gray-500 hover:text-gray-300 hover:bg-white/[0.04]'
          }`}
        >
          <FileText size={16} />
          llms.txt
          {txtResult && <span className="w-1.5 h-1.5 rounded-full bg-emerald-400" />}
        </button>
        <button
          onClick={() => setActiveTab('llm-json')}
          className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 ${
            activeTab === 'llm-json'
              ? 'bg-amber-500/15 text-amber-400 border border-amber-500/30 shadow-lg shadow-amber-900/20'
              : 'text-gray-500 hover:text-gray-300 hover:bg-white/[0.04]'
          }`}
        >
          <Braces size={16} />
          llm.json
          {jsonResult && <span className="w-1.5 h-1.5 rounded-full bg-amber-400" />}
        </button>
      </div>

      {/* Info banner */}
      {activeTab === 'llms-txt' ? (
        <div className="ninja-card p-4 mb-8 flex items-start gap-3 border-l-2 border-emerald-500/50">
          <FileText size={18} className="text-emerald-400 shrink-0 mt-0.5" />
          <div>
            <p className="text-sm text-gray-300 font-medium">Qu'est-ce que llms.txt ?</p>
            <p className="text-xs text-gray-500 mt-1">Un fichier texte placé à la racine de votre site (<code className="text-emerald-400/80">votresite.com/llms.txt</code>) qui donne aux LLMs un résumé structuré de votre identité, vos services et vos pages clés. C'est le "robots.txt" de l'ère IA.</p>
          </div>
        </div>
      ) : (
        <div className="ninja-card p-4 mb-8 flex items-start gap-3 border-l-2 border-amber-500/50">
          <Braces size={18} className="text-amber-400 shrink-0 mt-0.5" />
          <div>
            <p className="text-sm text-gray-300 font-medium">Qu'est-ce que llm.json ?</p>
            <p className="text-xs text-gray-500 mt-1">La <strong className="text-amber-400/80">carte d'identité machine-readable</strong> de votre entité (<code className="text-amber-400/80">votresite.com/llm.json</code>). Contrairement au llms.txt (lisible par l'humain), le llm.json fournit des données sémantiques structurées que les LLMs peuvent parser directement : identité, signaux E-E-A-T, préférences de citation, sources canoniques et instructions IA.</p>
          </div>
        </div>
      )}

      <div className="grid lg:grid-cols-2 gap-6">
        {/* Left — Form (shared) */}
        <div className="space-y-6">
          {/* Identity */}
          <div className="ninja-card p-6">
            <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Identité du site</h3>
            <div className="space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5">Nom du site <span className="text-red-400">*</span></label>
                  <input value={siteName} onChange={e => setSiteName(e.target.value)} placeholder="MonEntreprise"
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5">URL <span className="text-red-400">*</span></label>
                  <input value={siteUrl} onChange={e => setSiteUrl(e.target.value)} placeholder="https://example.com"
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
                </div>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-1.5">Description <span className="text-red-400">*</span></label>
                <textarea value={description} onChange={e => setDescription(e.target.value)} rows={2} placeholder="Description concise de votre entreprise/site..."
                  className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors resize-none" />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5">Type d'entité</label>
                  <select value={entity} onChange={e => setEntity(e.target.value)}
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50">
                    <option value="Organization">Organization</option>
                    <option value="LocalBusiness">LocalBusiness</option>
                    <option value="Person">Person</option>
                    <option value="Corporation">Corporation</option>
                    <option value="SaaS">SaaS Platform</option>
                  </select>
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5">Audience cible</label>
                  <input value={targetAudience} onChange={e => setTargetAudience(e.target.value)} placeholder="PME, marketeurs, développeurs..."
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
                </div>
              </div>
              {/* Extra fields for llm.json */}
              {activeTab === 'llm-json' && (
                <div className="grid grid-cols-2 gap-4 pt-2 border-t border-white/[0.04]">
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5">
                      Secteur d'activité
                      <span className="text-[10px] text-amber-400/60 bg-amber-500/10 px-1.5 py-0.5 rounded">JSON</span>
                    </label>
                    <input value={industry} onChange={e => setIndustry(e.target.value)} placeholder="SaaS, E-commerce, Santé..."
                      className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-amber-500/50 transition-colors" />
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5">
                      Année de création
                      <span className="text-[10px] text-amber-400/60 bg-amber-500/10 px-1.5 py-0.5 rounded">JSON</span>
                    </label>
                    <input value={foundedYear} onChange={e => setFoundedYear(e.target.value)} placeholder="2020"
                      className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-amber-500/50 transition-colors" />
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* Services */}
          <div className="ninja-card p-6">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider">Services / Produits</h3>
              <button onClick={() => setServices(prev => [...prev, { name: '', description: '', url: '' }])}
                className="flex items-center gap-1 text-xs text-purple-400 hover:text-purple-300 transition-colors">
                <Plus size={12} /> Ajouter
              </button>
            </div>
            <div className="space-y-3">
              {services.map((svc, i) => (
                <div key={i} className="bg-white/[0.02] border border-white/[0.04] rounded-xl p-3 space-y-2">
                  <div className="flex items-center gap-2">
                    <input value={svc.name} onChange={e => setServices(prev => prev.map((s, idx) => idx === i ? { ...s, name: e.target.value } : s))}
                      placeholder="Nom du service" className="flex-1 bg-transparent border-b border-white/[0.06] pb-1 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 font-medium" />
                    {services.length > 1 && (
                      <button onClick={() => setServices(prev => prev.filter((_, idx) => idx !== i))} className="text-gray-500 hover:text-red-400 p-1"><Trash2 size={12} /></button>
                    )}
                  </div>
                  <input value={svc.description} onChange={e => setServices(prev => prev.map((s, idx) => idx === i ? { ...s, description: e.target.value } : s))}
                    placeholder="Description courte..." className="w-full bg-transparent text-sm text-gray-400 focus:outline-none" />
                </div>
              ))}
            </div>
          </div>

          {/* Key Pages */}
          <div className="ninja-card p-6">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider">Pages Clés</h3>
              <button onClick={() => setKeyPages(prev => [...prev, { title: '', url: '', description: '' }])}
                className="flex items-center gap-1 text-xs text-purple-400 hover:text-purple-300 transition-colors">
                <Plus size={12} /> Ajouter
              </button>
            </div>
            <div className="space-y-3">
              {keyPages.map((page, i) => (
                <div key={i} className="bg-white/[0.02] border border-white/[0.04] rounded-xl p-3 space-y-2">
                  <div className="flex items-center gap-2">
                    <input value={page.title} onChange={e => setKeyPages(prev => prev.map((p, idx) => idx === i ? { ...p, title: e.target.value } : p))}
                      placeholder="Titre de la page" className="flex-1 bg-transparent border-b border-white/[0.06] pb-1 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 font-medium" />
                    {keyPages.length > 1 && (
                      <button onClick={() => setKeyPages(prev => prev.filter((_, idx) => idx !== i))} className="text-gray-500 hover:text-red-400 p-1"><Trash2 size={12} /></button>
                    )}
                  </div>
                  <input value={page.url} onChange={e => setKeyPages(prev => prev.map((p, idx) => idx === i ? { ...p, url: e.target.value } : p))}
                    placeholder="/pricing, /about, /docs..." className="w-full bg-transparent text-xs text-gray-500 focus:outline-none" />
                  <input value={page.description} onChange={e => setKeyPages(prev => prev.map((p, idx) => idx === i ? { ...p, description: e.target.value } : p))}
                    placeholder="Description de la page..." className="w-full bg-transparent text-sm text-gray-400 focus:outline-none" />
                </div>
              ))}
            </div>
          </div>

          {/* Contact & Social */}
          <div className="ninja-card p-6">
            <h3 className="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Contact & Réseaux</h3>
            <div className="space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5"><Mail size={12} /> Email <span className="text-red-400">*</span></label>
                  <input value={contactEmail} onChange={e => setContactEmail(e.target.value)} placeholder="contact@example.com" type="email"
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5"><Phone size={12} /> Téléphone</label>
                  <input value={contactPhone} onChange={e => setContactPhone(e.target.value)} placeholder="+33 1 23 45 67 89"
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
                </div>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5"><MapPin size={12} /> Adresse</label>
                <input value={contactAddress} onChange={e => setContactAddress(e.target.value)} placeholder="123 Rue Example, 75001 Paris"
                  className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors" />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-1.5 flex items-center gap-1.5"><Link size={12} /> Réseaux sociaux (un par ligne)</label>
                <textarea value={socialLinks} onChange={e => setSocialLinks(e.target.value)} rows={3}
                  placeholder={"https://twitter.com/monentreprise\nhttps://linkedin.com/company/monentreprise\nhttps://github.com/monentreprise"}
                  className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50 transition-colors resize-none" />
              </div>
            </div>
          </div>

          {/* Generate Button */}
          {activeTab === 'llms-txt' ? (
            <button onClick={handleGenerateTxt} disabled={isGenerating || !isValid}
              className={`w-full py-3.5 rounded-2xl font-semibold text-sm flex items-center justify-center gap-2 transition-all duration-300 ${
                isGenerating || !isValid ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'btn-gradient text-white hover:shadow-xl hover:shadow-purple-900/30 hover:-translate-y-0.5'
              }`}>
              {isGeneratingTxt ? (<><Loader2 size={16} className="animate-spin" /> Génération llms.txt...</>) : (<><Zap size={16} /> Générer llms.txt ({CREDIT_COST_TXT} Gas)</>)}
            </button>
          ) : (
            <button onClick={handleGenerateJson} disabled={isGenerating || !isValid}
              className={`w-full py-3.5 rounded-2xl font-semibold text-sm flex items-center justify-center gap-2 transition-all duration-300 ${
                isGenerating || !isValid ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'bg-gradient-to-r from-amber-500 to-orange-600 text-white hover:shadow-xl hover:shadow-amber-900/30 hover:-translate-y-0.5'
              }`}>
              {isGeneratingJson ? (<><Loader2 size={16} className="animate-spin" /> Génération llm.json...</>) : (<><Braces size={16} /> Générer llm.json ({CREDIT_COST_JSON} Gas)</>)}
            </button>
          )}
        </div>

        {/* Right — Result */}
        <div className="space-y-6">
          {/* ═══════ llms.txt Tab ═══════ */}
          {activeTab === 'llms-txt' && (
            <>
              {!txtResult && !isGeneratingTxt && (
                <div className="ninja-card p-12 flex flex-col items-center justify-center text-center sticky top-20">
                  <div className="p-4 bg-emerald-500/10 rounded-2xl mb-4">
                    <FileText size={40} className="text-emerald-400" />
                  </div>
                  <h3 className="text-lg font-bold text-gray-300 mb-2">llms.txt</h3>
                  <p className="text-sm text-gray-500 max-w-sm">Remplissez les informations à gauche pour générer votre fichier llms.txt optimisé pour les moteurs de réponse IA</p>
                  <div className="mt-6 text-left w-full max-w-sm">
                    <p className="text-xs text-gray-600 mb-2">Le fichier contiendra :</p>
                    <div className="space-y-1.5">
                      {['Identité & description', 'Liste des services', 'Pages clés avec liens', 'Informations de contact', 'Instructions pour les IA'].map(item => (
                        <div key={item} className="flex items-center gap-2 text-xs text-gray-500">
                          <div className="w-1 h-1 rounded-full bg-emerald-500" />
                          {item}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}

              {isGeneratingTxt && (
                <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
                  <Loader2 size={40} className="text-emerald-400 animate-spin mb-4" />
                  <h3 className="text-lg font-bold text-gray-300 mb-2">Génération en cours...</h3>
                  <p className="text-sm text-gray-500">Structuration de vos informations pour les LLMs</p>
                </div>
              )}

              {txtResult && !isGeneratingTxt && (
                <div className="space-y-4">
                  <div className="grid grid-cols-2 gap-3">
                    <div className="ninja-card p-4 text-center">
                      <p className="text-2xl font-bold text-emerald-400">{txtResult.sections}</p>
                      <p className="text-xs text-gray-500 mt-1">Sections</p>
                    </div>
                    <div className="ninja-card p-4 text-center">
                      <p className="text-2xl font-bold text-purple-400">{txtResult.wordCount}</p>
                      <p className="text-xs text-gray-500 mt-1">Mots</p>
                    </div>
                  </div>
                  <div className="ninja-card overflow-hidden">
                    <div className="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
                      <div className="flex items-center gap-2">
                        <FileText size={14} className="text-emerald-400" />
                        <span className="text-sm font-semibold text-gray-300">llms.txt</span>
                        <span className="text-xs text-gray-500 bg-white/[0.04] px-2 py-0.5 rounded">TXT</span>
                      </div>
                      <div className="flex items-center gap-2">
                        <button onClick={handleCopyTxt} className="flex items-center gap-1.5 text-xs text-gray-400 hover:text-purple-400 transition-colors px-2 py-1 rounded hover:bg-white/[0.04]">
                          {copiedTxt ? <Check size={12} className="text-emerald-400" /> : <Copy size={12} />}
                          {copiedTxt ? 'Copié !' : 'Copier'}
                        </button>
                        <button onClick={handleDownloadTxt} className="flex items-center gap-1.5 text-xs text-gray-400 hover:text-purple-400 transition-colors px-2 py-1 rounded hover:bg-white/[0.04]">
                          <Download size={12} /> Télécharger
                        </button>
                      </div>
                    </div>
                    <pre className="p-4 text-xs text-gray-300 overflow-x-auto max-h-[600px] overflow-y-auto leading-relaxed whitespace-pre-wrap">
                      <code>{txtResult.content}</code>
                    </pre>
                  </div>
                  <div className="ninja-card p-4">
                    <h4 className="text-sm font-semibold text-gray-300 mb-2 flex items-center gap-2">
                      <Globe size={14} className="text-purple-400" /> Comment déployer
                    </h4>
                    <ol className="space-y-1.5 text-xs text-gray-500">
                      <li>1. Téléchargez le fichier <code className="text-emerald-400">llms.txt</code></li>
                      <li>2. Placez-le à la racine de votre site : <code className="text-emerald-400">{siteUrl}/llms.txt</code></li>
                      <li>3. Ajoutez dans votre <code className="text-emerald-400">robots.txt</code> : <code className="text-purple-300">Sitemap: {siteUrl}/llms.txt</code></li>
                      <li>4. Ajoutez un <code className="text-emerald-400">&lt;link&gt;</code> dans votre <code>&lt;head&gt;</code> : <code className="text-purple-300">&lt;link rel="llms" href="/llms.txt"&gt;</code></li>
                    </ol>
                  </div>
                </div>
              )}
            </>
          )}

          {/* ═══════ llm.json Tab ═══════ */}
          {activeTab === 'llm-json' && (
            <>
              {!jsonResult && !isGeneratingJson && (
                <div className="ninja-card p-12 flex flex-col items-center justify-center text-center sticky top-20">
                  <div className="p-4 bg-amber-500/10 rounded-2xl mb-4">
                    <Braces size={40} className="text-amber-400" />
                  </div>
                  <h3 className="text-lg font-bold text-gray-300 mb-2">llm.json</h3>
                  <p className="text-sm text-gray-500 max-w-sm">Générez votre carte d'identité JSON structurée pour maximiser votre citabilité par les moteurs de réponse IA</p>
                  <div className="mt-6 text-left w-full max-w-sm">
                    <p className="text-xs text-gray-600 mb-2">Le fichier contiendra :</p>
                    <div className="space-y-1.5">
                      {[
                        'Identité & désambiguïsation',
                        'Signaux E-E-A-T (autorité)',
                        'Sources canoniques à citer',
                        'Préférences de citation',
                        'Instructions directes aux LLMs',
                        'Référence Schema.org',
                      ].map(item => (
                        <div key={item} className="flex items-center gap-2 text-xs text-gray-500">
                          <div className="w-1 h-1 rounded-full bg-amber-500" />
                          {item}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}

              {isGeneratingJson && (
                <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
                  <Loader2 size={40} className="text-amber-400 animate-spin mb-4" />
                  <h3 className="text-lg font-bold text-gray-300 mb-2">Génération en cours...</h3>
                  <p className="text-sm text-gray-500">Construction de votre carte d'identité IA structurée</p>
                </div>
              )}

              {jsonResult && !isGeneratingJson && (
                <div className="space-y-4">
                  <div className="grid grid-cols-2 gap-3">
                    <div className="ninja-card p-4 text-center">
                      <p className="text-2xl font-bold text-amber-400">{jsonResult.fieldCount}</p>
                      <p className="text-xs text-gray-500 mt-1">Champs</p>
                    </div>
                    <div className="ninja-card p-4 text-center">
                      <p className="text-2xl font-bold text-purple-400">{(jsonResult.byteSize / 1024).toFixed(1)} KB</p>
                      <p className="text-xs text-gray-500 mt-1">Taille</p>
                    </div>
                  </div>
                  <div className="ninja-card overflow-hidden">
                    <div className="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
                      <div className="flex items-center gap-2">
                        <Braces size={14} className="text-amber-400" />
                        <span className="text-sm font-semibold text-gray-300">llm.json</span>
                        <span className="text-xs text-gray-500 bg-amber-500/10 px-2 py-0.5 rounded text-amber-400/80">JSON</span>
                      </div>
                      <div className="flex items-center gap-2">
                        <button onClick={handleCopyJson} className="flex items-center gap-1.5 text-xs text-gray-400 hover:text-amber-400 transition-colors px-2 py-1 rounded hover:bg-white/[0.04]">
                          {copiedJson ? <Check size={12} className="text-emerald-400" /> : <Copy size={12} />}
                          {copiedJson ? 'Copié !' : 'Copier'}
                        </button>
                        <button onClick={handleDownloadJson} className="flex items-center gap-1.5 text-xs text-gray-400 hover:text-amber-400 transition-colors px-2 py-1 rounded hover:bg-white/[0.04]">
                          <Download size={12} /> Télécharger
                        </button>
                      </div>
                    </div>
                    <pre className="p-4 text-xs text-gray-300 overflow-x-auto max-h-[600px] overflow-y-auto leading-relaxed whitespace-pre-wrap">
                      <code>{jsonResult.content}</code>
                    </pre>
                  </div>
                  <div className="ninja-card p-4">
                    <h4 className="text-sm font-semibold text-gray-300 mb-2 flex items-center gap-2">
                      <Globe size={14} className="text-amber-400" /> Comment déployer
                    </h4>
                    <ol className="space-y-1.5 text-xs text-gray-500">
                      <li>1. Téléchargez le fichier <code className="text-amber-400">llm.json</code></li>
                      <li>2. Placez-le à la racine de votre site : <code className="text-amber-400">{siteUrl}/llm.json</code></li>
                      <li>3. Ajoutez dans votre <code className="text-amber-400">&lt;head&gt;</code> : <code className="text-purple-300">&lt;link rel="llm-identity" type="application/json" href="/llm.json"&gt;</code></li>
                      <li>4. Référencez-le dans votre <code className="text-amber-400">llms.txt</code> : <code className="text-purple-300">Machine-readable version: {siteUrl}/llm.json</code></li>
                      <li>5. Ajoutez dans votre <code className="text-amber-400">robots.txt</code> : <code className="text-purple-300">Allow: /llm.json</code></li>
                    </ol>
                  </div>
                </div>
              )}
            </>
          )}
        </div>
      </div>
    </div>
  );
};

export default LlmsTxtGenerator;
