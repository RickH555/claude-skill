'use client';

import React, { createContext, useContext, useState, useMemo, useCallback, useEffect, useRef } from 'react';
import { useRouter, usePathname } from 'next/navigation';
import { User, AnalysisResult, SMCContent, GeneratedSolution, MegaGenerationStatus } from '@/types';
import { analyzeUrl } from '@/services/analyzer';
import { db } from '@/services/database';
import { megaGenerate } from '@/services/mega-generator';
import { generateAllSolutions } from '@/services/solution-mega-generator';
import { storeInVault, hasVault } from '@/services/solution-vault';
import { VIEW_TO_PATH, getSectionFromPath, getViewNameFromPath, SECTION_DEFAULTS } from '@/lib/route-map';
import { getSectionForPage } from '@/components/layout/AppSidebar';
import type { Section } from '@/components/layout/TopNav';

// Animated number hook for smooth credit transitions
const useAnimatedNumber = (value: number, duration = 600) => {
  const [display, setDisplay] = useState(value);
  const prevValue = useRef(value);
  useEffect(() => {
    if (prevValue.current === value) return;
    const start = prevValue.current;
    const diff = value - start;
    const startTime = performance.now();
    const animate = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      setDisplay(Math.round(start + diff * eased));
      if (progress < 1) requestAnimationFrame(animate);
    };
    requestAnimationFrame(animate);
    prevValue.current = value;
  }, [value, duration]);
  return display;
};

const PLAN_LIMITS = {
  free: 1,
  pro: 3,
  enterprise: 1000
};

export interface AppContextValue {
  // User
  user: User | null;
  animatedCredits: number;
  showOnboarding: boolean;
  setShowOnboarding: (v: boolean) => void;
  showCelebration: boolean;

  // Data
  history: AnalysisResult[];
  analysisData: AnalysisResult | null;
  setAnalysisData: (data: AnalysisResult | null) => void;
  smcLibrary: SMCContent[];
  truthLibrary: SMCContent[];
  schemaLibrary: SMCContent[];
  robotsLibrary: SMCContent[];

  // Status
  megaStatus: MegaGenerationStatus;
  isAnalyzing: boolean;

  // Cross-page params
  resultsTab: 'overview' | 'details' | 'archives' | 'recommendations';
  setResultsTab: (tab: 'overview' | 'details' | 'archives' | 'recommendations') => void;
  publisherRequestData: { topic: string; url: string; brief: string } | null;
  initialRechargePackId: number | null;
  initialAccountTab: 'profile' | 'subscription' | 'billing';

  // Layout
  isSidebarCollapsed: boolean;
  setIsSidebarCollapsed: (v: boolean) => void;
  lowCreditsDismissed: boolean;
  setLowCreditsDismissed: (v: boolean) => void;

  // Computed
  monthlyProjectCount: number;
  maxProjects: number;
  actionPlanStatus: { complete: boolean; completed: number; total: number };

  // Command palette / shortcuts
  isCommandPaletteOpen: boolean;
  setIsCommandPaletteOpen: (v: boolean) => void;
  isShortcutsOpen: boolean;
  setIsShortcutsOpen: (v: boolean) => void;

  // Callbacks
  handleAnalyze: (url: string) => Promise<void>;
  handleDeductCredits: (amount: number) => boolean;
  handleLogin: (user: User) => void;
  handleLogout: () => void;
  handleRecharge: (amount: number, planLevel: 'free' | 'pro' | 'enterprise') => void;
  handleUpgradePlan: (newPlan: 'free' | 'pro' | 'enterprise') => void;
  handleSaveSolution: (analysisId: string, recommendationId: string, solution: GeneratedSolution) => void;
  handleViewAnalysis: (result: AnalysisResult, tab?: 'overview' | 'details' | 'recommendations' | 'preview' | 'archives') => void;
  handleViewDirectoryEntity: (result: AnalysisResult) => void;
  handleUpdateAnalysis: (index: number, updatedData: Partial<AnalysisResult>) => void;
  handleAddToSmcLibrary: (item: SMCContent) => void;
  handleAddToTruthLibrary: (item: SMCContent) => void;
  handleAddToSchemaLibrary: (item: SMCContent) => void;
  handleAddToRobotsLibrary: (item: SMCContent) => void;
  handleNavigateToPublisher: (data: { topic: string; url: string; brief: string }) => void;
  handleNavigateToDirectory: () => void;
  handleDirectRecharge: (packId: number) => void;

  // Navigation
  navigateTo: (view: string) => void;
  goBack: () => void;
  handleSectionChange: (section: Section) => void;
  activeSection: Section;
}

const AppContext = createContext<AppContextValue | null>(null);

export function useAppContext(): AppContextValue {
  const ctx = useContext(AppContext);
  if (!ctx) throw new Error('useAppContext must be used within AppProvider');
  return ctx;
}

export function AppProvider({ children }: { children: React.ReactNode }) {
  const router = useRouter();
  const pathname = usePathname() ?? '/';

  // ── User ──
  const [user, setUser] = useState<User | null>(null);
  const animatedCredits = useAnimatedNumber(user?.credits ?? 0);
  const [showOnboarding, setShowOnboarding] = useState(false);
  const [showCelebration, setShowCelebration] = useState(false);

  // ── Data ──
  const [analysisData, setAnalysisData] = useState<AnalysisResult | null>(null);
  const [history, setHistory] = useState<AnalysisResult[]>([]);
  const [smcLibrary, setSmcLibrary] = useState<SMCContent[]>([]);
  const [truthLibrary, setTruthLibrary] = useState<SMCContent[]>([]);
  const [schemaLibrary, setSchemaLibrary] = useState<SMCContent[]>([]);
  const [robotsLibrary, setRobotsLibrary] = useState<SMCContent[]>([]);

  // ── Status ──
  const [megaStatus, setMegaStatus] = useState<MegaGenerationStatus>('idle');
  const [isAnalyzing, setIsAnalyzing] = useState(false);

  // ── Cross-page params ──
  const [resultsTab, setResultsTab] = useState<'overview' | 'details' | 'archives' | 'recommendations'>('overview');
  const [publisherRequestData, setPublisherRequestData] = useState<{ topic: string; url: string; brief: string } | null>(null);
  const [initialRechargePackId, setInitialRechargePackId] = useState<number | null>(null);
  const [initialAccountTab, setInitialAccountTab] = useState<'profile' | 'subscription' | 'billing'>('profile');

  // ── Layout ──
  const [isSidebarCollapsed, setIsSidebarCollapsed] = useState(false);
  const [lowCreditsDismissed, setLowCreditsDismissed] = useState(false);

  // ── Command palette / shortcuts ──
  const [isCommandPaletteOpen, setIsCommandPaletteOpen] = useState(false);
  const [isShortcutsOpen, setIsShortcutsOpen] = useState(false);

  // ── Active section derived from pathname ──
  const activeSection = useMemo(() => getSectionFromPath(pathname), [pathname]);

  // ── Load history from localStorage on mount ──
  useEffect(() => {
    setHistory(db.getAll());
  }, []);

  // ── Onboarding ──
  useEffect(() => {
    if (user && !localStorage.getItem('citedby_onboarded')) {
      setShowOnboarding(true);
    }
  }, [user]);

  // ── Monthly project count ──
  const monthlyProjectCount = useMemo(() => {
    if (history.length === 0) return 0;
    const now = new Date();
    const billingCycleStart = new Date(now.getFullYear(), now.getMonth(), 1);
    const projectCreationDates = new Map<string, Date>();
    history.forEach(h => {
      let hostname: string;
      try { hostname = new URL(h.url).hostname; } catch { hostname = h.url; }
      const analysisDate = new Date(h.timestamp);
      if (!projectCreationDates.has(hostname) || analysisDate < projectCreationDates.get(hostname)!) {
        projectCreationDates.set(hostname, analysisDate);
      }
    });
    let count = 0;
    projectCreationDates.forEach((creationDate) => {
      if (creationDate >= billingCycleStart) count++;
    });
    return count;
  }, [history]);

  const maxProjects = user ? PLAN_LIMITS[user.plan] : 1;

  // ── Action plan status ──
  const actionPlanStatus = useMemo(() => {
    if (history.length === 0) return { complete: false, completed: 0, total: 0 };
    const latest = history[history.length - 1];
    const total = latest.recommendations.length;
    const completed = latest.recommendations.filter(rec => latest.generatedSolutions?.[rec.id]).length;
    return { complete: total > 0 && completed === total, completed, total };
  }, [history]);

  // ── Navigation ──
  const navigateTo = useCallback((view: string) => {
    if (view !== 'recharge') setInitialRechargePackId(null);
    if (view !== 'account') setInitialAccountTab('profile');
    const path = VIEW_TO_PATH[view];
    if (path) {
      router.push(path);
    }
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }, [router]);

  const goBack = useCallback(() => {
    router.back();
  }, [router]);

  const handleSectionChange = useCallback((section: Section) => {
    router.push(SECTION_DEFAULTS[section]);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }, [router]);

  // ── Analysis handler ──
  const handleAnalyze = useCallback(async (url: string) => {
    if (user) {
      const limit = PLAN_LIMITS[user.plan] || 1;
      let hostname = url;
      try { hostname = new URL(url).hostname; } catch { /* keep raw */ }
      const isExistingProject = history.some(h => {
        try { return new URL(h.url).hostname === hostname; }
        catch { return false; }
      });
      if (!isExistingProject && monthlyProjectCount >= limit) {
        alert(`Limite de nouveaux projets atteinte pour ce mois (${monthlyProjectCount}/${limit}). Passez au plan superieur pour ajouter plus de projets.`);
        setInitialAccountTab('subscription');
        navigateTo('account');
        return;
      }
    }

    setIsAnalyzing(true);
    try {
      const result = await analyzeUrl(url);
      setAnalysisData(result);
      const updatedHistory = db.add(result);
      setHistory(updatedHistory);

      if (history.length === 0) {
        setShowCelebration(true);
        setTimeout(() => setShowCelebration(false), 3000);
      }

      // Pre-generation en arriere-plan
      setMegaStatus('generating');
      megaGenerate(url).then(cache => {
        if (cache) {
          const preGenerated = { status: 'completed' as const, generatedAt: new Date().toISOString(), ...cache };
          setHistory(prev => {
            if (prev.length === 0) return prev;
            const updated = { ...prev[0], preGenerated };
            db.update(0, updated);
            return [updated, ...prev.slice(1)];
          });
          setAnalysisData(prev => prev ? { ...prev, preGenerated } : prev);
          setMegaStatus('completed');
        } else {
          setMegaStatus('failed');
        }
      }).catch(() => setMegaStatus('failed'));

      // Solution mega-generation
      const auditId = result.timestamp;
      if (!hasVault(auditId)) {
        const failedCriteria = result.recommendations.map(rec => ({
          id: rec.id,
          name: rec.title,
          category: rec.category,
          maxPoints: rec.priority === 'critical' ? 5 : rec.priority === 'high' ? 4 : rec.priority === 'medium' ? 3 : 1,
        }));
        let hostname = url;
        try { hostname = new URL(url).hostname; } catch { /* keep raw */ }
        generateAllSolutions(
          url, hostname,
          result.recommendations.map(r => r.title).join('. '),
          failedCriteria, [], hostname, 'fr'
        ).then(megaResult => {
          storeInVault(auditId, megaResult);
        }).catch(err => {
          console.error('[SolutionMegaGen] Erreur:', err);
        });
      }

      setResultsTab('details');
      navigateTo('projects');
    } catch (error) {
      console.error("Analysis failed", error);
      alert("Erreur lors de l'analyse. Veuillez reessayer.");
    } finally {
      setIsAnalyzing(false);
    }
  }, [user, history, monthlyProjectCount, navigateTo]);

  // ── View analysis ──
  const handleViewAnalysis = useCallback((result: AnalysisResult, tab: 'overview' | 'details' | 'recommendations' | 'preview' | 'archives' = 'overview') => {
    setAnalysisData(result);
    setResultsTab(tab as typeof resultsTab);
    navigateTo('projects');
  }, [navigateTo]);

  const handleViewDirectoryEntity = useCallback((result: AnalysisResult) => {
    setAnalysisData(result);
    navigateTo('directory-entity');
  }, [navigateTo]);

  const handleUpdateAnalysis = useCallback((index: number, updatedData: Partial<AnalysisResult>) => {
    const updatedHistory = db.update(index, updatedData);
    setHistory(updatedHistory);
  }, []);

  const handleSaveSolution = useCallback((analysisId: string, recommendationId: string, solution: GeneratedSolution) => {
    const timestamp = new Date().toISOString();
    const solutionWithMeta = { ...solution, timestamp };
    setAnalysisData(prev => {
      if (!prev || prev.timestamp !== analysisId) return prev;
      return {
        ...prev,
        generatedSolutions: {
          ...(prev.generatedSolutions || {}),
          [recommendationId]: solutionWithMeta
        }
      };
    });
    setHistory(prevHistory => {
      const index = prevHistory.findIndex(item => item.timestamp === analysisId);
      if (index !== -1) {
        const updatedItem = {
          ...prevHistory[index],
          generatedSolutions: {
            ...(prevHistory[index].generatedSolutions || {}),
            [recommendationId]: solutionWithMeta
          }
        };
        const newHistory = [...prevHistory];
        newHistory[index] = updatedItem;
        db.update(index, updatedItem);
        return newHistory;
      }
      return prevHistory;
    });
  }, []);

  // ── Library handlers ──
  const handleAddToSmcLibrary = useCallback((item: SMCContent) => setSmcLibrary(prev => [item, ...prev]), []);
  const handleAddToTruthLibrary = useCallback((item: SMCContent) => setTruthLibrary(prev => [item, ...prev]), []);
  const handleAddToSchemaLibrary = useCallback((item: SMCContent) => setSchemaLibrary(prev => [item, ...prev]), []);
  const handleAddToRobotsLibrary = useCallback((item: SMCContent) => setRobotsLibrary(prev => [item, ...prev]), []);

  const handleNavigateToPublisher = useCallback((data: { topic: string; url: string; brief: string }) => {
    setPublisherRequestData(data);
    navigateTo('publisher-request');
  }, [navigateTo]);

  const handleNavigateToDirectory = useCallback(() => navigateTo('directory'), [navigateTo]);

  const handleDirectRecharge = useCallback((packId: number) => {
    setInitialRechargePackId(packId);
    navigateTo('recharge');
  }, [navigateTo]);

  // ── Credits ──
  const handleDeductCredits = useCallback((amount: number): boolean => {
    if (!user) {
      if (confirm("Vous devez etre connecte pour effectuer cette action. Se connecter maintenant ?")) {
        navigateTo('login');
      }
      return false;
    }
    if (user.credits < amount) {
      alert(`Solde GTO Gas insuffisant pour generer cette solution.\n\nIl vous manque ${amount - user.credits} credits.\n\nRedirection vers la station de recharge...`);
      navigateTo('recharge');
      return false;
    }
    setUser(prev => prev ? { ...prev, credits: prev.credits - amount } : null);
    return true;
  }, [user, navigateTo]);

  const handleRecharge = useCallback((amount: number, planLevel: 'free' | 'pro' | 'enterprise') => {
    if (!user) return;
    setUser({ ...user, credits: user.credits + amount, plan: planLevel });
  }, [user]);

  const handleUpgradePlan = useCallback((newPlan: 'free' | 'pro' | 'enterprise') => {
    if (!user) return;
    setUser({ ...user, plan: newPlan });
  }, [user]);

  // ── Auth ──
  const handleLogin = useCallback((loggedInUser: User) => {
    setUser(loggedInUser);
    router.push('/analyze');
  }, [router]);

  const handleLogout = useCallback(() => {
    setUser(null);
    router.push('/');
  }, [router]);

  const value: AppContextValue = {
    user, animatedCredits, showOnboarding, setShowOnboarding, showCelebration,
    history, analysisData, setAnalysisData, smcLibrary, truthLibrary, schemaLibrary, robotsLibrary,
    megaStatus, isAnalyzing,
    resultsTab, setResultsTab, publisherRequestData, initialRechargePackId, initialAccountTab,
    isSidebarCollapsed, setIsSidebarCollapsed, lowCreditsDismissed, setLowCreditsDismissed,
    monthlyProjectCount, maxProjects, actionPlanStatus,
    isCommandPaletteOpen, setIsCommandPaletteOpen, isShortcutsOpen, setIsShortcutsOpen,
    handleAnalyze, handleDeductCredits, handleLogin, handleLogout,
    handleRecharge, handleUpgradePlan, handleSaveSolution,
    handleViewAnalysis, handleViewDirectoryEntity, handleUpdateAnalysis,
    handleAddToSmcLibrary, handleAddToTruthLibrary, handleAddToSchemaLibrary, handleAddToRobotsLibrary,
    handleNavigateToPublisher, handleNavigateToDirectory, handleDirectRecharge,
    navigateTo, goBack, handleSectionChange, activeSection,
  };

  return <AppContext.Provider value={value}>{children}</AppContext.Provider>;
}
