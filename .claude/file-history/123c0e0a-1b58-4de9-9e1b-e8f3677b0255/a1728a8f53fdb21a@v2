// ============================================
// CitedBy.ai - API Developer Types
// ============================================

export type ApiKeyStatus = 'active' | 'revoked'
export type HttpMethod = 'GET' | 'POST' | 'PUT' | 'DELETE'
export type PlanTier = 'free' | 'pro' | 'enterprise'
export type WebhookEvent = 'audit.completed' | 'monitoring.scan_completed' | 'monitoring.alert' | 'credits.low' | 'citations.new'

export interface ApiKey {
  id: string
  name: string
  key: string
  createdAt: string
  status: ApiKeyStatus
  lastUsed: string | null
}

export interface ApiEndpoint {
  method: HttpMethod
  path: string
  description: string
  gasCost: number
  params: EndpointParam[]
  exampleResponse: string
}

export interface EndpointParam {
  name: string
  type: string
  required: boolean
  description: string
}

export interface Webhook {
  id: string
  url: string
  events: WebhookEvent[]
  active: boolean
  lastDelivery: string | null
  createdAt: string
}

export interface ApiUsageDay {
  date: string
  success: number
  errors: number
}

export interface ApiUsageKPI {
  requestsPerDay: number
  errorRate: number
  avgLatency: number
}

export interface RateLimit {
  tier: PlanTier
  limit: number
}
