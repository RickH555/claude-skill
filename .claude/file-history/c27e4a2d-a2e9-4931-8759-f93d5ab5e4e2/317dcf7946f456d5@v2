// ──────────────────────────────────────────
// RoyallAzz — Database type definitions
// Matches the REMOTE Supabase schema
// ──────────────────────────────────────────

export interface Merchant {
  id: string;
  user_id: string;
  name: string;
  logo_url: string | null;
  address: string | null;
  category: string | null;
  plan: 'free' | 'pro' | 'business';
  subscription_status: string;
  stripe_customer_id: string | null;
  created_at: string;
  updated_at: string;
  phone: string | null;
  opening_hours: string | null;
  ai_campaigns_mode: string;
  max_push_per_week: number;
}

export interface LoyaltyProgram {
  id: string;
  merchant_id: string;
  name: string;
  type: 'stamp' | 'points';
  stamp_goal: number | null;
  points_per_euro: number | null;
  reward_description: string | null;
  expiration_days: number | null;
  welcome_bonus_stamps: number | null;
  welcome_bonus_points: number | null;
  is_active: boolean;
  created_at: string;
  updated_at: string;
}

export interface Reward {
  id: string;
  program_id: string;
  name: string;
  description: string | null;
  points_cost: number | null;
  stamps_required: number | null;
  discount_type: string | null;
  discount_value: number | null;
  is_active: boolean;
  created_at: string;
}

export interface Customer {
  id: string;
  email: string;
  name: string | null;
  phone: string | null;
  push_token: string | null;
  preferred_language: string | null;
  created_at: string;
  updated_at: string;
}

export interface CustomerCard {
  id: string;
  customer_id: string;
  program_id: string;
  current_stamps: number;
  current_points: number;
  tier: string;
  last_activity: string | null;
  created_at: string;
}

export interface Transaction {
  id: string;
  card_id: string;
  type: 'earn' | 'redeem';
  value: number;
  validated_by: string | null;
  created_at: string;
}

export interface QrCode {
  id: string;
  merchant_id: string;
  program_id: string;
  label: string | null;
  secret_key: string;
  is_active: boolean;
  created_at: string;
  location_id: string | null;
}

export interface CustomerQrCode {
  id: string;
  customer_id: string;
  qr_secret: string;
  is_active: boolean;
  created_at: string;
}

// Helpers
export function getBalance(card: CustomerCard, type: 'stamp' | 'points'): number {
  return type === 'stamp' ? card.current_stamps : card.current_points;
}

export function getTarget(program: LoyaltyProgram): number {
  return program.type === 'stamp' ? (program.stamp_goal || 10) : (program.points_per_euro || 100);
}

export function getWelcomeBonus(program: LoyaltyProgram): number {
  return program.type === 'stamp'
    ? (program.welcome_bonus_stamps || 0)
    : (program.welcome_bonus_points || 0);
}
