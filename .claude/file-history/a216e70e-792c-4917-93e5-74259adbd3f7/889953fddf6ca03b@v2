import React, { useState } from 'react';
import { User as UserIcon, Mail, Shield, Crown, CreditCard, FileText, Check, ArrowRight, Loader2, Zap, Calendar, Download, ExternalLink } from 'lucide-react';
import { User } from '../types';
import StripeCheckout from '../components/StripeCheckout';

interface AccountProps {
  user: User | null;
  onLogout: () => void;
  onNavigate: (view: any) => void;
  onUpgrade: (plan: 'free' | 'pro' | 'enterprise') => void;
  initialTab?: 'profile' | 'subscription' | 'billing';
}

const Account: React.FC<AccountProps> = ({ user, onLogout, onNavigate, onUpgrade, initialTab = 'profile' }) => {
  const [activeTab, setActiveTab] = useState<'profile' | 'subscription' | 'billing'>(initialTab);
  const [editName, setEditName] = useState(user?.name || '');
  const [editEmail, setEditEmail] = useState(user?.email || '');
  const [isSaving, setIsSaving] = useState(false);
  const [showUpgradeModal, setShowUpgradeModal] = useState(false);
  const [upgradePlan, setUpgradePlan] = useState<'pro' | 'enterprise'>('pro');
  const [upgradeStep, setUpgradeStep] = useState<'select' | 'checkout' | 'success'>('select');

  const handleSaveProfile = async () => {
    setIsSaving(true);
    await new Promise(r => setTimeout(r, 1000));
    setIsSaving(false);
  };

  const plans = [
    { id: 'free' as const, name: 'Starter', price: 0, period: '/mois', features: ['50 cr\u00e9dits/mois', '1 audit/jour', 'Dashboard basique', 'Support email'], current: user?.plan === 'free' },
    { id: 'pro' as const, name: 'Pro', price: 89, period: '/mois', features: ['500 cr\u00e9dits/mois', 'Audits illimit\u00e9s', 'Monitoring IA complet', 'Support prioritaire', 'API Beta'], current: user?.plan === 'pro', popular: true },
    { id: 'enterprise' as const, name: 'Agency', price: 299, period: '/mois', features: ['2000 cr\u00e9dits/mois', 'Tout illimit\u00e9', 'Support d\u00e9di\u00e9', 'API compl\u00e8te', 'Multi-utilisateurs', 'Formations incluses'], current: user?.plan === 'enterprise' },
  ];

  const invoices = [
    { id: 'INV-2026-001', date: '2026-02-15', amount: '49.00\u20ac', status: 'Pay\u00e9e', type: 'GTO Gas - La Pompe' },
    { id: 'INV-2026-002', date: '2026-01-20', amount: '15.00\u20ac', status: 'Pay\u00e9e', type: 'GTO Gas - Le Jerrican' },
    { id: 'INV-2025-012', date: '2025-12-10', amount: '89.00\u20ac', status: 'Pay\u00e9e', type: 'Abonnement Pro' },
  ];

  const handleUpgrade = (plan: 'pro' | 'enterprise') => {
    setUpgradePlan(plan);
    setUpgradeStep('checkout');
    setShowUpgradeModal(true);
  };

  const handleUpgradeSuccess = () => {
    onUpgrade(upgradePlan);
    setUpgradeStep('success');
  };

  return (
    <div className="w-full px-6 py-8 animate-in fade-in duration-500">
      <h1 className="text-3xl font-bold text-white mb-2">Compte & <span className="gradient-text">Plan</span></h1>
      <p className="text-gray-500 text-sm mb-8">G\u00e9rez votre profil, abonnement et facturation.</p>

      {/* Tabs */}
      <div className="flex gap-1 bg-white/[0.03] rounded-xl p-1 mb-8 w-fit">
        {(['profile', 'subscription', 'billing'] as const).map(tab => (
          <button key={tab} onClick={() => setActiveTab(tab)} className={`px-5 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === tab ? 'bg-amber-500/20 text-amber-300 border border-amber-500/20' : 'text-gray-500 hover:text-gray-300'}`}>
            {tab === 'profile' ? 'Profil' : tab === 'subscription' ? 'Abonnement' : 'Facturation'}
          </button>
        ))}
      </div>

      {/* Profile Tab */}
      {activeTab === 'profile' && (
        <div className="max-w-2xl">
          <div className="ninja-card p-6 mb-6">
            <h3 className="text-lg font-bold text-white mb-4">Informations personnelles</h3>
            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">Nom complet</label>
                <div className="relative">
                  <UserIcon className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500" size={16} />
                  <input type="text" value={editName} onChange={e => setEditName(e.target.value)} className="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-3 pl-10 pr-4 text-white placeholder-gray-600 focus:border-amber-500/50 outline-none transition-all" />
                </div>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">Email</label>
                <div className="relative">
                  <Mail className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500" size={16} />
                  <input type="email" value={editEmail} onChange={e => setEditEmail(e.target.value)} className="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-3 pl-10 pr-4 text-white placeholder-gray-600 focus:border-amber-500/50 outline-none transition-all" />
                </div>
              </div>
              <button onClick={handleSaveProfile} disabled={isSaving} className="btn-gradient px-6 py-2.5 font-bold flex items-center gap-2">
                {isSaving ? <Loader2 size={16} className="animate-spin" /> : 'Sauvegarder'}
              </button>
            </div>
          </div>

          <div className="ninja-card p-6 mb-6">
            <h3 className="text-lg font-bold text-white mb-4">S\u00e9curit\u00e9</h3>
            <div className="space-y-3">
              <div className="flex items-center justify-between p-3 bg-white/[0.02] rounded-xl border border-white/[0.06]">
                <div className="flex items-center gap-3"><Shield size={16} className="text-amber-400" /><span className="text-sm text-gray-300">Mot de passe</span></div>
                <button className="text-xs text-amber-400 hover:text-amber-300 font-medium">Modifier</button>
              </div>
              <div className="flex items-center justify-between p-3 bg-white/[0.02] rounded-xl border border-white/[0.06]">
                <div className="flex items-center gap-3"><Shield size={16} className="text-gray-500" /><span className="text-sm text-gray-300">Double authentification</span></div>
                <span className="text-xs text-gray-500">Bient\u00f4t disponible</span>
              </div>
            </div>
          </div>

          <div className="ninja-card p-6 border-red-500/10">
            <h3 className="text-lg font-bold text-white mb-2">Zone danger</h3>
            <p className="text-sm text-gray-500 mb-4">Actions irr\u00e9versibles sur votre compte.</p>
            <div className="flex gap-3">
              <button onClick={onLogout} className="px-4 py-2 text-sm text-red-400 border border-red-500/20 rounded-xl hover:bg-red-500/10 transition-colors">D\u00e9connexion</button>
              <button className="px-4 py-2 text-sm text-gray-500 border border-white/[0.06] rounded-xl hover:bg-white/[0.04] transition-colors">Supprimer le compte</button>
            </div>
          </div>
        </div>
      )}

      {/* Subscription Tab */}
      {activeTab === 'subscription' && (
        <div>
          <div className="ninja-card p-6 mb-8">
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-4">
                <div className="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center"><Crown size={24} className="text-white" /></div>
                <div>
                  <h3 className="text-lg font-bold text-white">Plan {user?.plan === 'enterprise' ? 'Agency' : user?.plan === 'pro' ? 'Pro' : 'Starter'}</h3>
                  <p className="text-sm text-gray-500">Votre plan actuel</p>
                </div>
              </div>
              <div className="text-right">
                <div className="text-sm text-amber-400 flex items-center gap-1"><Zap size={14} /> {user?.credits} cr\u00e9dits</div>
              </div>
            </div>
          </div>

          <div className="grid md:grid-cols-3 gap-6">
            {plans.map(plan => (
              <div key={plan.id} className={`ninja-card p-6 relative flex flex-col ${plan.current ? 'border-amber-500/30' : ''} ${plan.popular ? 'shadow-lg shadow-amber-900/10' : ''}`}>
                {plan.popular && <div className="absolute top-0 right-6 px-3 py-1 bg-gradient-to-r from-amber-500 to-amber-700 text-xs font-bold rounded-b-lg text-white">Recommand\u00e9</div>}
                {plan.current && <div className="absolute top-3 left-3 px-2 py-0.5 bg-amber-500/20 text-amber-400 text-[10px] font-bold rounded-full border border-amber-500/20">Actuel</div>}
                <h3 className="text-lg font-bold text-white mt-2 mb-1">{plan.name}</h3>
                <div className="text-3xl font-bold text-white mb-4">{plan.price}<span className="text-sm text-gray-500 font-normal">\u20ac{plan.period}</span></div>
                <ul className="space-y-2 mb-6 flex-1">
                  {plan.features.map(f => <li key={f} className="flex items-center gap-2 text-sm text-gray-400"><Check size={14} className="text-amber-400 shrink-0" />{f}</li>)}
                </ul>
                {plan.current ? (
                  <button disabled className="w-full py-2.5 rounded-full border border-amber-500/20 text-amber-400 text-sm font-medium opacity-50 cursor-not-allowed">Plan actuel</button>
                ) : plan.id !== 'free' ? (
                  <button onClick={() => handleUpgrade(plan.id as 'pro' | 'enterprise')} className="btn-gradient w-full py-2.5 font-bold text-sm">Passer au {plan.name}</button>
                ) : null}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Billing Tab */}
      {activeTab === 'billing' && (
        <div className="max-w-3xl">
          <div className="ninja-card p-6">
            <h3 className="text-lg font-bold text-white mb-4 flex items-center gap-2"><FileText size={20} className="text-amber-400" /> Historique de facturation</h3>
            <div className="overflow-x-auto">
              <table className="w-full text-left text-sm">
                <thead><tr className="text-gray-500 border-b border-white/[0.06]"><th className="pb-3 font-medium">Facture</th><th className="pb-3 font-medium">Date</th><th className="pb-3 font-medium">Type</th><th className="pb-3 font-medium">Montant</th><th className="pb-3 font-medium">Statut</th><th className="pb-3"></th></tr></thead>
                <tbody>
                  {invoices.map(inv => (
                    <tr key={inv.id} className="border-b border-white/[0.06] last:border-0">
                      <td className="py-3 text-gray-300 font-mono text-xs">{inv.id}</td>
                      <td className="py-3 text-gray-500">{inv.date}</td>
                      <td className="py-3 text-gray-400">{inv.type}</td>
                      <td className="py-3 text-white font-semibold">{inv.amount}</td>
                      <td className="py-3"><span className="px-2 py-0.5 bg-green-500/20 text-green-400 text-[10px] rounded-full font-bold">{inv.status}</span></td>
                      <td className="py-3"><button className="text-amber-400 hover:text-amber-300"><Download size={14} /></button></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <div className="ninja-card p-6 mt-6">
            <h3 className="text-lg font-bold text-white mb-4 flex items-center gap-2"><CreditCard size={20} className="text-amber-400" /> Moyen de paiement</h3>
            <div className="flex items-center justify-between p-4 bg-white/[0.02] rounded-xl border border-white/[0.06]">
              <div className="flex items-center gap-3">
                <div className="w-10 h-6 bg-gradient-to-r from-blue-600 to-blue-800 rounded flex items-center justify-center text-white text-[8px] font-bold">VISA</div>
                <span className="text-sm text-gray-300">**** **** **** 4242</span>
              </div>
              <button className="text-xs text-amber-400 hover:text-amber-300 font-medium">Modifier</button>
            </div>
          </div>
        </div>
      )}

      {/* Upgrade Modal */}
      {showUpgradeModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4" onClick={() => { setShowUpgradeModal(false); setUpgradeStep('select'); }}>
          <div className="absolute inset-0 bg-black/80 backdrop-blur-sm" />
          <div className="relative w-full max-w-md bg-[#13131d] border border-white/[0.1] rounded-2xl shadow-2xl p-6" onClick={e => e.stopPropagation()}>
            {upgradeStep === 'checkout' && (
              <>
                <h3 className="text-lg font-bold text-white mb-4">Passer au plan {upgradePlan === 'pro' ? 'Pro' : 'Agency'}</h3>
                <div className="mb-4 p-3 bg-white/[0.03] rounded-xl border border-white/[0.06] flex justify-between">
                  <span className="text-sm text-gray-400">Montant mensuel</span>
                  <span className="text-sm font-bold text-white">{upgradePlan === 'pro' ? '89' : '299'}\u20ac/mois</span>
                </div>
                <StripeCheckout
                  amount={upgradePlan === 'pro' ? 89 : 299}
                  label={`S'abonner au plan ${upgradePlan === 'pro' ? 'Pro' : 'Agency'}`}
                  onSuccess={handleUpgradeSuccess}
                  onCancel={() => { setShowUpgradeModal(false); setUpgradeStep('select'); }}
                />
              </>
            )}
            {upgradeStep === 'success' && (
              <div className="text-center py-4">
                <div className="w-16 h-16 rounded-full bg-amber-500/20 flex items-center justify-center mx-auto mb-4"><Check size={32} className="text-amber-400" /></div>
                <h3 className="text-xl font-bold text-white mb-2">Bienvenue sur {upgradePlan === 'pro' ? 'Pro' : 'Agency'} !</h3>
                <p className="text-gray-400 text-sm mb-6">Votre plan a \u00e9t\u00e9 mis \u00e0 jour avec succ\u00e8s.</p>
                <button onClick={() => { setShowUpgradeModal(false); setUpgradeStep('select'); }} className="btn-gradient px-8 py-2.5 font-bold">Fermer</button>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
};

export default Account;
