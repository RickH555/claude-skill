'use client';

import { useState } from 'react';
import {
  Bot,
  Sparkles,
  Loader2,
  Copy,
  Check,
  Download,
  Shield,
  ShieldOff,
  ToggleLeft,
  ToggleRight,
} from 'lucide-react';
import { PageHeader } from '@/components/page-header';
import { Button } from '@/components/ui/button';
import { Card } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { CodeBlock } from '@/components/code-block';

const AI_BOTS = [
  { id: 'GPTBot', name: 'GPTBot', engine: 'ChatGPT / OpenAI', description: 'Crawler d\'OpenAI pour ChatGPT' },
  { id: 'ChatGPT-User', name: 'ChatGPT-User', engine: 'ChatGPT', description: 'Requetes utilisateur ChatGPT' },
  { id: 'anthropic-ai', name: 'anthropic-ai', engine: 'Claude', description: 'Crawler d\'Anthropic' },
  { id: 'ClaudeBot', name: 'ClaudeBot', engine: 'Claude', description: 'Bot Claude pour l\'indexation' },
  { id: 'Google-Extended', name: 'Google-Extended', engine: 'Gemini', description: 'Crawler de Google pour l\'IA' },
  { id: 'PerplexityBot', name: 'PerplexityBot', engine: 'Perplexity', description: 'Crawler de Perplexity' },
  { id: 'Bytespider', name: 'Bytespider', engine: 'TikTok / ByteDance', description: 'Crawler de ByteDance' },
  { id: 'CCBot', name: 'CCBot', engine: 'Common Crawl', description: 'Crawler Common Crawl (datasets IA)' },
];

const PLATFORMS = [
  { id: 'wordpress', label: 'WordPress' },
  { id: 'nextjs', label: 'Next.js' },
  { id: 'shopify', label: 'Shopify' },
  { id: 'custom', label: 'Custom' },
];

export default function RobotsTxtPage() {
  const [platform, setPlatform] = useState('nextjs');
  const [sitemapUrl, setSitemapUrl] = useState('');
  const [botStates, setBotStates] = useState<Record<string, boolean>>(
    Object.fromEntries(AI_BOTS.map((bot) => [bot.id, true]))
  );
  const [generating, setGenerating] = useState(false);
  const [result, setResult] = useState<string | null>(null);
  const [copied, setCopied] = useState(false);

  const toggleBot = (botId: string) => {
    setBotStates((prev) => ({ ...prev, [botId]: !prev[botId] }));
  };

  const allowAll = () => {
    setBotStates(Object.fromEntries(AI_BOTS.map((bot) => [bot.id, true])));
  };

  const blockAll = () => {
    setBotStates(Object.fromEntries(AI_BOTS.map((bot) => [bot.id, false])));
  };

  const handleGenerate = () => {
    setGenerating(true);

    setTimeout(() => {
      const lines: string[] = [
        '# robots.txt - Generated by CitedBy.ai',
        `# Platform: ${platform}`,
        `# Generated: ${new Date().toISOString().split('T')[0]}`,
        '',
        '# Default rules',
        'User-agent: *',
        'Allow: /',
        'Disallow: /api/',
        'Disallow: /admin/',
        'Disallow: /_next/static/',
        '',
      ];

      // AI Bot rules
      const allowed = AI_BOTS.filter((b) => botStates[b.id]);
      const blocked = AI_BOTS.filter((b) => !botStates[b.id]);

      if (allowed.length > 0) {
        lines.push('# AI Bots - Allowed');
        allowed.forEach((bot) => {
          lines.push(`User-agent: ${bot.id}`);
          lines.push('Allow: /');
          lines.push('');
        });
      }

      if (blocked.length > 0) {
        lines.push('# AI Bots - Blocked');
        blocked.forEach((bot) => {
          lines.push(`User-agent: ${bot.id}`);
          lines.push('Disallow: /');
          lines.push('');
        });
      }

      if (sitemapUrl) {
        lines.push(`Sitemap: ${sitemapUrl}`);
      } else {
        lines.push('# Sitemap: https://your-site.com/sitemap.xml');
      }

      setResult(lines.join('\n'));
      setGenerating(false);
    }, 1200);
  };

  const handleCopy = () => {
    if (result) {
      navigator.clipboard.writeText(result);
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }
  };

  const allowedCount = Object.values(botStates).filter(Boolean).length;
  const blockedCount = AI_BOTS.length - allowedCount;

  return (
    <div className="p-4 sm:p-8 max-w-7xl mx-auto">
      <PageHeader
        title="Robots.txt Optimizer"
        description="Optimisez votre robots.txt pour autoriser les bots IA tout en securisant votre site."
        breadcrumbs={[
          { label: 'App', href: '/app' },
          { label: 'Outils Generatifs', href: '/app/generative-tools' },
          { label: 'robots.txt' },
        ]}
      />

      <div className="grid lg:grid-cols-12 gap-8 animate-fade-in-up">
        {/* Configuration */}
        <div className="lg:col-span-5 space-y-6">
          {/* Platform */}
          <Card className="p-5">
            <h3 className="text-sm font-bold text-white mb-3">Plateforme</h3>
            <div className="flex flex-wrap gap-2">
              {PLATFORMS.map((p) => (
                <button
                  key={p.id}
                  onClick={() => setPlatform(p.id)}
                  className={`px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${
                    platform === p.id
                      ? 'bg-primary/20 text-primary border border-primary/30'
                      : 'bg-white/5 text-white/50 border border-white/10 hover:border-white/20'
                  }`}
                >
                  {p.label}
                </button>
              ))}
            </div>
            <div className="mt-4">
              <label className="block text-xs font-medium text-white/50 mb-1">URL du Sitemap</label>
              <input
                type="url"
                value={sitemapUrl}
                onChange={(e) => setSitemapUrl(e.target.value)}
                placeholder="https://your-site.com/sitemap.xml"
                className="w-full bg-white/5 border border-white/10 rounded-xl p-2.5 text-white placeholder:text-white/30 focus:border-primary/50 outline-none transition-all text-sm"
              />
            </div>
          </Card>

          {/* AI Bots */}
          <Card className="p-5">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-sm font-bold text-white">Bots IA</h3>
              <div className="flex items-center gap-2">
                <Badge variant={allowedCount === AI_BOTS.length ? 'success' : 'default'} className="text-[10px]">
                  {allowedCount} autorises
                </Badge>
                {blockedCount > 0 && (
                  <Badge variant="destructive" className="text-[10px]">
                    {blockedCount} bloques
                  </Badge>
                )}
              </div>
            </div>

            <div className="flex gap-2 mb-4">
              <button onClick={allowAll} className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-emerald-500/10 text-emerald-400 text-xs font-medium hover:bg-emerald-500/20 transition-colors">
                <Shield size={12} /> Tout autoriser
              </button>
              <button onClick={blockAll} className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-red-500/10 text-red-400 text-xs font-medium hover:bg-red-500/20 transition-colors">
                <ShieldOff size={12} /> Tout bloquer
              </button>
            </div>

            <div className="space-y-2">
              {AI_BOTS.map((bot) => {
                const isAllowed = botStates[bot.id];
                return (
                  <button
                    key={bot.id}
                    onClick={() => toggleBot(bot.id)}
                    className={`w-full flex items-center gap-3 p-3 rounded-xl border text-left transition-all ${
                      isAllowed
                        ? 'bg-emerald-500/5 border-emerald-500/10 hover:border-emerald-500/20'
                        : 'bg-red-500/5 border-red-500/10 hover:border-red-500/20'
                    }`}
                  >
                    {isAllowed ? (
                      <ToggleRight size={20} className="text-emerald-400 shrink-0" />
                    ) : (
                      <ToggleLeft size={20} className="text-red-400 shrink-0" />
                    )}
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2">
                        <span className="text-xs font-bold text-white">{bot.name}</span>
                        <span className="text-[10px] text-white/30">{bot.engine}</span>
                      </div>
                      <p className="text-[10px] text-white/30">{bot.description}</p>
                    </div>
                    <Badge variant={isAllowed ? 'success' : 'destructive'} className="text-[10px] shrink-0">
                      {isAllowed ? 'Allow' : 'Block'}
                    </Badge>
                  </button>
                );
              })}
            </div>
          </Card>

          <Button
            onClick={handleGenerate}
            disabled={generating}
            className="w-full gap-2"
          >
            {generating ? (
              <>
                <Loader2 className="animate-spin" size={16} />
                Generation...
              </>
            ) : (
              <>
                <Bot size={16} />
                Generer le robots.txt
              </>
            )}
          </Button>
        </div>

        {/* Output */}
        <div className="lg:col-span-7">
          {result ? (
            <div className="space-y-4 animate-fade-in-up">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <Bot size={16} className="text-cyan-400" />
                  <span className="text-sm font-bold text-white">robots.txt genere</span>
                </div>
                <div className="flex gap-2">
                  <Button variant="outline" size="sm" onClick={handleCopy} className="gap-1.5">
                    {copied ? <Check size={14} /> : <Copy size={14} />}
                    {copied ? 'Copie !' : 'Copier'}
                  </Button>
                  <Button variant="outline" size="sm" className="gap-1.5">
                    <Download size={14} /> Telecharger
                  </Button>
                </div>
              </div>
              <CodeBlock code={result} language="text" title="robots.txt" />
              <Card className="p-4">
                <p className="text-xs text-white/40">
                  <Sparkles size={12} className="inline text-primary mr-1" />
                  Placez ce fichier a la racine de votre site web : <code className="text-primary/70">https://votre-site.com/robots.txt</code>
                </p>
              </Card>
            </div>
          ) : (
            <div className="flex flex-col items-center justify-center h-full min-h-[400px] text-center">
              <div className="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mb-4">
                <Bot size={24} className="text-white/20" />
              </div>
              <p className="text-white/30 text-sm">
                Configurez les bots IA et generez votre robots.txt optimise
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
