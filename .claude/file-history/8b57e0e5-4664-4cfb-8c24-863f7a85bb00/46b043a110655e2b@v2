// services/v3/citation-api-client.ts

import type { AIEngineId } from '../../types/v3-types';

interface APICallResult {
  responseText: string;
  sources: string[];
  model: string;
  responseTimeMs: number;
  estimatedCostUsd: number;
}

// ─── OpenAI (ChatGPT) ───────────────────────────────

export async function callChatGPT(prompt: string): Promise<APICallResult> {
  const apiKey = (typeof process !== 'undefined' && process.env?.OPENAI_API_KEY) || null;
  if (!apiKey) {
    return simulateChatGPTResponse(prompt);
  }

  const startTime = Date.now();
  const response = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`,
    },
    body: JSON.stringify({
      model: 'gpt-4o-mini',
      messages: [{ role: 'user', content: prompt }],
      max_tokens: 1500,
      temperature: 0.7,
    }),
  });

  const data = await response.json();
  const responseTimeMs = Date.now() - startTime;
  const text = data.choices?.[0]?.message?.content || '';
  const inputTokens = data.usage?.prompt_tokens || 0;
  const outputTokens = data.usage?.completion_tokens || 0;

  return {
    responseText: text,
    sources: [],
    model: 'gpt-4o-mini',
    responseTimeMs,
    estimatedCostUsd: (inputTokens * 0.00000015) + (outputTokens * 0.0000006),
  };
}

// ─── Perplexity ──────────────────────────────────────

export async function callPerplexity(prompt: string): Promise<APICallResult> {
  const apiKey = (typeof process !== 'undefined' && process.env?.PERPLEXITY_API_KEY) || null;
  if (!apiKey) {
    return simulatePerplexityResponse(prompt);
  }

  const startTime = Date.now();
  const response = await fetch('https://api.perplexity.ai/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`,
    },
    body: JSON.stringify({
      model: 'sonar',
      messages: [{ role: 'user', content: prompt }],
      max_tokens: 1500,
    }),
  });

  const data = await response.json();
  const responseTimeMs = Date.now() - startTime;
  const text = data.choices?.[0]?.message?.content || '';
  const sources: string[] = data.citations || [];

  return {
    responseText: text,
    sources,
    model: 'sonar',
    responseTimeMs,
    estimatedCostUsd: 0.005,
  };
}

// ─── Gemini ──────────────────────────────────────────

export async function callGemini(prompt: string): Promise<APICallResult> {
  const apiKey = (typeof process !== 'undefined' && process.env?.GEMINI_API_KEY) || null;
  if (!apiKey) {
    return simulateGeminiResponse(prompt);
  }

  const startTime = Date.now();

  // Instance Gemini SÉPARÉE de celle de services/generator.ts
  const { GoogleGenAI } = await import('@google/genai');
  const ai = new GoogleGenAI({ apiKey });

  const response = await ai.models.generateContent({
    model: 'gemini-2.0-flash',
    contents: prompt,
  });

  const responseTimeMs = Date.now() - startTime;
  const text = response.text || '';

  return {
    responseText: text,
    sources: [],
    model: 'gemini-2.0-flash',
    responseTimeMs,
    estimatedCostUsd: 0.0001,
  };
}

// ─── Dispatcher ──────────────────────────────────────

export async function callAIEngine(
  engine: AIEngineId,
  prompt: string
): Promise<APICallResult> {
  switch (engine) {
    case 'chatgpt': return callChatGPT(prompt);
    case 'perplexity': return callPerplexity(prompt);
    case 'gemini': return callGemini(prompt);
  }
}

// ─── Simulations fallback (si pas d'API key) ─────────

function simulateChatGPTResponse(prompt: string): Promise<APICallResult> {
  return new Promise(resolve => {
    setTimeout(() => {
      resolve({
        responseText: `[Simulation ChatGPT] Réponse simulée pour : "${prompt.slice(0, 50)}...".\n\nVoici quelques recommandations pertinentes pour votre recherche. Plusieurs options sont disponibles sur le marché, incluant des enseignes reconnues qui proposent une large gamme de produits avec un bon rapport qualité-prix.`,
        sources: [],
        model: 'gpt-4o-mini-simulated',
        responseTimeMs: 500,
        estimatedCostUsd: 0,
      });
    }, 300 + Math.random() * 400);
  });
}

