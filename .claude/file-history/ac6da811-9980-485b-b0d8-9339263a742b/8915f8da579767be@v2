export interface GeneratedTrustBlock {
  html: string;
  schemaOrg: string;
}

export interface GeneratedCredentials {
  html: string;
  schemaOrg: string;
}

export interface GeneratedCitationBlock {
  html: string;
  schemaOrg: string;
}

