interface MessagesProps {
  onBack: () => void;
  user: { name: string; plan: string; credits: number } | null;
}

interface Message {
  id: string;
  content: string;
  timestamp: string;
  sender: 'me' | 'them';
  read: boolean;
}

interface Conversation {
  id: string;
  name: string;
  avatar: string;
  role: string;
  lastMessage: string;
  timestamp: string;
  unread: number;
  online: boolean;
  messages: Message[];
  category: 'all' | 'support';
}

