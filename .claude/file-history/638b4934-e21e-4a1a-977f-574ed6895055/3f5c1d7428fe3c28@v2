export interface SchemaInput {
  name: string;
  url: string;
  logoUrl: string;
  description: string;
  socialProfiles: string[];
  contactPhone: string;
  contactEmail: string;
  alternateName: string;
}

export const generateJsonLd = (data: SchemaInput): string => {
  const schema = {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": `${data.url}/#organization`,
        "name": data.name,
        "url": data.url,
        "logo": {
          "@type": "ImageObject",
          "url": data.logoUrl
        },
        "description": data.description,
        "alternateName": data.alternateName || undefined,
        "sameAs": data.socialProfiles.filter(url => url.length > 0),
        "contactPoint": (data.contactPhone || data.contactEmail) ? {
          "@type": "ContactPoint",
          "telephone": data.contactPhone || undefined,
          "email": data.contactEmail || undefined,
          "contactType": "customer service"
        } : undefined
      },
      {
        "@type": "WebSite",
        "@id": `${data.url}/#website`,
        "url": data.url,
        "name": data.name,
        "publisher": {
          "@id": `${data.url}/#organization`
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${data.url}/search?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  };

  return JSON.stringify(schema, null, 2);
};

// AI-enhanced schema generation using Google Gemini
export const generateSchemaWithAI = async (data: SchemaInput): Promise<{ content: string }> => {
  let apiKey: string | null = null;
  if (typeof process !== 'undefined' && process.env && process.env.API_KEY) {
    apiKey = process.env.API_KEY;
  }

  if (!apiKey) {
    // Fallback: use local generation with enriched output
    await new Promise(resolve => setTimeout(resolve, 1200));
    return { content: generateJsonLd(data) };
  }

  try {
    const { GoogleGenAI, Type } = await import("@google/genai");
    const ai = new GoogleGenAI({ apiKey });

    const prompt = `
      You are an expert in Schema.org structured data. Generate an optimized JSON-LD schema for the following organization.

      ORGANIZATION INFO:
      - Name: ${data.name}
      - URL: ${data.url}
      - Logo: ${data.logoUrl}
      - Description: ${data.description}
      ${data.alternateName ? `- Alternate Name: ${data.alternateName}` : ''}
      ${data.contactPhone ? `- Phone: ${data.contactPhone}` : ''}
      ${data.contactEmail ? `- Email: ${data.contactEmail}` : ''}
      ${data.socialProfiles.filter(s => s).length > 0 ? `- Social Profiles: ${data.socialProfiles.filter(s => s).join(', ')}` : ''}

      Generate a comprehensive Schema.org JSON-LD with @graph containing Organization and WebSite types.
      Include all relevant properties. Use proper schema.org vocabulary.
      Return ONLY the valid JSON-LD object, no markdown fences.
    `;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: {
        responseMimeType: 'application/json',
        temperature: 0.2,
      }
    });

    let output = response.text;
    if (!output) throw new Error("Empty response from AI");

    output = output.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();

    // Validate it's valid JSON
    const parsed = JSON.parse(output);
    return { content: JSON.stringify(parsed, null, 2) };
  } catch (error) {
    console.error("Schema AI generation failed:", error);
    return { content: generateJsonLd(data) };
  }
};