import React from 'react';
import { X } from 'lucide-react';

const ShortcutsModal: React.FC<{ isOpen: boolean; onClose: () => void }> = ({ isOpen, onClose }) => {
  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-[100] flex items-center justify-center p-4" onClick={onClose}>
      <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" />
      <div className="relative w-full max-w-[400px] max-h-[90vh] overflow-y-auto bg-[#13131d] border border-white/[0.1] rounded-2xl shadow-2xl" onClick={e => e.stopPropagation()}>
        <div className="flex items-center justify-between px-5 py-4 border-b border-white/[0.08]">
          <h3 className="text-sm font-semibold text-white">Raccourcis clavier</h3>
          <button onClick={onClose} className="text-gray-500 hover:text-white transition-colors"><X size={14} /></button>
        </div>
        <div className="px-5 py-3 space-y-2.5">
          {[
            { keys: 'Ctrl + K', desc: 'Recherche rapide / Navigation' },
            { keys: '?', desc: 'Afficher les raccourcis' },
            { keys: 'Esc', desc: 'Fermer les modales' },
            { keys: '↑ ↓', desc: 'Naviguer dans les résultats' },
            { keys: '↵', desc: 'Ouvrir la sélection' },
          ].map(s => (
            <div key={s.keys} className="flex items-center justify-between py-1.5">
              <span className="text-sm text-gray-400">{s.desc}</span>
              <kbd className="px-2 py-1 text-[11px] text-gray-500 bg-white/[0.04] border border-white/[0.08] rounded-md font-mono">{s.keys}</kbd>
            </div>
          ))}
        </div>
        <div className="px-5 py-3 border-t border-white/[0.06] text-[11px] text-gray-600 text-center">
          Appuyez sur <kbd className="px-1.5 py-0.5 bg-white/[0.04] border border-white/[0.08] rounded text-[10px] font-mono">?</kbd> pour afficher ce panneau
        </div>
      </div>
    </div>
  );
};

export default ShortcutsModal;
