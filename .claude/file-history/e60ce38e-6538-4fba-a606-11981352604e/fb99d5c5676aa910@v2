import { authenticateRequest, corsHeaders, createAdminClient, enforceRateLimit, jsonResponse, logAutomationEvent, parseJsonBody, sha256Hex } from '../_shared/common.ts';

type Heat = 'burning' | 'hot' | 'warm' | 'cold';

interface AnalyzePayload {
  sector: string;
  source: string;
  source_id?: string | null;
  raw_data: Record<string, unknown>;
  dedup_hash?: string;
  approach_tone?: 'professional' | 'friendly' | 'direct';
  message_only?: boolean;
}

interface GeminiAnalysis {
  score: number;
  heat: Heat;
  signal: string;
  market_analysis: Record<string, unknown>;
  approach_message: string;
  approach_why: string;
  score_breakdown: Record<string, unknown>;
}

const normalizeHeat = (score: number): Heat => {
  if (score >= 90) {
    return 'burning';
  }
  if (score >= 75) {
    return 'hot';
  }
  if (score >= 50) {
    return 'warm';
  }
  return 'cold';
};

const parseGeminiText = (raw: string): GeminiAnalysis => {
  const cleaned = raw.trim().replace(/^```json\s*/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();
  return JSON.parse(cleaned) as GeminiAnalysis;
};

const buildPrompt = (
  sector: string,
  rawData: Record<string, unknown>,
  marketContext: Record<string, unknown>,
  approachTone: string,
