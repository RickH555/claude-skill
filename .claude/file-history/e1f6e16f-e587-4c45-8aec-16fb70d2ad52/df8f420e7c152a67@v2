  <style>
    /* ── RESET & BASE ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: #09090B;
      color: #A1A1AA;
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    img, svg { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; cursor: pointer; border: none; background: none; }
    ul { list-style: none; }

    ::selection { background: rgba(59,130,246,0.3); color: #fff; }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(161,161,170,0.2); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(161,161,170,0.35); }

    /* ── TOKENS ── */
    :root {
      --bg: #09090B;
      --surface: #18181B;
      --surface-alt: #0F0F12;
      --border: #27272A;
      --border-subtle: #1E1E22;
      --text-primary: #FAFAFA;
      --text-secondary: #A1A1AA;
      --text-muted: #71717A;
      --text-faint: #52525B;
      --blue: #3B82F6;
      --blue-dim: rgba(59,130,246,0.1);
      --blue-border: rgba(59,130,246,0.2);
      --green: #22C55E;
      --green-dim: rgba(34,197,94,0.1);
      --green-border: rgba(34,197,94,0.2);
      --red: #EF4444;
      --red-dim: rgba(239,68,68,0.08);
      --red-border: rgba(239,68,68,0.15);
      --purple: #A855F7;
      --purple-dim: rgba(168,85,247,0.1);
      --purple-border: rgba(168,85,247,0.2);
      --emerald-grad: linear-gradient(135deg, #34D399, #6EE7B7);
      --font-display: 'Fraunces', Georgia, serif;
      --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --max-w: 1120px;
      --nav-h: 64px;
    }

    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }
    .section { padding: 96px 24px; }

    /* ── FONTS ── */
    .font-display { font-family: var(--font-display); }
    .font-mono { font-family: var(--font-mono); }

    /* ── ANIMATIONS ── */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes slideInLeft {
      from { opacity: 0; transform: translateX(-40px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(40px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes scaleIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes barFill {
      from { width: 0%; }
    }

    .animate-on-scroll { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    .animate-on-scroll.visible { opacity: 1; transform: translateY(0); }
    .animate-on-scroll.slide-left { transform: translateX(-40px); }
    .animate-on-scroll.slide-left.visible { transform: translateX(0); }
    .animate-on-scroll.slide-right { transform: translateX(40px); }
    .animate-on-scroll.slide-right.visible { transform: translateX(0); }
    .animate-on-scroll.scale-up { transform: scale(0.95); }
    .animate-on-scroll.scale-up.visible { transform: scale(1); }

    /* Stagger delays */
    .delay-1 { transition-delay: 0.1s; }
    .delay-2 { transition-delay: 0.2s; }
    .delay-3 { transition-delay: 0.3s; }
    .delay-4 { transition-delay: 0.4s; }
    .delay-5 { transition-delay: 0.5s; }

    /* ── NAV ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      height: var(--nav-h);
      display: flex; align-items: center;
      transition: background 0.3s, border-color 0.3s, backdrop-filter 0.3s;
      border-bottom: 1px solid transparent;
    }
    .nav.scrolled {
      background: rgba(9,9,11,0.8);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border-bottom-color: var(--border-subtle);
    }
    .nav-inner {
      max-width: var(--max-w); margin: 0 auto; padding: 0 24px;
      width: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 16px; color: var(--text-primary); }
    .nav-logo-icon { width: 28px; height: 28px; background: var(--blue); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: #fff; }
    .nav-links { display: flex; align-items: center; gap: 32px; }
    .nav-link { font-size: 14px; font-weight: 500; color: var(--text-muted); transition: color 0.2s; }
    .nav-link:hover { color: var(--text-primary); }
    .nav-cta {
      background: #fff; color: #000; font-size: 14px; font-weight: 600;
      padding: 8px 18px; border-radius: 8px; transition: all 0.2s;
    }
    .nav-cta:hover { background: #E4E4E7; transform: scale(1.02); }

    .nav-mobile-toggle { display: none; color: var(--text-secondary); font-size: 14px; font-weight: 600; }
    .nav-mobile-menu {
      display: none; position: fixed; top: var(--nav-h); left: 0; right: 0;
      background: rgba(9,9,11,0.95); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-subtle);
      padding: 24px; flex-direction: column; gap: 16px;
    }
    .nav-mobile-menu.open { display: flex; }
    .nav-mobile-menu a { font-size: 16px; color: var(--text-secondary); padding: 8px 0; font-weight: 500; }
    .nav-mobile-menu .nav-cta { display: block; text-align: center; margin-top: 8px; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-mobile-toggle { display: block; }
    }

    /* ── HERO ── */
    .hero {
      min-height: 90vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      padding: 128px 24px 80px; position: relative; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.15), transparent),
        radial-gradient(circle at 50% 50%, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 100% 100%, 24px 24px;
    }
    .hero-content { position: relative; z-index: 2; max-width: 880px; }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 14px; border-radius: 100px;
      background: var(--blue-dim); border: 1px solid var(--blue-border);
      font-size: 13px; font-weight: 500; color: #60A5FA;
      animation: fadeIn 0.6s ease-out both;
    }
    .hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px rgba(34,197,94,0.5); }

    .hero h1 {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(36px, 6vw, 72px); line-height: 1.08;
      letter-spacing: -0.025em; color: var(--text-primary);
      margin-top: 28px;
      animation: fadeInUp 0.7s ease-out 0.1s both;
    }
    .hero h1 .gradient-text {
      background: linear-gradient(135deg, #34D399, #6EE7B7);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero h1 .line-break {
      display: block; font-size: clamp(30px, 5vw, 56px); margin-top: 4px;
    }

    .hero-sub {
      font-size: clamp(16px, 2vw, 20px); color: var(--text-secondary);
      max-width: 640px; margin: 24px auto 0; line-height: 1.7;
      animation: fadeInUp 0.6s ease-out 0.25s both;
    }

    .hero-ctas {
      display: flex; align-items: center; justify-content: center; gap: 16px;
      margin-top: 40px; flex-wrap: wrap;
      animation: fadeInUp 0.5s ease-out 0.4s both;
    }
    .btn-primary {
      background: #fff; color: #000; font-weight: 600; font-size: 16px;
      padding: 14px 32px; border-radius: 10px;
      box-shadow: 0 0 24px rgba(255,255,255,0.08);
      transition: all 0.2s;
    }
    .btn-primary:hover { background: #E4E4E7; transform: scale(1.02); box-shadow: 0 0 32px rgba(255,255,255,0.12); }
    .btn-secondary {
      color: var(--text-secondary); font-weight: 500; font-size: 16px;
      padding: 14px 24px; transition: color 0.2s;
    }
    .btn-secondary:hover { color: var(--text-primary); }
    .btn-secondary .arrow { display: inline-block; transition: transform 0.2s; }
    .btn-secondary:hover .arrow { transform: translateX(3px); }

    .hero-proof {
      display: flex; align-items: center; justify-content: center; gap: 24px;
      margin-top: 40px; flex-wrap: wrap;
      animation: fadeInUp 0.5s ease-out 0.55s both;
    }
    .hero-proof span { font-size: 14px; color: var(--text-muted); font-weight: 500; }
    .hero-proof .check { color: var(--green); margin-right: 4px; }

    /* ── PRODUCT MOCKUP ── */
    .mockup-wrapper {
      max-width: 960px; margin: -40px auto 0; padding: 0 24px;
      position: relative; z-index: 3;
    }
    .mockup {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
      box-shadow: 0 20px 60px -10px rgba(0,0,0,0.5);
    }
    .mockup-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 14px 18px; border-bottom: 1px solid var(--border-subtle);
    }
    .mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
    .mockup-dot.r { background: rgba(239,68,68,0.5); }
    .mockup-dot.y { background: rgba(234,179,8,0.5); }
    .mockup-dot.g { background: rgba(34,197,94,0.5); }
    .mockup-url { font-size: 12px; color: var(--text-faint); margin-left: 12px; font-family: var(--font-mono); }

    .mockup-body { padding: 24px; }
    .mockup-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .mockup-stat {
      background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle);
      border-radius: 12px; padding: 16px;
    }
    .mockup-stat-label { font-size: 12px; color: var(--text-faint); }
    .mockup-stat-value { font-family: var(--font-mono); font-size: 28px; font-weight: 700; color: var(--text-primary); margin-top: 4px; }
    .mockup-stat-delta { font-size: 12px; color: #34D399; margin-top: 4px; }

    .mockup-scores { margin-top: 16px; }
    .mockup-engine {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 0; border-bottom: 1px solid var(--border-subtle);
    }
    .mockup-engine:last-child { border-bottom: none; }
    .mockup-engine-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .mockup-engine-name { font-size: 13px; font-weight: 600; color: var(--text-primary); width: 90px; flex-shrink: 0; }
    .mockup-engine-score { font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--text-primary); width: 50px; flex-shrink: 0; text-align: right; }
    .mockup-bar-track { flex: 1; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.06); overflow: hidden; }
    .mockup-bar-fill { height: 100%; border-radius: 3px; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1); width: 0; }

    .mockup-alert {
      display: flex; align-items: center; gap: 12px;
      margin-top: 16px; padding: 14px;
      background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle);
      border-radius: 12px;
    }
    .mockup-alert-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--blue-dim); display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .mockup-alert-text { font-size: 13px; font-weight: 500; color: var(--text-primary); }
    .mockup-alert-sub { font-size: 12px; color: var(--text-faint); margin-top: 2px; }

    @media (max-width: 640px) {
      .mockup-grid { grid-template-columns: 1fr; }
      .mockup-engine { flex-wrap: wrap; gap: 8px; }
      .mockup-bar-track { width: 100%; }
    }

    /* ── PROBLEM / SOLUTION ── */
    .problem-section { padding: 96px 24px; }
    .problem-title {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(28px, 4vw, 44px); color: var(--text-primary);
      text-align: center; letter-spacing: -0.02em; margin-bottom: 48px;
    }
    .problem-grid {
      display: grid; grid-template-columns: 1fr auto 1fr;
      gap: 24px; max-width: 960px; margin: 0 auto; align-items: stretch;
    }
    .problem-col {
      border-radius: 16px; padding: 32px;
    }
    .problem-col.before { background: var(--red-dim); border: 1px solid var(--red-border); }
    .problem-col.after { background: var(--green-dim); border: 1px solid var(--green-border); }
    .problem-col-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px; }
    .problem-col.before .problem-col-label { color: #F87171; }
    .problem-col.after .problem-col-label { color: #4ADE80; }
    .problem-row { display: flex; gap: 12px; align-items: flex-start; padding: 10px 0; }
    .problem-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }
    .problem-col.before .problem-icon { color: #F87171; }
    .problem-col.after .problem-icon { color: #4ADE80; }
    .problem-text { font-size: 15px; color: var(--text-secondary); line-height: 1.5; }

    .problem-arrow {
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; color: var(--text-faint);
    }

    @media (max-width: 768px) {
      .problem-grid { grid-template-columns: 1fr; }
      .problem-arrow { transform: rotate(90deg); padding: 8px 0; }
    }

    /* ── FEATURES ── */
    .features-section { padding: 96px 24px; background: var(--surface-alt); }
    .section-label {
      font-size: 13px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.1em; color: #60A5FA; text-align: center;
    }
    .section-title {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(28px, 4vw, 48px); color: var(--text-primary);
      text-align: center; letter-spacing: -0.02em; margin-top: 12px; line-height: 1.15;
    }
    .section-sub {
      font-size: 17px; color: var(--text-secondary); text-align: center;
      max-width: 600px; margin: 16px auto 0; line-height: 1.7;
    }

    .features-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; max-width: var(--max-w); margin: 56px auto 0;
    }
    .feature-card {
      background: rgba(24,24,27,0.5); border: 1px solid var(--border);
      border-radius: 16px; padding: 32px;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    }
    .feature-card:hover { border-color: var(--text-faint); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .feature-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: 20px;
    }
    .feature-icon.blue { background: var(--blue-dim); }
    .feature-icon.green { background: var(--green-dim); }
    .feature-icon.purple { background: var(--purple-dim); }
    .feature-card h3 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; }
    .feature-card p { font-size: 15px; color: var(--text-muted); line-height: 1.65; }

    @media (max-width: 768px) {
      .features-grid { grid-template-columns: 1fr; }
    }

    /* ── METRICS ── */
    .metrics-section { padding: 96px 24px; }
    .metrics-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 24px; max-width: var(--max-w); margin: 0 auto;
    }
    .metric-card { text-align: center; padding: 24px; }
    .metric-value {
      font-family: var(--font-mono); font-size: clamp(32px, 4vw, 48px);
      font-weight: 700; color: var(--text-primary);
    }
    .metric-label {
      font-size: 13px; color: var(--text-faint); text-transform: uppercase;
      letter-spacing: 0.08em; margin-top: 8px; font-weight: 500;
    }

    @media (max-width: 768px) {
      .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ── HOW IT WORKS ── */
    .steps-section { padding: 96px 24px; }
    .steps-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 40px; max-width: 960px; margin: 56px auto 0;
      position: relative;
    }
    .steps-line {
      display: none; position: absolute; top: 20px; left: 16%; right: 16%;
      border-top: 2px dashed var(--border); z-index: 0;
    }
    @media (min-width: 769px) { .steps-line { display: block; } }

    .step { text-align: center; position: relative; z-index: 1; }
    .step-num {
      width: 40px; height: 40px; border-radius: 50%;
      border: 2px solid var(--blue-border); background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-weight: 700; font-size: 16px;
      color: #60A5FA; margin: 0 auto;
    }
    .step h3 { font-size: 18px; font-weight: 600; color: var(--text-primary); margin-top: 16px; }
    .step p { font-size: 15px; color: var(--text-muted); margin-top: 8px; line-height: 1.6; }

    @media (max-width: 768px) {
      .steps-grid { grid-template-columns: 1fr; gap: 32px; }
    }

    /* ── ENGINE SCORING ── */
    .scoring-section { padding: 96px 24px; background: var(--surface-alt); }
    .scoring-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 16px; padding: 32px; max-width: 720px; margin: 48px auto 0;
    }
    .scoring-engine {
      display: flex; align-items: center; gap: 16px;
      padding: 20px 0; border-bottom: 1px solid var(--border-subtle);
    }
    .scoring-engine:last-child { border-bottom: none; }
    .scoring-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .scoring-name { font-size: 15px; font-weight: 600; color: var(--text-primary); width: 100px; flex-shrink: 0; }
    .scoring-val { font-family: var(--font-mono); font-weight: 600; color: var(--text-primary); width: 65px; text-align: right; flex-shrink: 0; }
    .scoring-track { flex: 1; height: 8px; border-radius: 4px; background: rgba(255,255,255,0.06); overflow: hidden; }
    .scoring-fill { height: 100%; border-radius: 4px; width: 0; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1); }
    .scoring-hint { font-size: 13px; color: var(--text-faint); margin-top: 4px; padding-left: 126px; }

    @media (max-width: 640px) {
      .scoring-engine { flex-wrap: wrap; gap: 8px; }
      .scoring-track { width: 100%; order: 4; }
      .scoring-hint { padding-left: 0; }
    }

    /* ── PRICING ── */
    .pricing-section { padding: 96px 24px; }
    .pricing-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; max-width: var(--max-w); margin: 56px auto 0; align-items: start;
    }
    .pricing-card {
      border-radius: 16px; padding: 32px; position: relative;
      background: rgba(24,24,27,0.3); border: 1px solid var(--border);
    }
    .pricing-card.highlighted {
      background: var(--surface); border-color: var(--blue-border);
      box-shadow: 0 0 0 1px rgba(59,130,246,0.08), 0 8px 40px rgba(0,0,0,0.3);
    }
