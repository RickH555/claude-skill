import type {
  ApiKey,
  ApiEndpoint,
  ApiUsageDay,
  ApiUsageKPI,
  RateLimit,
  Webhook,
  WebhookEvent,
} from '../types/api-developer.ts'

const API_KEYS_KEY = 'citedby_api_keys'
const WEBHOOKS_KEY = 'citedby_webhooks'

function generateId(prefix: string): string {
  return `${prefix}_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`
}

function generateApiKey(): string {
  const parts = Array.from({ length: 4 }, () => Math.random().toString(36).slice(2, 10))
  return `cb_live_${parts.join('')}`
}

// ---- API Keys CRUD ----

export function getApiKeys(): ApiKey[] {
  const raw = localStorage.getItem(API_KEYS_KEY)
  return raw ? JSON.parse(raw) : []
}

function saveApiKeys(keys: ApiKey[]): void {
  localStorage.setItem(API_KEYS_KEY, JSON.stringify(keys))
}

export function createApiKey(name: string): ApiKey {
  const key: ApiKey = {
    id: generateId('key'),
    name,
    key: generateApiKey(),
    createdAt: new Date().toISOString(),
    status: 'active',
    lastUsed: null,
  }
  const keys = getApiKeys()
  keys.push(key)
  saveApiKeys(keys)
  return key
}

export function revokeApiKey(id: string): void {
  const keys = getApiKeys()
  const key = keys.find((k) => k.id === id)
  if (key) {
    key.status = 'revoked'
    saveApiKeys(keys)
  }
}

export function regenerateApiKey(id: string): ApiKey | null {
  const keys = getApiKeys()
  const key = keys.find((k) => k.id === id)
  if (!key) return null
  key.key = generateApiKey()
  key.status = 'active'
  key.createdAt = new Date().toISOString()
  key.lastUsed = null
  saveApiKeys(keys)
  return key
}

export function truncateKey(key: string): string {
  return key.slice(0, 12) + '••••••••' + key.slice(-4)
}

// ---- Webhooks CRUD ----

export function getWebhooks(): Webhook[] {
  const raw = localStorage.getItem(WEBHOOKS_KEY)
  return raw ? JSON.parse(raw) : []
}

function saveWebhooks(webhooks: Webhook[]): void {
  localStorage.setItem(WEBHOOKS_KEY, JSON.stringify(webhooks))
}

export function createWebhook(url: string, events: WebhookEvent[]): Webhook {
  const webhook: Webhook = {
    id: generateId('wh'),
    url,
    events,
    active: true,
    lastDelivery: null,
    createdAt: new Date().toISOString(),
  }
  const webhooks = getWebhooks()
  webhooks.push(webhook)
  saveWebhooks(webhooks)
  return webhook
}

export function toggleWebhook(id: string): void {
  const webhooks = getWebhooks()
  const wh = webhooks.find((w) => w.id === id)
  if (wh) {
    wh.active = !wh.active
    saveWebhooks(webhooks)
  }
}

export function deleteWebhook(id: string): void {
  const webhooks = getWebhooks().filter((w) => w.id !== id)
  saveWebhooks(webhooks)
}

