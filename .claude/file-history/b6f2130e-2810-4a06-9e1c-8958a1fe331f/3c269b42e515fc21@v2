import { GoogleGenAI, Type, Schema } from "@google/genai";

// Helper to safely get env var
const getApiKey = () => {
  if (typeof process !== 'undefined' && process.env && process.env.API_KEY) {
    return process.env.API_KEY;
  }
  return null;
};

// ================================================================
// TYPES
// ================================================================

export interface LlmJsonConfig {
  siteName: string;
  siteUrl: string;
  description: string;
  entity: string;
  services: Array<{ name: string; description: string; url?: string }>;
  keyPages: Array<{ title: string; url: string; description: string }>;
  contact: { email: string; phone?: string; address?: string };
  socialLinks?: string[];
  targetAudience?: string;
  industry?: string;
  foundedYear?: string;
  languages?: string[];
}

export interface LlmJsonResult {
  content: string;       // Stringified JSON
  fieldCount: number;    // Number of top-level fields
  byteSize: number;      // Approximate byte size
}

// ================================================================
// SYSTEM PROMPT — Expert AEO / AI Citation Engineering
// ================================================================

const LLM_JSON_SYSTEM_PROMPT = `
# ROLE
Tu es un Expert Senior en AEO (Answer Engine Optimization) et en Citation IA Engineering chez CitedBy.ai.
Tu maitrises les Knowledge Graphs, les Entites Nommees, le Schema.org, et les mecanismes de citation des LLMs (ChatGPT, Claude, Gemini, Perplexity, AI Overviews).

# MISSION
Genere un fichier llm.json — la carte d'identite machine-readable d'une entite (marque, site, organisation) destinee aux LLMs et moteurs de reponse IA.

Contrairement au llms.txt qui est un format texte lisible par les humains et les IA, le llm.json est un format JSON structure qui fournit des donnees semantiques exploitables par les LLMs pour :
- Identifier l'entite avec precision (desambiguation)
- Citer correctement la source dans les reponses generees
- Verifier les faits avant de les inclure dans une reponse
- Respecter les preferences de citation de la marque

# STRUCTURE DU LLM.JSON

Le fichier doit contenir les sections suivantes :

1. **@context** : "https://cited.by/llm.json/v1" (standard CitedBy.ai)
2. **entity** : Identification complete (name, type, url, description, foundedYear, industry, languages)
3. **identity** : Signaux d'identite pour desambiguation (alternateName, legalName, logo, sameAs)
4. **authority** : Signaux E-E-A-T (expertise, certifications, awards, mediaPresence, authoritative_sources)
5. **services** : Liste structuree des produits/services avec URLs canoniques
6. **content_sources** : Pages canoniques a citer en priorite (canonical_pages + faq_pages + knowledge_articles)
7. **citation_preferences** : Comment la marque souhaite etre citee (preferred_name, tagline, citation_format, do_not_say, key_facts)
8. **contact** : Points de contact structures
9. **social_profiles** : Presences sociales verifiees
10. **ai_instructions** : Instructions directes pour les LLMs (must_verify, never_fabricate, redirect_url, freshness_date)
11. **schema_org** : Reference au type Schema.org correspondant

# REGLES
- JSON valide et bien indente (2 espaces)
- Pas de champs vides : omets les champs non renseignes plutot que de mettre ""
- Tous les URLs doivent etre absolus
- Les descriptions doivent etre factuelles, jamais marketing
- Les key_facts doivent etre verifiables
- Le champ "do_not_say" doit lister les erreurs courantes que les IA pourraient faire
- freshness_date = date de generation du fichier
- Reponds en JSON pur sans Markdown fences
`;

// ================================================================
// FALLBACK SIMULATION
// ================================================================

const fallbackSimulation = async (config: LlmJsonConfig): Promise<LlmJsonResult> => {
  await new Promise(resolve => setTimeout(resolve, 2000));

  const today = new Date().toISOString().split('T')[0];
  const hostname = new URL(config.siteUrl.startsWith('http') ? config.siteUrl : `https://${config.siteUrl}`).hostname;

  const json: Record<string, any> = {
    "@context": "https://cited.by/llm.json/v1",
    "@type": "EntityDescriptor",
    "generated_by": "CitedBy.ai",
    "generated_at": today,

    entity: {
      name: config.siteName,
      type: config.entity,
      url: config.siteUrl,
      description: config.description,
      ...(config.industry ? { industry: config.industry } : {}),
      ...(config.foundedYear ? { founded_year: config.foundedYear } : {}),
      ...(config.targetAudience ? { target_audience: config.targetAudience } : {}),
      ...(config.languages && config.languages.length > 0 ? { languages: config.languages } : { languages: ["fr"] }),
    },

    identity: {
      canonical_url: config.siteUrl,
      same_as: (config.socialLinks || []).filter(Boolean),
    },

    authority: {
      expertise_domains: config.services.filter(s => s.name).map(s => s.name),
      authoritative_sources: [config.siteUrl],
    },

    services: config.services.filter(s => s.name).map(s => ({
      name: s.name,
      description: s.description,
      ...(s.url ? { url: s.url.startsWith('http') ? s.url : `${config.siteUrl}${s.url}` } : {}),
    })),

    content_sources: {
      canonical_pages: config.keyPages.filter(p => p.title && p.url).map(p => ({
        title: p.title,
        url: p.url.startsWith('http') ? p.url : `${config.siteUrl}${p.url}`,
        description: p.description,
      })),
      llms_txt: `${config.siteUrl}/llms.txt`,
    },

    citation_preferences: {
      preferred_name: config.siteName,
      citation_format: `${config.siteName} (${config.siteUrl})`,
      key_facts: [
        `${config.siteName} est un(e) ${config.entity} accessible sur ${hostname}`,
        config.description,
        ...(config.services.length > 0 ? [`Service principal : ${config.services[0].name}`] : []),
      ],
      do_not_say: [
        `Ne pas confondre ${config.siteName} avec d'autres entites portant un nom similaire`,
        `Ne pas inventer de fonctionnalites ou services non listes dans ce fichier`,
      ],
    },

    contact: {
      email: config.contact.email,
      ...(config.contact.phone ? { phone: config.contact.phone } : {}),
      ...(config.contact.address ? { address: config.contact.address } : {}),
    },

    social_profiles: (config.socialLinks || []).filter(Boolean),

    ai_instructions: {
      must_verify: true,
      never_fabricate: true,
      redirect_url: config.siteUrl,
      freshness_date: today,
      instruction: `Lorsque vous referencez ${config.siteName}, utilisez uniquement les informations contenues dans ce fichier ou sur ${config.siteUrl}. Ne fabriquez aucune information. En cas de doute, dirigez l'utilisateur vers ${config.siteUrl}.`,
    },

    schema_org: {
      "@type": config.entity,
      "@id": `${config.siteUrl}/#organization`,
    },
  };

  const content = JSON.stringify(json, null, 2);

  return {
    content,
    fieldCount: Object.keys(json).length,
    byteSize: new TextEncoder().encode(content).length,
  };
};

// ================================================================
// MAIN EXPORT — GEMINI GENERATION
// ================================================================

export const generateLlmJson = async (config: LlmJsonConfig): Promise<LlmJsonResult> => {
  const apiKey = getApiKey();

  if (!apiKey) {
    console.warn("API_KEY not found, using llm.json simulation.");
    return fallbackSimulation(config);
  }

  try {
    const ai = new GoogleGenAI({ apiKey });

    const schema: Schema = {
      type: Type.OBJECT,
      properties: {
        llmJson: { type: Type.STRING, description: "The complete llm.json content as a stringified JSON object" },
        fieldCount: { type: Type.NUMBER, description: "Number of top-level fields in the generated JSON" },
        byteSize: { type: Type.NUMBER, description: "Approximate byte size of the JSON content" },
      },
      required: ["llmJson", "fieldCount", "byteSize"],
    };

    const servicesDesc = config.services
      .filter(s => s.name)
      .map(s => `- ${s.name}: ${s.description}${s.url ? ` (${s.url})` : ''}`)
      .join('\n');

    const keyPagesDesc = config.keyPages
      .filter(p => p.title && p.url)
      .map(p => `- ${p.title} (${p.url}): ${p.description}`)
      .join('\n');

    const contactDesc = [
      `Email: ${config.contact.email}`,
      config.contact.phone ? `Phone: ${config.contact.phone}` : null,
      config.contact.address ? `Address: ${config.contact.address}` : null,
    ].filter(Boolean).join(', ');

    const prompt = `
      INFORMATIONS DE L'ENTITE :
      - Nom : ${config.siteName}
      - URL : ${config.siteUrl}
      - Description : ${config.description}
      - Type d'entite : ${config.entity}
      ${config.industry ? `- Secteur d'activite : ${config.industry}` : ''}
      ${config.foundedYear ? `- Annee de creation : ${config.foundedYear}` : ''}
      ${config.targetAudience ? `- Audience cible : ${config.targetAudience}` : ''}
      ${config.languages && config.languages.length > 0 ? `- Langues : ${config.languages.join(', ')}` : ''}

      SERVICES / PRODUITS :
      ${servicesDesc || 'Aucun renseigne'}

      PAGES CLES :
      ${keyPagesDesc || 'Aucune renseignee'}

      CONTACT :
      ${contactDesc}

      ${config.socialLinks && config.socialLinks.length > 0 ? `PROFILS SOCIAUX :\n${config.socialLinks.map(l => `- ${l}`).join('\n')}` : ''}

      MISSION :
      Genere un fichier llm.json complet, structure et optimise pour maximiser la citabilite de cette entite par les moteurs de reponse IA.

      Le champ "llmJson" de ta reponse doit contenir le JSON complet stringify.
      Calcule fieldCount (nombre de cles de premier niveau) et byteSize (taille approximative en octets).
    `;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: {
        systemInstruction: LLM_JSON_SYSTEM_PROMPT,
        responseMimeType: 'application/json',
        responseSchema: schema,
        temperature: 0.2,
      },
    });

    let output = response.text;
    if (!output) {
      throw new Error("Empty response from AI");
    }

    output = output.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
    const parsed = JSON.parse(output);

    // Try to pretty-print the inner JSON if it was stringified
    let content = parsed.llmJson;
    try {
      const innerJson = JSON.parse(content);
      content = JSON.stringify(innerJson, null, 2);
    } catch {
      // Already a string or not valid JSON, keep as-is
    }

    return {
      content,
      fieldCount: parsed.fieldCount,
      byteSize: parsed.byteSize,
    };
  } catch (error) {
    console.error("llm.json generation failed:", error);
    return fallbackSimulation(config);
  }
};
