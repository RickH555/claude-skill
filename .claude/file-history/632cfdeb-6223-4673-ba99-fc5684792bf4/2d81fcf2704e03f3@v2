import { describe, it, expect } from "vitest"
import { checkRateLimit, rateLimitHeaders } from "@/lib/rate-limit"

describe("checkRateLimit", () => {
  it("allows first request", () => {
    const result = checkRateLimit("test-user-1", 5, 60_000)
    expect(result.success).toBe(true)
    expect(result.remaining).toBe(4)
    expect(result.limit).toBe(5)
  })

  it("decrements remaining on each request", () => {
    const id = "test-user-decrement-" + Date.now()
    checkRateLimit(id, 5, 60_000) // 1st
    checkRateLimit(id, 5, 60_000) // 2nd
    const result = checkRateLimit(id, 5, 60_000) // 3rd
    expect(result.success).toBe(true)
    expect(result.remaining).toBe(2)
  })

  it("rejects when limit exceeded", () => {
    const id = "test-user-reject-" + Date.now()
    for (let i = 0; i < 3; i++) {
      checkRateLimit(id, 3, 60_000)
    }
    const result = checkRateLimit(id, 3, 60_000)
    expect(result.success).toBe(false)
    expect(result.remaining).toBe(0)
  })

  it("resets after window expires", () => {
    const id = "test-user-reset-" + Date.now()
    // Use a very short window
    for (let i = 0; i < 3; i++) {
      checkRateLimit(id, 3, 1) // 1ms window
    }
    // Wait a bit for window to expire
    const start = Date.now()
    while (Date.now() - start < 5) {
      // busy wait
    }
    const result = checkRateLimit(id, 3, 1)
    expect(result.success).toBe(true)
  })

  it("isolates different identifiers", () => {
    const id1 = "test-user-a-" + Date.now()
    const id2 = "test-user-b-" + Date.now()
    for (let i = 0; i < 5; i++) {
      checkRateLimit(id1, 5, 60_000)
    }
    const result1 = checkRateLimit(id1, 5, 60_000)
    const result2 = checkRateLimit(id2, 5, 60_000)
    expect(result1.success).toBe(false)
    expect(result2.success).toBe(true)
  })
})

describe("rateLimitHeaders", () => {
  it("returns correct header values", () => {
    const result = { success: true, limit: 60, remaining: 45, resetAt: 1700000000000 }
    const headers = rateLimitHeaders(result)
    expect(headers["X-RateLimit-Limit"]).toBe("60")
    expect(headers["X-RateLimit-Remaining"]).toBe("45")
    expect(headers["X-RateLimit-Reset"]).toBe("1700000000")
  })
})
