import { GoogleGenAI, Type, Schema } from "@google/genai";
import { EeatAuditResult } from "../../types/eeat";
import { PROMPT_EEAT_AUDIT } from "./prompts";

const getApiKey = () => {
  if (typeof process !== 'undefined' && process.env && process.env.API_KEY) {
    return process.env.API_KEY;
  }
  return null;
};

const seededScore = (seed: number, offset: number, min = 15, max = 85): number => {
  const raw = ((seed * 37 + offset * 19 + 11) * 17) % 1000;
  return min + Math.round((raw / 1000) * (max - min));
};

const fallbackSimulation = async (url: string, brandName?: string): Promise<EeatAuditResult> => {
  await new Promise(resolve => setTimeout(resolve, 2800));

  let hostname: string;
  try { hostname = new URL(url).hostname; } catch { hostname = url; }
  const brand = brandName || hostname;
  const seed = url.length + hostname.length;

  const experience = seededScore(seed, 1);
  const expertise = seededScore(seed, 2);
  const authoritativeness = seededScore(seed, 3);
  const trustworthiness = seededScore(seed, 4);
  const overall = Math.round((experience + expertise + authoritativeness + trustworthiness) / 4);

  const findings: EeatAuditResult['findings'] = [
    { category: 'experience', status: experience >= 50 ? 'present' : 'missing', element: 'Temoignages de premiere main', impact: 'high', recommendation: 'Ajouter des etudes de cas detaillees avec des resultats concrets et mesurables.' },
    { category: 'experience', status: experience >= 60 ? 'present' : 'incomplete', element: 'Contenu original (photos, videos)', impact: 'medium', recommendation: 'Integrer des visuels originaux (captures, photos terrain, videos) pour prouver l\'experience.' },
    { category: 'experience', status: experience >= 40 ? 'incomplete' : 'missing', element: 'Details specifiques au metier', impact: 'medium', recommendation: 'Enrichir le contenu avec des termes techniques et des details concrets du secteur.' },
    { category: 'expertise', status: expertise >= 50 ? 'present' : 'missing', element: 'Auteur identifie avec bio', impact: 'high', recommendation: 'Ajouter un bloc auteur avec bio, photo et credentials sur chaque article.' },
    { category: 'expertise', status: expertise >= 60 ? 'present' : 'missing', element: 'Credentials visibles', impact: 'high', recommendation: 'Lister les diplomes, certifications et experiences directement sur la page.' },
    { category: 'expertise', status: expertise >= 40 ? 'incomplete' : 'missing', element: 'Schema.org Person/hasCredential', impact: 'medium', recommendation: 'Implementer le schema JSON-LD Person avec hasCredential et alumniOf.' },
    { category: 'expertise', status: expertise >= 55 ? 'present' : 'incomplete', element: 'Profondeur du contenu', impact: 'medium', recommendation: 'Approfondir les sujets avec des donnees chiffrees, des sources et des exemples.' },
    { category: 'authority', status: authoritativeness >= 50 ? 'present' : 'missing', element: 'Mentions presse', impact: 'high', recommendation: 'Creer un bloc "Ils parlent de nous" avec des citations et liens vers les articles.' },
    { category: 'authority', status: authoritativeness >= 60 ? 'present' : 'missing', element: 'Citations par des pairs', impact: 'medium', recommendation: 'Obtenir des backlinks de sites d\'autorite et des mentions par des experts du secteur.' },
    { category: 'authority', status: authoritativeness >= 40 ? 'incomplete' : 'missing', element: 'Anciennete du domaine', impact: 'low', recommendation: 'Mettre en avant la date de creation du site et l\'historique de l\'entreprise.' },
    { category: 'trust', status: trustworthiness >= 60 ? 'present' : 'present', element: 'HTTPS', impact: 'high', recommendation: 'Le site est accessible en HTTPS (bon signal de confiance).' },
    { category: 'trust', status: trustworthiness >= 50 ? 'present' : 'missing', element: 'Mentions legales', impact: 'high', recommendation: 'Ajouter des mentions legales completes avec raison sociale, SIRET, adresse.' },
    { category: 'trust', status: trustworthiness >= 40 ? 'incomplete' : 'missing', element: 'Contact visible', impact: 'medium', recommendation: 'Afficher clairement email, telephone et adresse sur toutes les pages.' },
    { category: 'trust', status: trustworthiness >= 55 ? 'present' : 'missing', element: 'Avis verifiables', impact: 'high', recommendation: 'Integrer des avis Google/Trustpilot avec Schema.org AggregateRating.' },
    { category: 'trust', status: trustworthiness >= 45 ? 'incomplete' : 'missing', element: 'Politique de confidentialite', impact: 'medium', recommendation: 'Publier une politique de confidentialite detaillee et conforme RGPD.' },
  ];

  const sortedFindings = [...findings].filter(f => f.status !== 'present').sort((a, b) => {
    const impactOrder = { high: 0, medium: 1, low: 2 };
    return impactOrder[a.impact] - impactOrder[b.impact];
  });

  const priorityActions: EeatAuditResult['priorityActions'] = sortedFindings.slice(0, 5).map((f, i) => ({
    action: f.recommendation || `Ameliorer : ${f.element}`,
    impact: 100 - i * 15,
    effort: f.impact === 'high' ? 'medium' as const : 'low' as const,
    tool: f.category === 'expertise' ? 'Author Bio Generator' : f.category === 'authority' ? 'Trust Signals Generator' : f.category === 'trust' ? 'Trust Signals Generator' : 'Citation Block Generator',
  }));

  const summary = overall >= 70
    ? `${brand} presente un bon profil E-E-A-T avec un score de ${overall}/100. Les signaux d'autorite et de confiance sont bien presents. Des ameliorations ciblees sur ${experience < expertise ? 'l\'experience documentee' : 'l\'expertise visible'} permettraient d'atteindre l'excellence.`
    : overall >= 45
      ? `${brand} a un profil E-E-A-T moyen (${overall}/100). Certains signaux sont presents mais des elements cles manquent. Priorite : renforcer les credentials des auteurs, ajouter des preuves sociales et structurer les donnees Schema.org.`
      : `${brand} a un faible score E-E-A-T (${overall}/100). Les moteurs de reponse IA ne trouvent pas suffisamment de signaux d'autorite et de confiance. Une strategie E-E-A-T complete est necessaire : bios auteurs, certifications, avis, mentions legales.`;

  return {
    url,
    scores: { overall, experience, expertise, authoritativeness, trustworthiness },
    findings,
    priorityActions,
    summary,
  };
};

const buildResponseSchema = (): Schema => {
  const findingSchema: Schema = {
    type: Type.OBJECT,
    properties: {
      category: { type: Type.STRING, description: "experience | expertise | authority | trust" },
      status: { type: Type.STRING, description: "present | missing | incomplete" },
      element: { type: Type.STRING, description: "Element E-E-A-T evalue" },
      impact: { type: Type.STRING, description: "high | medium | low" },
      recommendation: { type: Type.STRING, description: "Recommandation actionable" },
    },
    required: ["category", "status", "element", "impact"],
  };

  const actionSchema: Schema = {
    type: Type.OBJECT,
    properties: {
      action: { type: Type.STRING },
      impact: { type: Type.NUMBER },
      effort: { type: Type.STRING, description: "low | medium | high" },
      tool: { type: Type.STRING, description: "Outil E-E-A-T recommande" },
    },
    required: ["action", "impact", "effort", "tool"],
  };

  return {
    type: Type.OBJECT,
    properties: {
      scores: {
        type: Type.OBJECT,
        properties: {
          overall: { type: Type.NUMBER },
          experience: { type: Type.NUMBER },
          expertise: { type: Type.NUMBER },
          authoritativeness: { type: Type.NUMBER },
          trustworthiness: { type: Type.NUMBER },
        },
        required: ["overall", "experience", "expertise", "authoritativeness", "trustworthiness"],
      },
      findings: { type: Type.ARRAY, items: findingSchema },
      priorityActions: { type: Type.ARRAY, items: actionSchema },
      summary: { type: Type.STRING },
    },
    required: ["scores", "findings", "priorityActions", "summary"],
  };
};

export const auditEeat = async (url: string, brandName?: string): Promise<EeatAuditResult> => {
  const apiKey = getApiKey();
  if (!apiKey) {
    console.warn("API_KEY not found, using simulation.");
    return fallbackSimulation(url, brandName);
  }

  try {
    const ai = new GoogleGenAI({ apiKey });

    const prompt = `${PROMPT_EEAT_AUDIT}\n\nURL: ${url}\n${brandName ? `MARQUE: ${brandName}` : ''}\n\nAnalyse la page et genere l'audit E-E-A-T complet.`;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: {
        responseMimeType: 'application/json',
        responseSchema: buildResponseSchema(),
        temperature: 0.3,
      }
    });

    let output = response.text;
    if (!output) throw new Error("Empty response");
    output = output.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();

    const parsed = JSON.parse(output);
    return { url, ...parsed };
  } catch (error) {
    console.error("E-E-A-T Audit failed:", error);
    return fallbackSimulation(url, brandName);
  }
};
