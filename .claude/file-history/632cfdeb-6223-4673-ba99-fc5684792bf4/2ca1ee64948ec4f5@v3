import { NextRequest, NextResponse } from "next/server"
import { createClient } from "@/lib/supabase/server"
import { deepScore, quickScore } from "@/services/content_scorer"
import { AuthError, ValidationError, formatApiError } from "@/lib/errors"

export const maxDuration = 30

export async function POST(req: NextRequest) {
  try {
    const supabase = createClient()
    const { data: { user } } = await supabase.auth.getUser()
    if (!user) {
      throw new AuthError()
    }

    const body = await req.json()
    const { content, contentType, brandName, language, mode } = body

    if (!content) {
      throw new ValidationError("Le champ 'content' est requis")
    }

    // Quick mode = rule-based only (instant, no API call)
    if (mode === "quick") {
      const result = quickScore(content)
      return NextResponse.json({
        success: true,
        score: result.score,
        flags: result.flags,
        mode: "quick",
      })
    }

    // Deep mode = AI-powered analysis
    const result = await deepScore(
      content,
      contentType || "general",
      brandName,
      language || "fr"
    )

    return NextResponse.json({
      success: true,
      ...result,
      mode: "deep",
    })
  } catch (error) {
    const { status, body } = formatApiError(error)
    return NextResponse.json(body, { status })
  }
}
