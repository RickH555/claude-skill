// ============================================================
// Dashboard Stats (aggregated queries)
// ============================================================

export async function getWorkspaceDashboardStats(workspaceId: string) {
  const supabase = createClient()

  const { data: projects } = await supabase
    .from("projects")
    .select("id, visibility_score, status")
    .eq("workspace_id", workspaceId)
    .eq("status", "active")

  const activeProjects = projects || []
  const avgScore = activeProjects.length > 0
    ? Math.round(activeProjects.reduce((sum, p) => sum + (p.visibility_score || 0), 0) / activeProjects.length)
    : 0

  const projectIds = activeProjects.map(p => p.id)

  let totalCitations = 0
  let totalMentions = 0

  if (projectIds.length > 0) {
    const { data: runs } = await supabase
      .from("analysis_runs")
      .select("citations_found, mentions_found")
      .in("project_id", projectIds)
      .eq("status", "completed")

    if (runs) {
      totalCitations = runs.reduce((sum, r) => sum + (r.citations_found || 0), 0)
      totalMentions = runs.reduce((sum, r) => sum + (r.mentions_found || 0), 0)
    }
  }

  return {
    activeProjectsCount: activeProjects.length,
    averageScore: avgScore,
    totalCitations,
    totalMentions,
  }
}
