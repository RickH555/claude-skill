n\n### 4. app/(app)/tools/blog-optimizer/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport BlogOptimizer from '@/views/BlogOptimizer';\n\nexport default function BlogOptimizerPage() {\n  const { goBack, user, handleDeductCredits, handleNavigateToPublisher } = useAppContext();\n  return (\n    <BlogOptimizer\n      onBack={goBack}\n      user={user}\n      onDeductCredits={handleDeductCredits}\n      onNavigateToPublisher={handleNavigateToPublisher}\n    />\n  );\n}\n```\n\n### 5. app/(app)/tools/source-of-truth/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport SourceOfTruth from '@/views/SourceOfTruth';\n\nexport default function SourceOfTruthPage() {\n  const { goBack, history, user, handleDeductCredits, truthLibrary, handleAddToTruthLibrary } = useAppContext();\n  return (\n    <SourceOfTruth\n      onBack={goBack}\n      history={history}\n      user={user}\n      onDeductCredits={handleDeductCredits}\n      savedFiles={truthLibrary}\n      onSaveFile={handleAddToTruthLibrary}\n    />\n  );\n}\n```\n\n### 6. app/(app)/tools/schema-org/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport SchemaOrg from '@/views/SchemaOrg';\n\nexport default function SchemaOrgPage() {\n  const { goBack, history, user, handleDeductCredits, schemaLibrary, handleAddToSchemaLibrary } = useAppContext();\n  return (\n    <SchemaOrg\n      onBack={goBack}\n      history={history}\n      user={user}\n      onDeductCredits={handleDeductCredits}\n      savedFiles={schemaLibrary}\n      onSaveFile={handleAddToSchemaLibrary}\n    />\n  );\n}\n```\n\n### 7. app/(app)/tools/robots-txt/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport RobotsTxt from '@/views/RobotsTxt';\n\nexport default function RobotsTxtPage() {\n  const { goBack, history, user, handleDeductCredits, handleUpdateAnalysis, robotsLibrary, handleAddToRobotsLibrary } = useAppContext();\n  return (\n    <RobotsTxt\n      onBack={goBack}\n      history={history}\n      user={user}\n      onDeductCredits={handleDeductCredits}\n      onUpdateAnalysis={handleUpdateAnalysis}\n      savedFiles={robotsLibrary}\n      onSaveFile={handleAddToRobotsLibrary}\n    />\n  );\n}\n```\n\n### 8. app/(app)/tools/llms-txt/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport LlmsTxtGenerator from '@/views/LlmsTxtGenerator';\n\nexport default function LlmsTxtPage() {\n  const { goBack, user, handleDeductCredits, history } = useAppContext();\n  return <LlmsTxtGenerator onBack={goBack} user={user} onDeductCredits={handleDeductCredits} history={history} />;\n}\n```\n\n### 9. app/(app)/tools/ai-response-layer/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport AiResponseLayer from '@/views/AiResponseLayer';\n\nexport default function AiResponseLayerPage() {\n  const { goBack, user, handleDeductCredits } = useAppContext();\n  return <AiResponseLayer onBack={goBack} user={user} onDeductCredits={handleDeductCredits} />;\n}\n```\n\n### 10. app/(app)/tools/citation-simulator/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport AiCitationSimulator from '@/views/AiCitationSimulator';\n\nexport default function CitationSimulatorPage() {\n  const { goBack, user, handleDeductCredits } = useAppContext();\n  return <AiCitationSimulator onBack={goBack} user={user} onDeductCredits={handleDeductCredits} />;\n}\n```\n\n### 11. app/(app)/tools/answer-first/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport AnswerFirstAudit from '@/views/AnswerFirstAudit';\n\nexport default function AnswerFirstPage() {\n  const { goBack, user, handleDeductCredits, history } = useAppContext();\n  return <AnswerFirstAudit onBack={goBack} user={user} onDeductCredits={handleDeductCredits} history={history} />;\n}\n```\n\n### 12. app/(app)/tools/eeat-builder/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport EeatBuilder from '@/views/EeatBuilder';\n\nexport default function EeatBuilderPage() {\n  const { goBack, user, handleDeductCredits, history } = useAppContext();\n  return <EeatBuilder onBack={goBack} user={user} onDeductCredits={handleDeductCredits} history={history} />;\n}\n```\n\nWrite all 12 files. Create directories as needed."},"uuid":"c064554c-742a-4dd7-904b-045f57aa98eb","timestamp":"2026-02-21T21:40:41.662Z"}
