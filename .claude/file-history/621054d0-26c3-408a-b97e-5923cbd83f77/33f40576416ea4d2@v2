import type { LoyaltyProgram } from '@loyalty/shared';

interface Props {
  merchantId: string;
  program?: LoyaltyProgram;
}

export function ProgramForm({ merchantId, program }: Props) {
  const [name, setName] = useState(program?.name ?? '');
  const [type, setType] = useState<string>(program?.type ?? 'stamp');
  const [stampGoal, setStampGoal] = useState(program?.stamp_goal?.toString() ?? '10');
  const [pointsPerEuro, setPointsPerEuro] = useState(program?.points_per_euro?.toString() ?? '1');
  const [rewardDescription, setRewardDescription] = useState(program?.reward_description ?? '');
  const [expirationDays, setExpirationDays] = useState(program?.expiration_days?.toString() ?? '');
  const [loading, setLoading] = useState(false);
  const router = useRouter();
  const supabase = createClient();

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    setLoading(true);
    const payload = {
      merchant_id: merchantId,
      name,
      type,
      stamp_goal: type === 'stamp' ? parseInt(stampGoal) : null,
      points_per_euro: type === 'points' ? parseFloat(pointsPerEuro) : null,
      reward_description: rewardDescription || null,
      expiration_days: expirationDays ? parseInt(expirationDays) : null,
    };

    if (program) {
      await supabase.from('loyalty_programs').update(payload).eq('id', program.id);
    } else {
      await supabase.from('loyalty_programs').insert(payload);
    }
    router.push('/programs');
    router.refresh();
  }

  return (
