import type {
  IntegrationConnection,
  IntegrationKPI,
  IntegrationPeriod,
  IntegrationProvider,
  IntegrationState,
  TrafficDataPoint,
  AttributionRow,
  AIQueryRow,
} from '../types/integrations.ts'

const STORAGE_KEY = 'citedby_integrations'

// ---- Connection State ----

function defaultState(): IntegrationState {
  return {
    connections: [
      { provider: 'ga4', status: 'disconnected', accountName: null, connectedAt: null },
      { provider: 'search_console', status: 'disconnected', accountName: null, connectedAt: null },
    ],
    period: '30d',
  }
}

export function getIntegrationState(): IntegrationState {
  const raw = localStorage.getItem(STORAGE_KEY)
  return raw ? JSON.parse(raw) : defaultState()
}

function saveState(state: IntegrationState): void {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state))
}

export function hasAnyConnection(state: IntegrationState): boolean {
  return state.connections.some((c) => c.status === 'connected')
}

// ---- OAuth Simulation ----

export function connectProvider(provider: IntegrationProvider): Promise<IntegrationConnection> {
  return new Promise((resolve) => {
    const state = getIntegrationState()
    const conn = state.connections.find((c) => c.provider === provider)!
    conn.status = 'connecting'
    saveState(state)

    setTimeout(() => {
      conn.status = 'connected'
      conn.accountName = provider === 'ga4' ? 'citedby.ai - GA4' : 'citedby.ai - Search Console'
      conn.connectedAt = new Date().toISOString()
      saveState(state)
      resolve(conn)
    }, 2000)
  })
}

export function disconnectProvider(provider: IntegrationProvider): void {
  const state = getIntegrationState()
  const conn = state.connections.find((c) => c.provider === provider)!
  conn.status = 'disconnected'
  conn.accountName = null
  conn.connectedAt = null
  saveState(state)
}

export function setPeriod(period: IntegrationPeriod): void {
  const state = getIntegrationState()
  state.period = period
  saveState(state)
}

// ---- Mock Data Generators ----

function daysForPeriod(period: IntegrationPeriod): number {
  return period === '7d' ? 7 : period === '30d' ? 30 : 90
}

export function getKPIs(period: IntegrationPeriod): IntegrationKPI {
  const mul = daysForPeriod(period) / 30
  return {
    aiVisits: Math.round(4820 * mul),
    aiConversions: Math.round(234 * mul),
    aiTrafficShare: 12.4 + (Math.random() * 2 - 1),
    avgAiCTR: 3.8 + (Math.random() * 0.6 - 0.3),
  }
}

export function getTrafficData(period: IntegrationPeriod): TrafficDataPoint[] {
  const days = daysForPeriod(period)
  const data: TrafficDataPoint[] = []
  const now = new Date()

  for (let i = days - 1; i >= 0; i--) {
    const d = new Date(now)
    d.setDate(d.getDate() - i)
    data.push({
      date: d.toISOString().slice(0, 10),
      chatgpt: Math.floor(40 + Math.random() * 60),
      perplexity: Math.floor(20 + Math.random() * 40),
      claude: Math.floor(15 + Math.random() * 30),
      gemini: Math.floor(10 + Math.random() * 25),
      copilot: Math.floor(5 + Math.random() * 15),
    })
  }

  return data
}

