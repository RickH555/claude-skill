// ================================================================
// PLATFORM DETECTION
// ================================================================

const detectPlatform = (url: string): PlatformConfig => {
  const lowerUrl = url.toLowerCase();

  if (lowerUrl.includes('shopify') || lowerUrl.includes('store') || lowerUrl.includes('shop')) {
    return {
      name: 'Shopify / E-commerce',
      disallow: ['/cart', '/orders', '/checkouts', '/account', '/collections/*+*', '/blogs/*+*', '/*design_theme_id'],
      sitemaps: ['/sitemap.xml', '/sitemap_products_1.xml']
    };
  }

  if (lowerUrl.includes('wordpress') || lowerUrl.includes('blog') || lowerUrl.includes('wp-')) {
    return {
      name: 'WordPress',
      disallow: ['/wp-admin/', '/wp-includes/', '/wp-content/plugins/', '/xmlrpc.php', '/readme.html', '/?s='],
      sitemaps: ['/sitemap_index.xml', '/post-sitemap.xml']
    };
  }

  if (lowerUrl.includes('app.') || lowerUrl.includes('dashboard') || lowerUrl.includes('portal')) {
    return {
      name: 'SaaS / Web App',
      disallow: ['/api/', '/dashboard/', '/settings/', '/user/', '/private/', '/auth/'],
      sitemaps: ['/sitemap.xml']
    };
  }

  // Default / Generic
  return {
    name: 'Site Général',
    disallow: ['/admin/', '/login/', '/tmp/', '/private/', '/search'],
    sitemaps: ['/sitemap.xml']
  };
};

// ================================================================
// FALLBACK — Local generation (existing logic preserved)
// ================================================================

const fallbackGeneration = (urlStr: string): RobotsResult => {
  let hostname = urlStr;
  let protocol = 'https';

  try {
    const urlObj = new URL(urlStr.startsWith('http') ? urlStr : `https://${urlStr}`);
    hostname = urlObj.hostname;
    protocol = urlObj.protocol.replace(':', '');
  } catch (e) {
    // Fallback if URL is invalid
  }

  const platform = detectPlatform(urlStr);
  const date = new Date().toISOString().split('T')[0];

  let content = `# Robots.txt Optimized for AEO (Answer Engine Optimization)
# Generated by CitedBy.ai on ${date}
# Domain: ${hostname}
# Detected Architecture: ${platform.name}

# ==========================================
# PART 1: AI & LLM AGENTS (ALLOW LIST)
# ==========================================
# We explicitly allow these bots to ensure your content feeds
# the knowledge graphs of ChatGPT, Gemini, Claude, and Perplexity.
`;

  AI_BOTS.forEach(bot => {
    content += `\nUser-agent: ${bot.agent}\n`;
    content += `Allow: /\n`;
    content += `# Purpose: ${bot.comment}\n`;
  });

  content += `
# ==========================================
# PART 2: GENERAL CRAWLERS & SEO
# ==========================================
User-agent: *
Allow: /

# --- Security & Privacy Protection ---
# Rules adapted for ${platform.name} structure
`;

  platform.disallow.forEach(path => {
    content += `Disallow: ${path}\n`;
  });

  content += `
# --- Sitemaps ---
# Provide clear paths for deep indexing
`;

  platform.sitemaps.forEach(map => {
    content += `Sitemap: ${protocol}://${hostname}${map}\n`;
  });

  content += `
# End of file
`;

  const rulesCount = AI_BOTS.length + platform.disallow.length + 1; // +1 for Allow: /

  return {
    content,
    platformDetected: platform.name,
    aiBotsCount: AI_BOTS.length,
    rulesCount,
  };
};

// ================================================================
// LEGACY EXPORTS — Synchronous local generation (kept for compatibility)
// ================================================================

export const generateOptimizedRobotsTxt = (urlStr: string): string => {
  return fallbackGeneration(urlStr).content;
};

export const parseCurrentRobotsTxt = (url: string): string => {
  const platform = detectPlatform(url);

  let content = `User-agent: *\n`;

  if (platform.name === 'WordPress') {
    content += `Disallow: /wp-admin/\nAllow: /wp-admin/admin-ajax.php\n`;
  } else if (platform.name.includes('Shopify')) {
    content += `Disallow: /cart\nDisallow: /orders\n`;
  } else {
    content += `Disallow: /admin/\nDisallow: /tmp/\n`;
  }

  content += `\nSitemap: ${url}/sitemap.xml`;

  return content;
};

export const getDetectedPlatformName = (url: string): string => {
  return detectPlatform(url).name;
};

// ================================================================
// MAIN EXPORT — GEMINI-POWERED GENERATION
// ================================================================

export const generateRobotsWithAI = async (urlStr: string): Promise<RobotsResult> => {
  const apiKey = getApiKey();

  if (!apiKey) {
    console.warn("API_KEY not found, using local robots.txt generation.");
    return fallbackGeneration(urlStr);
  }

  let hostname = urlStr;
  let protocol = 'https';

  try {
    const urlObj = new URL(urlStr.startsWith('http') ? urlStr : `https://${urlStr}`);
    hostname = urlObj.hostname;
    protocol = urlObj.protocol.replace(':', '');
  } catch (e) {
    // Fallback
  }

  const platform = detectPlatform(urlStr);

  try {
    const ai = new GoogleGenAI({ apiKey });

    const schema: Schema = {
      type: Type.OBJECT,
      properties: {
        robotsTxt: { type: Type.STRING, description: "The complete robots.txt file content optimized for AEO" },
        platformDetected: { type: Type.STRING, description: "The detected platform/CMS name" },
        aiBotsCount: { type: Type.NUMBER, description: "Number of AI bots explicitly whitelisted" },
        rulesCount: { type: Type.NUMBER, description: "Total number of Allow/Disallow rules" },
      },
      required: ["robotsTxt", "platformDetected", "aiBotsCount", "rulesCount"],
    };

    const prompt = `
      INFORMATIONS DU SITE :
      - URL complete : ${urlStr}
      - Hostname : ${hostname}
      - Protocol : ${protocol}
      - Architecture detectee : ${platform.name}
      - Routes sensibles identifiees : ${platform.disallow.join(', ')}
      - Sitemaps connus : ${platform.sitemaps.map(s => `${protocol}://${hostname}${s}`).join(', ')}

      BOTS IA A AUTORISER (whitelist explicite obligatoire) :
      ${AI_BOTS.map(bot => `- ${bot.agent} : ${bot.comment}`).join('\n')}

      Bots supplementaires a considerer :
      - Bytespider : ByteDance/TikTok AI
      - Cohere-ai : Cohere (recherche semantique)
      - YouBot : You.com AI search engine
      - AI2Bot : Allen Institute for AI
      - Diffbot : Knowledge Graph builder

      MISSION :
      Genere un fichier robots.txt complet optimise pour maximiser la citabilite de ce site par les moteurs de reponse IA, tout en protegeant les routes sensibles.

      Exigences :
      1. En-tete avec date de generation, domaine et architecture detectee
      2. PARTIE 1 : Whitelist explicite de TOUS les bots IA avec Allow: / et commentaire explicatif
      3. PARTIE 2 : Regles generales (User-agent: * avec Allow: /)
      4. PARTIE 3 : Protection des routes sensibles adaptees a ${platform.name}
      5. PARTIE 4 : Declaration de tous les Sitemaps
      6. PARTIE 5 : References aux fichiers AEO (llms.txt, llm.json) si applicable
      7. Commentaires clairs et pedagogiques dans chaque section
      8. Format robots.txt standard uniquement (pas de JSON, pas de Markdown)

      Le champ "robotsTxt" doit contenir le contenu brut du fichier robots.txt.
      Calcule aiBotsCount (bots IA autorises) et rulesCount (total des regles Allow/Disallow).
    `;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: {
        systemInstruction: ROBOTS_SYSTEM_PROMPT,
        responseMimeType: 'application/json',
        responseSchema: schema,
        temperature: 0.2,
      },
    });

    let output = response.text;
    if (!output) {
      throw new Error("Empty response from AI");
    }

    output = output.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
    const parsed = JSON.parse(output);

    return {
      content: parsed.robotsTxt,
      platformDetected: parsed.platformDetected,
      aiBotsCount: parsed.aiBotsCount,
      rulesCount: parsed.rulesCount,
    };
  } catch (error) {
    console.error("Robots.txt AI generation failed:", error);
    return fallbackGeneration(urlStr);
  }
};
