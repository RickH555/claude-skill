import { NextResponse } from "next/server"
import { createClient } from "@/lib/supabase/server"
import { runMonitoring, generateDefaultPrompts, type ProjectContext } from "@/services/monitoring_service"
import { AuthError, ValidationError, NotFoundError, RateLimitError, formatApiError } from "@/lib/errors"
import { checkRateLimit } from "@/lib/rate-limit"

export const maxDuration = 60 // Allow up to 60s for AI calls

export async function POST(req: Request) {
  try {
    const supabase = createClient()
    const { data: { user } } = await supabase.auth.getUser()

    if (!user) {
      throw new AuthError()
    }

    // Rate limit: 5 analysis runs per minute per user
    const rl = checkRateLimit(`runs:${user.id}`, 5)
    if (!rl.success) throw new RateLimitError()

    const { projectId } = await req.json()

    if (!projectId) {
      throw new ValidationError("Project ID required")
    }

    // 1. Fetch project data
    const { data: project, error: projectError } = await supabase
      .from("projects")
      .select("*")
      .eq("id", projectId)
      .single()

    if (projectError || !project) {
      throw new NotFoundError("Projet introuvable")
    }

    // 2. Create analysis run record
    const { data: run, error: runError } = await supabase
      .from("analysis_runs")
      .insert({
        project_id: projectId,
        triggered_by: user.id,
        status: "running",
        started_at: new Date().toISOString(),
      })
      .select()
      .single()

    if (runError || !run) {
      return NextResponse.json({ error: "Failed to create run" }, { status: 500 })
    }

    // 3. Build project context
    const context: ProjectContext = {
      brandName: project.brand_name || project.name,
      domain: project.domain,
      industry: project.industry || "general",
      services: project.keywords || [],
      competitors: project.competitors || [],
      keywords: project.keywords || [],
    }

    // 4. Generate prompts and run monitoring
    const prompts = generateDefaultPrompts(context, "fr")
    const engines = ["ChatGPT", "Perplexity", "Gemini", "Claude", "Copilot"] as const

    const { results, summary } = await runMonitoring(prompts, context, [...engines])

    // 5. Save results to Supabase
    const runResults = results.map((r) => ({
      run_id: run.id,
      project_id: projectId,
      ai_engine: r.engine,
      prompt: r.prompt,
      response: r.response,
      score: r.score,
      result_type: r.resultType,
      brand_mentioned: r.brandMentioned,
      url_mentioned: r.urlMentioned,
      competitor_mentioned: r.competitorMentioned,
      sentiment: r.sentiment,
      sentiment_score: r.sentimentScore,
    }))

    await supabase.from("run_results").insert(runResults)

    // 6. Update run with summary
    await supabase
      .from("analysis_runs")
      .update({
        status: "completed",
        global_score: summary.globalScore,
        total_prompts: summary.totalPrompts,
        citations_found: summary.citationsFound,
        mentions_found: summary.mentionsFound,
        categories: summary.engineScores,
        ai_citation: {
          alerts: summary.alerts,
          competitorComparison: summary.competitorComparison,
        },
        completed_at: new Date().toISOString(),
      })
      .eq("id", run.id)

    // 7. Update project score and trend
    const { data: previousRun } = await supabase
      .from("analysis_runs")
      .select("global_score")
      .eq("project_id", projectId)
      .eq("status", "completed")
      .neq("id", run.id)
      .order("created_at", { ascending: false })
      .limit(1)
      .single()

    const previousScore = previousRun?.global_score || 0
    const trend = previousScore > 0 ? ((summary.globalScore - previousScore) / previousScore) * 100 : 0

    await supabase
      .from("projects")
      .update({
        visibility_score: summary.globalScore,
        trend: Math.round(trend * 100) / 100,
        last_run_at: new Date().toISOString(),
      })
      .eq("id", projectId)

    // 8. Generate recommendations from alerts
    if (summary.alerts.length > 0) {
      const recs = summary.alerts
        .filter((a) => a.severity !== "info")
        .map((alert) => ({
          run_id: run.id,
          project_id: projectId,
          priority: alert.severity === "critical" ? "critical" : "high",
          title: alert.message,
          description: alert.action,
          action: alert.action,
          effort: "medium",
          impact: alert.severity === "critical" ? "high" : "medium",
          category: "Monitoring",
        }))

      if (recs.length > 0) {
        await supabase.from("recommendations").insert(recs)
      }
    }

    return NextResponse.json({
      success: true,
      runId: run.id,
      summary: {
        globalScore: summary.globalScore,
        totalPrompts: summary.totalPrompts,
        citationsFound: summary.citationsFound,
        mentionsFound: summary.mentionsFound,
        engineScores: summary.engineScores,
        alerts: summary.alerts,
      },
    })
  } catch (error) {
    const { status, body } = formatApiError(error)
    return NextResponse.json(body, { status })
  }
}
