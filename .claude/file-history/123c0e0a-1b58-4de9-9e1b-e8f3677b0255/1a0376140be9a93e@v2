import type { MonitoringSchedule, ScheduleFrequency, ScheduledScanResult } from '../types/scheduling.ts'

const SCHEDULES_KEY = 'citedby_monitoring_schedules'
const HISTORY_KEY = 'citedby_scheduled_scan_history'

function generateId(): string {
  return `sch_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`
}

// ---- CRUD Schedules ----

export function getSchedules(): MonitoringSchedule[] {
  const raw = localStorage.getItem(SCHEDULES_KEY)
  return raw ? JSON.parse(raw) : []
}

function saveSchedules(schedules: MonitoringSchedule[]): void {
  localStorage.setItem(SCHEDULES_KEY, JSON.stringify(schedules))
}

export function computeNextRun(frequency: ScheduleFrequency, hour: string, dayOfWeek?: number, dayOfMonth?: number): string {
  const now = new Date()
  const [h, m] = hour.split(':').map(Number)
  const next = new Date(now)
  next.setHours(h, m, 0, 0)

  if (frequency === 'daily') {
    if (next <= now) next.setDate(next.getDate() + 1)
  } else if (frequency === 'weekly' && dayOfWeek !== undefined) {
    next.setDate(next.getDate() + ((7 + dayOfWeek - next.getDay()) % 7 || 7))
    if (next <= now) next.setDate(next.getDate() + 7)
  } else if (frequency === 'monthly' && dayOfMonth !== undefined) {
    next.setDate(dayOfMonth)
    if (next <= now) next.setMonth(next.getMonth() + 1)
  }

  return next.toISOString()
}

export function createSchedule(
  brandName: string,
  brandUrl: string,
  frequency: ScheduleFrequency,
  hour: string,
  emailNotification: boolean,
  dayOfWeek?: number,
  dayOfMonth?: number,
): MonitoringSchedule {
  const schedule: MonitoringSchedule = {
    id: generateId(),
    brandName,
    brandUrl,
    frequency,
    hour,
    dayOfWeek,
    dayOfMonth,
    emailNotification,
    active: true,
    createdAt: new Date().toISOString(),
    lastRun: null,
    nextRun: computeNextRun(frequency, hour, dayOfWeek, dayOfMonth),
  }

  const schedules = getSchedules()
  schedules.push(schedule)
  saveSchedules(schedules)
  return schedule
}

export function toggleSchedule(id: string): MonitoringSchedule | null {
  const schedules = getSchedules()
  const schedule = schedules.find((s) => s.id === id)
  if (!schedule) return null
  schedule.active = !schedule.active
  saveSchedules(schedules)
  return schedule
}

export function deleteSchedule(id: string): void {
  const schedules = getSchedules().filter((s) => s.id !== id)
  saveSchedules(schedules)
}

// ---- Scan History ----

export function getScanHistory(): ScheduledScanResult[] {
  const raw = localStorage.getItem(HISTORY_KEY)
  return raw ? JSON.parse(raw) : []
}

function saveScanHistory(history: ScheduledScanResult[]): void {
  localStorage.setItem(HISTORY_KEY, JSON.stringify(history))
}

function simulateScan(schedule: MonitoringSchedule): ScheduledScanResult {
  const citationsFound = Math.floor(Math.random() * 20) + 5
  return {
    id: `scan_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
    scheduleId: schedule.id,
    brandName: schedule.brandName,
    executedAt: new Date().toISOString(),
    citationsFound,
    citedCount: Math.floor(citationsFound * (0.3 + Math.random() * 0.5)),
    status: 'completed',
  }
}

export function checkAndRunPendingScans(): ScheduledScanResult[] {
  const schedules = getSchedules()
  const now = new Date()
  const results: ScheduledScanResult[] = []
  const history = getScanHistory()

  for (const schedule of schedules) {
    if (!schedule.active) continue
    if (new Date(schedule.nextRun) <= now) {
      const result = simulateScan(schedule)
      results.push(result)
      history.unshift(result)
      schedule.lastRun = now.toISOString()
      schedule.nextRun = computeNextRun(schedule.frequency, schedule.hour, schedule.dayOfWeek, schedule.dayOfMonth)
    }
  }

  if (results.length > 0) {
    saveSchedules(schedules)
    saveScanHistory(history.slice(0, 100))
  }

  return results
}

export function getFrequencyLabel(freq: ScheduleFrequency): string {
  const labels: Record<ScheduleFrequency, string> = {
    daily: 'Quotidien',
    weekly: 'Hebdomadaire',
    monthly: 'Mensuel',
  }
  return labels[freq]
}

export function getFrequencyColor(freq: ScheduleFrequency): string {
  const colors: Record<ScheduleFrequency, string> = {
    daily: 'bg-blue-100 text-blue-700',
    weekly: 'bg-purple-100 text-purple-700',
    monthly: 'bg-amber-100 text-amber-700',
  }
  return colors[freq]
}
