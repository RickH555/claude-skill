export const dynamic = 'force-dynamic';

import PageHeader from '@/components/layout/PageHeader';
import Card from '@/components/ui/Card';
import Badge from '@/components/ui/Badge';
import RewardForm from '@/components/merchant/RewardForm';
import { createServerSupabase } from '@/lib/supabase/server';

export default async function RewardsPage() {
  const supabase = await createServerSupabase();
  const { data: { user } } = await supabase.auth.getUser();

  // Get merchant record via user_id
  const { data: merchant } = await supabase
    .from('merchants')
    .select('id')
    .eq('user_id', user!.id)
    .single();

  const { data: programs } = await supabase
    .from('loyalty_programs')
    .select('*')
    .eq('merchant_id', merchant!.id)
    .eq('is_active', true);

  // Fetch rewards for all merchant programs
  const programIds = programs?.map(p => p.id) || [];
  const { data: rewards } = programIds.length > 0
    ? await supabase
        .from('rewards')
        .select('*, loyalty_programs(name)')
        .in('program_id', programIds)
        .order('created_at', { ascending: false })
    : { data: [] };

  const discountLabel = (type: string, value: number) => {
    if (type === 'freebie') return 'Gratuit';
    if (type === 'percentage') return `${value}%`;
    return `${value}€`;
  };

  return (
    <div className="space-y-6">
      <PageHeader title="Récompenses" description="Gérez les récompenses de vos programmes." />

      <RewardForm programs={programs || []} />

      {rewards && rewards.length > 0 && (
        <div>
          <h2 className="text-[15px] font-semibold text-[var(--text-primary)] mb-4">Récompenses existantes</h2>
          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {rewards.map((r: any, i: number) => (
              <Card key={r.id} className={`stagger-enter stagger-${Math.min(i + 1, 6)}`}>
                <div className="flex items-center justify-between mb-2">
                  <h3 className="text-[15px] font-semibold text-[var(--text-primary)]">{r.name}</h3>
                  <Badge variant={r.is_active ? 'success' : 'default'}>
                    {r.is_active ? 'Active' : 'Inactive'}
                  </Badge>
                </div>
                {r.description && (
                  <p className="text-[12px] text-[var(--text-secondary)] mb-1">{r.description}</p>
                )}
                <p className="text-[13px] text-[var(--text-tertiary)]">
                  {(r as any).loyalty_programs?.name || 'Programme'} — {discountLabel(r.discount_type, r.discount_value)}
                </p>
                {(r.stamps_required > 0 || r.points_cost > 0) && (
                  <p className="text-[12px] text-[var(--accent)] mt-1">
                    {r.stamps_required > 0 && `${r.stamps_required} tampons requis`}
                    {r.points_cost > 0 && `${r.points_cost} points requis`}
                  </p>
                )}
              </Card>
            ))}
          </div>
        </div>
      )}

      {(!rewards || rewards.length === 0) && programs && programs.length > 0 && (
        <Card className="text-center py-8">
          <p className="text-[var(--text-tertiary)] text-[13px]">Aucune récompense. Créez-en une ci-dessus !</p>
        </Card>
      )}
    </div>
  );
}
