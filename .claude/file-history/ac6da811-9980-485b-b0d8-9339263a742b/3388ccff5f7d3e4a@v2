  return {
    html,
    title: `${config.name} — AI Response Hub`,
    description: `${config.description} — Hub central des ressources optimisées pour les moteurs de réponse IA.`,
    schemaMarkup: 'WebPage + ItemList (intégré dans le HTML)',
  };
};

export const generateHub = async (config: SiteConfig, queryPages: QueryPageConfig[]): Promise<HubOutput> => {
  const apiKey = getApiKey();

  if (!apiKey) {
    console.warn("API_KEY not found, using hub simulation.");
    return fallbackHubSimulation(config, queryPages);
  }

  try {
    const ai = new GoogleGenAI({ apiKey });

    const schema: Schema = {
      type: Type.OBJECT,
      properties: {
        html: { type: Type.STRING, description: "Le HTML complet de la page hub (<!DOCTYPE html> ... </html>)" },
        title: { type: Type.STRING, description: "Le titre de la page" },
        description: { type: Type.STRING, description: "La meta description" },
        schemaMarkup: { type: Type.STRING, description: "Description des Schema.org utilisés" },
      },
      required: ["html", "title", "description", "schemaMarkup"],
    };

    const prompt = `Génère le Hub Central /ai/index.html pour le site suivant :

SITE : ${config.name}
URL : ${config.url}
DESCRIPTION : ${config.description}
ENTITÉ : ${config.entity}
CONTACT : ${config.contact.email}

QUERY PAGES EXISTANTES :
${queryPages.map(qp => `- "${qp.targetQuestion}" → /ai/query/${qp.slug}.html`).join('\n')}

Le hub doit :
1. Présenter l'entreprise en format Answer-First
2. Lister toutes les Query Pages avec liens
3. Pointer vers /ai/recommend.json et /sitemap-ai.xml
4. Intégrer Schema.org JSON-LD (WebPage + ItemList)
5. Avoir un design dark theme professionnel autonome (CSS intégré)`;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: {
        systemInstruction: HUB_SYSTEM_PROMPT,
        responseMimeType: 'application/json',
        responseSchema: schema,
        temperature: 0.3,
      }
    });

    let output = response.text;
    if (!output) throw new Error("Empty response from AI");
    output = output.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
    const parsed = JSON.parse(output);

    return {
      html: parsed.html,
      title: parsed.title,
      description: parsed.description,
      schemaMarkup: parsed.schemaMarkup,
    };
  } catch (error) {
    console.error("Hub generation failed:", error);
    return fallbackHubSimulation(config, queryPages);
  }
};
