// components/UnlockAllBanner.tsx

import { Zap, Star, Package } from 'lucide-react';
import type { VaultSummary } from '../services/solution-vault';

interface UnlockAllBannerProps {
  summary: VaultSummary;
  onUnlockAll: () => void;
  creditsRemaining: number;
}

export default function UnlockAllBanner({ summary, onUnlockAll, creditsRemaining }: UnlockAllBannerProps) {
  if (summary.lockedBlocks === 0) return null; // Tout est déjà débloqué

  // Réduction pour pack complet : -30% arrondi
  const packCost = summary.creditCostToUnlockAll;
  const savings = summary.lockedBlocks - packCost;
  const canAfford = creditsRemaining >= packCost;

  return (
    <div className="rounded-2xl border border-purple-500/20 bg-gradient-to-r from-purple-500/[0.08] to-violet-500/[0.08] p-5">
      <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div className="min-w-0">
          <div className="flex items-center gap-2 mb-1">
            <Package className="w-5 h-5 text-purple-400 shrink-0" />
            <h3 className="text-white font-semibold text-sm">
              Débloquer toutes les solutions ({summary.lockedBlocks} restantes)
            </h3>
          </div>
          <p className="text-xs text-gray-500">
            Impact total : +{summary.remainingImpact} points sur votre score AEO
          </p>
          {savings > 0 && (
            <p className="text-xs text-green-400 mt-1 flex items-center gap-1">
              <Star className="w-3 h-3" />
              Économisez {savings} crédit{savings > 1 ? 's' : ''} avec le pack complet
            </p>
          )}
        </div>

        <button
          onClick={onUnlockAll}
          disabled={!canAfford}
          className={`flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-xs transition-all whitespace-nowrap shrink-0
            ${canAfford
              ? 'bg-gradient-to-r from-purple-500 to-violet-600 text-white hover:from-purple-600 hover:to-violet-700 shadow-lg shadow-purple-900/30 hover:shadow-xl hover:scale-105'
              : 'bg-white/[0.06] text-gray-600 cursor-not-allowed'
            }`}
        >
          <Zap className="w-4 h-4" />
          {canAfford
            ? `Tout débloquer (${packCost} crédits)`
            : `${packCost} crédits requis`}
        </button>
      </div>
    </div>
  );
}
