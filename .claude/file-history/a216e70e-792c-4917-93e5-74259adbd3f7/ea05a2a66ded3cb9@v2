import React, { useState, useEffect } from 'react';
import { Activity, Search, Clock, Plus, Loader2, CheckCircle, XCircle, RefreshCw, Bot, Globe, BrainCircuit, Sparkles, Calendar, ArrowRight, Zap } from 'lucide-react';
import { User } from '../types';

interface AiMonitoringProps {
  onBack: () => void;
  onNavigate: (view: any) => void;
  onDeductCredits: (amount: number) => boolean;
  user: User | null;
}

type EngineResult = {
  engine: string;
  icon: React.ReactNode;
  color: string;
  status: 'idle' | 'scanning' | 'done' | 'error';
  mentioned: boolean;
  excerpt: string;
  confidence: number;
};

type ScheduleEntry = {
  id: string;
  url: string;
  frequency: 'daily' | 'weekly' | 'monthly';
  lastRun: string;
  nextRun: string;
  enabled: boolean;
};

const AiMonitoring: React.FC<AiMonitoringProps> = ({ onBack, onNavigate, onDeductCredits, user }) => {
  const [activeTab, setActiveTab] = useState<'scan' | 'schedule'>('scan');
  const [scanUrl, setScanUrl] = useState('');
  const [scanBrand, setScanBrand] = useState('');
  const [isScanning, setIsScanning] = useState(false);
  const [scanComplete, setScanComplete] = useState(false);

  const [engines, setEngines] = useState<EngineResult[]>([
    { engine: 'ChatGPT', icon: <Bot size={20} />, color: 'text-green-400', status: 'idle', mentioned: false, excerpt: '', confidence: 0 },
    { engine: 'Claude', icon: <BrainCircuit size={20} />, color: 'text-amber-400', status: 'idle', mentioned: false, excerpt: '', confidence: 0 },
    { engine: 'Gemini', icon: <Sparkles size={20} />, color: 'text-blue-400', status: 'idle', mentioned: false, excerpt: '', confidence: 0 },
    { engine: 'Perplexity', icon: <Search size={20} />, color: 'text-purple-400', status: 'idle', mentioned: false, excerpt: '', confidence: 0 },
    { engine: 'AI Overviews', icon: <Globe size={20} />, color: 'text-rose-400', status: 'idle', mentioned: false, excerpt: '', confidence: 0 },
  ]);

  const [schedules, setSchedules] = useState<ScheduleEntry[]>([
    { id: '1', url: 'https://example.com', frequency: 'weekly', lastRun: '2026-02-18', nextRun: '2026-02-25', enabled: true },
    { id: '2', url: 'https://myblog.com', frequency: 'daily', lastRun: '2026-02-19', nextRun: '2026-02-20', enabled: true },
    { id: '3', url: 'https://shop.example.fr', frequency: 'monthly', lastRun: '2026-02-01', nextRun: '2026-03-01', enabled: false },
  ]);

  const handleScan = async () => {
    if (!scanUrl.trim() || !scanBrand.trim()) return;
    if (!onDeductCredits(5)) return;
    setIsScanning(true);
    setScanComplete(false);
    const updated = engines.map(e => ({ ...e, status: 'scanning' as const, mentioned: false, excerpt: '', confidence: 0 }));
    setEngines(updated);

    for (let i = 0; i < engines.length; i++) {
      await new Promise(r => setTimeout(r, 800 + Math.random() * 1200));
      setEngines(prev => prev.map((e, idx) => {
        if (idx !== i) return e;
        const mentioned = Math.random() > 0.3;
        return {
          ...e,
          status: 'done',
          mentioned,
          excerpt: mentioned ? `${scanBrand} est une r\u00e9f\u00e9rence reconnue dans son domaine...` : 'Aucune mention d\u00e9tect\u00e9e pour cette marque.',
          confidence: mentioned ? Math.round(50 + Math.random() * 50) : Math.round(Math.random() * 30),
        };
      }));
    }
    setIsScanning(false);
    setScanComplete(true);
  };

  const toggleSchedule = (id: string) => {
    setSchedules(prev => prev.map(s => s.id === id ? { ...s, enabled: !s.enabled } : s));
  };

  return (
    <div className="w-full px-6 py-8 animate-in fade-in duration-500">
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
          <h1 className="text-3xl font-bold text-white">Monitoring <span className="gradient-text">IA</span></h1>
          <p className="text-gray-500 text-sm mt-1">Scannez votre pr\u00e9sence sur les 5 moteurs IA g\u00e9n\u00e9ratifs</p>
        </div>
        <div className="flex items-center gap-2 text-xs text-gray-500 bg-white/[0.03] border border-white/[0.06] rounded-full px-3 py-1.5">
          <Zap size={12} className="text-amber-400" /> 5 cr\u00e9dits / scan
        </div>
      </div>

      {/* Tabs */}
      <div className="flex gap-1 bg-white/[0.03] rounded-xl p-1 mb-8 w-fit">
        <button onClick={() => setActiveTab('scan')} className={`px-5 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === 'scan' ? 'bg-amber-500/20 text-amber-300 border border-amber-500/20' : 'text-gray-500 hover:text-gray-300'}`}>
          <span className="flex items-center gap-2"><Activity size={14} /> Scan Instantan\u00e9</span>
        </button>
        <button onClick={() => setActiveTab('schedule')} className={`px-5 py-2 rounded-lg text-sm font-medium transition-all ${activeTab === 'schedule' ? 'bg-amber-500/20 text-amber-300 border border-amber-500/20' : 'text-gray-500 hover:text-gray-300'}`}>
          <span className="flex items-center gap-2"><Calendar size={14} /> Planification</span>
        </button>
      </div>

      {activeTab === 'scan' && (
        <div>
          {/* Scan Form */}
          <div className="ninja-card p-6 mb-8">
            <div className="grid md:grid-cols-2 gap-4 mb-4">
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">Marque / Entreprise</label>
                <input type="text" value={scanBrand} onChange={e => setScanBrand(e.target.value)} placeholder="Ex: CitedBy" className="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-600 outline-none focus:border-amber-500/50 transition-all" />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-300 mb-2">URL du site</label>
                <input type="text" value={scanUrl} onChange={e => setScanUrl(e.target.value)} placeholder="https://www.example.com" className="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-600 outline-none focus:border-amber-500/50 transition-all" />
              </div>
            </div>
            <button onClick={handleScan} disabled={isScanning || !scanUrl.trim() || !scanBrand.trim()} className="btn-gradient px-8 py-3 font-bold flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
              {isScanning ? <><Loader2 size={16} className="animate-spin" /> Scan en cours...</> : <><RefreshCw size={16} /> Lancer le scan</>}
            </button>
          </div>

          {/* Engine Cards */}
          <div className="grid md:grid-cols-5 gap-4 mb-8">
            {engines.map(e => (
              <div key={e.engine} className={`ninja-card p-5 flex flex-col items-center text-center gap-3 transition-all ${e.status === 'scanning' ? 'animate-pulse' : ''}`}>
                <div className={`w-12 h-12 rounded-full flex items-center justify-center ${e.status === 'done' && e.mentioned ? 'bg-green-500/20' : e.status === 'done' ? 'bg-red-500/10' : 'bg-white/[0.04]'}`}>
                  <span className={e.color}>{e.icon}</span>
                </div>
                <span className="text-sm font-semibold text-white">{e.engine}</span>
                {e.status === 'idle' && <span className="text-xs text-gray-600">En attente</span>}
                {e.status === 'scanning' && <Loader2 size={14} className="text-amber-400 animate-spin" />}
                {e.status === 'done' && (
                  <>
                    <span className={`flex items-center gap-1 text-xs font-bold ${e.mentioned ? 'text-green-400' : 'text-gray-500'}`}>
                      {e.mentioned ? <><CheckCircle size={12} /> Cit\u00e9</> : <><XCircle size={12} /> Non cit\u00e9</>}
                    </span>
                    <span className="text-xs text-gray-500">{e.confidence}% confiance</span>
                  </>
                )}
              </div>
            ))}
          </div>

          {scanComplete && (
            <div className="ninja-card p-6">
              <h3 className="text-lg font-bold text-white mb-4">D\u00e9tails du scan</h3>
              <div className="space-y-3">
                {engines.filter(e => e.status === 'done').map(e => (
                  <div key={e.engine} className="p-4 bg-white/[0.02] border border-white/[0.06] rounded-xl flex items-start gap-3">
                    <span className={e.color}>{e.icon}</span>
                    <div className="flex-1">
                      <div className="text-sm font-semibold text-white">{e.engine}</div>
                      <p className="text-xs text-gray-500 mt-1">{e.excerpt}</p>
                    </div>
                    <div className={`px-2 py-0.5 rounded-full text-[10px] font-bold ${e.mentioned ? 'bg-green-500/20 text-green-400' : 'bg-white/[0.04] text-gray-500'}`}>
                      {e.confidence}%
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {activeTab === 'schedule' && (
        <div>
          <div className="ninja-card p-6 mb-6">
            <div className="flex justify-between items-center mb-4">
              <h3 className="text-lg font-bold text-white">Scans Planifi\u00e9s</h3>
              <button className="text-sm text-amber-400 hover:text-amber-300 font-medium flex items-center gap-1"><Plus size={14} /> Ajouter</button>
            </div>
            <div className="overflow-x-auto">
              <table className="w-full text-left text-sm">
                <thead><tr className="text-gray-500 border-b border-white/[0.06]"><th className="pb-3 font-medium">URL</th><th className="pb-3 font-medium">Fr\u00e9quence</th><th className="pb-3 font-medium">Dernier</th><th className="pb-3 font-medium">Prochain</th><th className="pb-3 font-medium">Actif</th></tr></thead>
                <tbody>
                  {schedules.map(s => (
                    <tr key={s.id} className="border-b border-white/[0.06] last:border-0">
                      <td className="py-3 text-gray-300">{s.url}</td>
                      <td className="py-3"><span className="px-2 py-0.5 rounded-full text-[10px] bg-amber-500/10 text-amber-400 border border-amber-500/20">{s.frequency}</span></td>
                      <td className="py-3 text-gray-500">{s.lastRun}</td>
                      <td className="py-3 text-gray-500">{s.nextRun}</td>
                      <td className="py-3">
                        <button onClick={() => toggleSchedule(s.id)} className={`w-10 h-5 rounded-full relative transition-colors ${s.enabled ? 'bg-amber-500' : 'bg-white/[0.1]'}`}>
                          <div className={`absolute top-0.5 w-4 h-4 rounded-full bg-white transition-all ${s.enabled ? 'left-5' : 'left-0.5'}`} />
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          <div className="ninja-card p-6 text-center">
            <Clock size={32} className="text-amber-400 mx-auto mb-3" />
            <h4 className="text-white font-bold mb-2">Automatisez vos scans</h4>
            <p className="text-gray-500 text-sm mb-4">Configurez des scans r\u00e9currents pour suivre l'\u00e9volution de votre visibilit\u00e9 IA.</p>
          </div>
        </div>
      )}
    </div>
  );
};

export default AiMonitoring;
