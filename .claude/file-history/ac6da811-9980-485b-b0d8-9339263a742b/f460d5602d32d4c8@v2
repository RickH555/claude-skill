import React, { useState, useEffect } from 'react';
import { Search, ShieldCheck, TrendingUp, Sparkles, Globe, FileSearch, BarChart3 } from 'lucide-react';

interface AnalyzeProps {
  onAnalyze: (url: string) => void;
  isAnalyzing: boolean;
}

const analysisStages = [
  { icon: Globe, label: 'Crawling du site...', desc: 'Exploration des pages et du contenu' },
  { icon: FileSearch, label: 'Analyse sémantique...', desc: 'Évaluation des critères AEO & GEO' },
  { icon: BarChart3, label: 'Calcul du score...', desc: 'Génération du rapport et recommandations' },
];

const Analyze: React.FC<AnalyzeProps> = ({ onAnalyze, isAnalyzing }) => {
  const [inputUrl, setInputUrl] = useState('');
  const [stage, setStage] = useState(0);

  useEffect(() => {
    if (!isAnalyzing) { setStage(0); return; }
    const t1 = setTimeout(() => setStage(1), 2000);
    const t2 = setTimeout(() => setStage(2), 5000);
    return () => { clearTimeout(t1); clearTimeout(t2); };
  }, [isAnalyzing]);

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (inputUrl && !isAnalyzing) {
      onAnalyze(inputUrl);
    }
  };

  return (
    <div className="w-full px-4 min-h-[80vh] flex flex-col items-center justify-center animate-in fade-in duration-500">

      <div className="text-center mb-10 space-y-4">
        <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.04] border border-white/[0.08] text-purple-400 text-sm font-medium">
          <Sparkles size={14} />
          <span>Audit AEO & GEO Instantané</span>
        </div>
        <h1 className="text-4xl md:text-5xl font-sans font-bold text-white">
          Analysez votre <span className="gradient-text">visibilité IA</span>
        </h1>
        <p className="text-xl text-gray-500 max-w-2xl mx-auto">
          Découvrez comment les moteurs de réponse perçoivent votre contenu et obtenez un plan d'action pour être cité.
        </p>
      </div>

      <div className="w-full max-w-3xl relative z-10">
        <div className="absolute inset-0 bg-primary/20 blur-3xl rounded-full opacity-20 -z-10"></div>
        <form onSubmit={handleSubmit}>
          <div className="ninja-card p-8">
            <div className="flex items-center gap-3">
              <Search className="text-gray-500 shrink-0" size={24} />
              <input
                type="url"
                required
                placeholder="https://votre-site.com"
                className="w-full bg-[#111111] border border-white/[0.08] rounded-xl focus:ring-1 focus:ring-purple-500/30 focus:border-purple-500/30 text-white placeholder-gray-500 text-lg px-4 py-4"
                value={inputUrl}
                onChange={(e) => setInputUrl(e.target.value)}
                autoFocus
                disabled={isAnalyzing}
              />
              <button
                type="submit"
                disabled={isAnalyzing}
                className={`btn-gradient px-8 py-4 shrink-0 transition-all transform hover:scale-105 ${isAnalyzing ? '!bg-gray-600 cursor-not-allowed opacity-60' : ''}`}
              >
                {isAnalyzing ? 'Analyse...' : 'Lancer l\'audit'}
              </button>
            </div>
          </div>
        </form>

        {/* Multi-stage progress indicator */}
        {isAnalyzing && (
          <div className="mt-6 ninja-card p-6 space-y-4 animate-in fade-in duration-300">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm font-semibold text-white">Analyse en cours</span>
              <span className="text-xs text-gray-500">Étape {stage + 1}/3</span>
            </div>
            <div className="w-full h-1.5 bg-white/[0.06] rounded-full overflow-hidden">
              <div
                className="h-full rounded-full bg-gradient-to-r from-purple-500 to-violet-500 transition-all duration-1000 ease-out"
                style={{ width: `${((stage + 1) / 3) * 100}%` }}
              />
            </div>
            <div className="space-y-3 mt-3">
              {analysisStages.map((s, i) => {
                const Icon = s.icon;
                const isDone = i < stage;
                const isCurrent = i === stage;
                return (
                  <div key={i} className={`flex items-center gap-3 transition-all duration-300 ${isCurrent ? 'opacity-100' : isDone ? 'opacity-50' : 'opacity-25'}`}>
                    <div className={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ${isCurrent ? 'bg-purple-500/20' : isDone ? 'bg-emerald-500/15' : 'bg-white/[0.04]'}`}>
                      {isDone ? (
                        <svg className="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2.5} d="M5 13l4 4L19 7" /></svg>
                      ) : (
                        <Icon size={16} className={isCurrent ? 'text-purple-400 animate-pulse' : 'text-gray-600'} />
                      )}
                    </div>
                    <div>
                      <p className={`text-sm font-medium ${isCurrent ? 'text-white' : isDone ? 'text-gray-400' : 'text-gray-600'}`}>{s.label}</p>
                      <p className="text-xs text-gray-600">{s.desc}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {!isAnalyzing && (
          <div className="flex justify-center gap-8 mt-8 text-sm text-gray-500">
            <span className="flex items-center gap-2"><ShieldCheck size={16} className="text-purple-400"/> Analyse Sécurisée</span>
            <span className="flex items-center gap-2"><TrendingUp size={16} className="text-purple-400"/> +50 Critères GEO</span>
          </div>
        )}
      </div>

    </div>
  );
};

export default Analyze;