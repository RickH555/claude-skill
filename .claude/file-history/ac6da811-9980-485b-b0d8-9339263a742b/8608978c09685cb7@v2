                    <option value="trustpilot">Trustpilot</option>
                    <option value="facebook">Facebook</option>
                  </select>
                </div>
                <InputField label="Note" value={trustReviewRating} onChange={setTrustReviewRating} placeholder="4.5" />
                <InputField label="Nb avis" value={trustReviewCount} onChange={setTrustReviewCount} placeholder="150" />
              </div>
            </div>
            <button onClick={handleGenerateTrust} disabled={isLoading || !trustOrgName}
              className={`w-full py-3 rounded-xl font-semibold text-sm flex items-center justify-center gap-2 transition-all ${
                isLoading || !trustOrgName ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'btn-gradient text-white'
              }`}>
              {isLoading ? <Loader2 size={16} className="animate-spin" /> : <Zap size={16} />}
              {isLoading ? 'Generation...' : `Generer les Blocs (${EEAT_CREDITS.trustSignals} Gas)`}
            </button>
          </div>
          <div className="space-y-4">
            {trustResult ? (
              <>
                <CodeBlock code={trustResult.html} title="Blocs HTML Trust Signals" />
                <CodeBlock code={trustResult.schemaOrg} title="Schema.org (JSON-LD)" />
              </>
            ) : (
              <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
                <Shield size={48} className="text-amber-400/30 mb-4" />
                <h3 className="text-lg font-bold text-gray-400 mb-2">Trust Signals</h3>
                <p className="text-sm text-gray-600 max-w-sm">Generez des blocs de confiance : certifications, presse, avis, garanties</p>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ═══ TAB: Credentials ═══ */}
      {activeTab === 'credentials' && (
        <div className="grid md:grid-cols-2 gap-6">
          <div className="space-y-4">
            <div className="ninja-card p-6 space-y-4">
              <h3 className="text-sm font-bold text-gray-300 uppercase tracking-wider">Expert</h3>
              <div className="grid grid-cols-2 gap-4">
                <InputField label="Nom" value={credName} onChange={setCredName} placeholder="Dr. Marie Laurent" required />
                <InputField label="Titre" value={credTitle} onChange={setCredTitle} placeholder="Directrice R&D" required />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <InputField label="Organisation" value={credOrg} onChange={setCredOrg} placeholder="MonEntreprise" />
                <InputField label="Annees d'exp." value={credYears} onChange={setCredYears} placeholder="15" type="number" />
              </div>
              <InputField label="Specialisations (virgules)" value={credSpecs} onChange={setCredSpecs} placeholder="IA, Machine Learning, NLP" />
            </div>

            <div className="ninja-card p-6 space-y-3">
              <div className="flex items-center justify-between">
                <h3 className="text-sm font-bold text-gray-300 uppercase tracking-wider">Formation</h3>
                <button onClick={() => setCredEducation([...credEducation, { degree: '', field: '', institution: '', year: 2020 }])}
                  className="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1"><Plus size={12} /> Ajouter</button>
              </div>
              {credEducation.map((edu, i) => (
                <div key={i} className="flex gap-2 items-start">
                  <div className="flex-1 grid grid-cols-4 gap-2">
                    <input value={edu.degree} onChange={e => { const n = [...credEducation]; n[i] = { ...n[i], degree: e.target.value }; setCredEducation(n); }}
                      placeholder="Doctorat" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={edu.field} onChange={e => { const n = [...credEducation]; n[i] = { ...n[i], field: e.target.value }; setCredEducation(n); }}
                      placeholder="IA" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={edu.institution} onChange={e => { const n = [...credEducation]; n[i] = { ...n[i], institution: e.target.value }; setCredEducation(n); }}
                      placeholder="Polytechnique" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={edu.year} onChange={e => { const n = [...credEducation]; n[i] = { ...n[i], year: parseInt(e.target.value) || 2020 }; setCredEducation(n); }}
                      type="number" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                  </div>
                  <button onClick={() => setCredEducation(credEducation.filter((_, j) => j !== i))} className="p-1 text-gray-600 hover:text-red-400"><X size={14} /></button>
                </div>
              ))}
            </div>

            <div className="ninja-card p-6 space-y-3">
              <div className="flex items-center justify-between">
                <h3 className="text-sm font-bold text-gray-300 uppercase tracking-wider">Certifications</h3>
                <button onClick={() => setCredCredentials([...credCredentials, { type: 'certification', name: '', issuer: '' }])}
                  className="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1"><Plus size={12} /> Ajouter</button>
              </div>
              {credCredentials.map((c, i) => (
                <div key={i} className="flex gap-2 items-start">
                  <div className="flex-1 grid grid-cols-2 gap-2">
                    <input value={c.name} onChange={e => { const n = [...credCredentials]; n[i] = { ...n[i], name: e.target.value }; setCredCredentials(n); }}
                      placeholder="Certification" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={c.issuer} onChange={e => { const n = [...credCredentials]; n[i] = { ...n[i], issuer: e.target.value }; setCredCredentials(n); }}
                      placeholder="Emetteur" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                  </div>
                  <button onClick={() => setCredCredentials(credCredentials.filter((_, j) => j !== i))} className="p-1 text-gray-600 hover:text-red-400"><X size={14} /></button>
                </div>
              ))}
            </div>

            <div className="ninja-card p-6 space-y-3">
              <div className="flex items-center justify-between">
                <h3 className="text-sm font-bold text-gray-300 uppercase tracking-wider">Recompenses</h3>
                <button onClick={() => setCredAwards([...credAwards, { name: '', issuer: '', year: 2024 }])}
                  className="text-xs text-purple-400 hover:text-purple-300 flex items-center gap-1"><Plus size={12} /> Ajouter</button>
              </div>
              {credAwards.map((a, i) => (
                <div key={i} className="flex gap-2 items-start">
                  <div className="flex-1 grid grid-cols-3 gap-2">
                    <input value={a.name} onChange={e => { const n = [...credAwards]; n[i] = { ...n[i], name: e.target.value }; setCredAwards(n); }}
                      placeholder="Prix" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={a.issuer} onChange={e => { const n = [...credAwards]; n[i] = { ...n[i], issuer: e.target.value }; setCredAwards(n); }}
                      placeholder="Emetteur" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                    <input value={a.year} onChange={e => { const n = [...credAwards]; n[i] = { ...n[i], year: parseInt(e.target.value) || 2024 }; setCredAwards(n); }}
                      type="number" className="bg-[#0a0a0a] border border-white/5 rounded-lg px-3 py-2 text-xs text-gray-300" />
                  </div>
                  <button onClick={() => setCredAwards(credAwards.filter((_, j) => j !== i))} className="p-1 text-gray-600 hover:text-red-400"><X size={14} /></button>
                </div>
              ))}
            </div>

            <button onClick={handleGenerateCredentials} disabled={isLoading || !credName || !credTitle}
              className={`w-full py-3 rounded-xl font-semibold text-sm flex items-center justify-center gap-2 transition-all ${
                isLoading || !credName || !credTitle ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'btn-gradient text-white'
              }`}>
              {isLoading ? <Loader2 size={16} className="animate-spin" /> : <Zap size={16} />}
              {isLoading ? 'Generation...' : `Generer (${EEAT_CREDITS.credentials} Gas)`}
            </button>
          </div>
          <div className="space-y-4">
            {credResult ? (
              <>
                <CodeBlock code={credResult.html} title="Bloc HTML Credentials" />
                <CodeBlock code={credResult.schemaOrg} title="Schema.org Person (JSON-LD)" />
              </>
            ) : (
              <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
                <AwardIcon size={48} className="text-purple-400/30 mb-4" />
                <h3 className="text-lg font-bold text-gray-400 mb-2">Expert Credentials</h3>
                <p className="text-sm text-gray-600 max-w-sm">Structurez les diplomes, certifications et recompenses avec Schema.org</p>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ═══ TAB: Citation Block ═══ */}
      {activeTab === 'citation-block' && (
        <div className="grid md:grid-cols-2 gap-6">
          <div className="space-y-4">
            <div className="ninja-card p-6 space-y-4">
              <h3 className="text-sm font-bold text-gray-300 uppercase tracking-wider">Auteur</h3>
              <div className="grid grid-cols-2 gap-4">
                <InputField label="Nom" value={citeName} onChange={setCiteName} placeholder="Jean Dupont" required />
                <InputField label="Titre" value={citeTitle} onChange={setCiteTitle} placeholder="Expert AEO" required />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <InputField label="Organisation" value={citeOrg} onChange={setCiteOrg} placeholder="CitedBy.ai" />
                <InputField label="Annees d'exp." value={citeYears} onChange={setCiteYears} placeholder="10" type="number" />
              </div>
              <InputField label="Specialisations (virgules)" value={citeSpecs} onChange={setCiteSpecs} placeholder="AEO, SEO, Content Strategy" />
              <div className="grid grid-cols-2 gap-4">
                <InputField label="LinkedIn URL" value={citeLinkedin} onChange={setCiteLinkedin} placeholder="https://linkedin.com/in/..." />
                <InputField label="Photo URL" value={citePhotoUrl} onChange={setCitePhotoUrl} placeholder="https://..." />
              </div>
              <InputField label="Titre de l'article (optionnel)" value={citeArticleTitle} onChange={setCiteArticleTitle} placeholder="Guide complet du E-E-A-T en 2026" />
            </div>
            <button onClick={handleGenerateCitation} disabled={isLoading || !citeName || !citeTitle}
              className={`w-full py-3 rounded-xl font-semibold text-sm flex items-center justify-center gap-2 transition-all ${
                isLoading || !citeName || !citeTitle ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'btn-gradient text-white'
              }`}>
              {isLoading ? <Loader2 size={16} className="animate-spin" /> : <Zap size={16} />}
              {isLoading ? 'Generation...' : `Generer le Bloc (${EEAT_CREDITS.citationBlock} Gas)`}
            </button>
          </div>
          <div className="space-y-4">
            {citeResult ? (
              <>
                <CodeBlock code={citeResult.html} title="Bloc Citation Auteur (HTML)" />
                <CodeBlock code={citeResult.schemaOrg} title="Schema.org Person (JSON-LD)" />
              </>
            ) : (
              <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
                <FileText size={48} className="text-cyan-400/30 mb-4" />
                <h3 className="text-lg font-bold text-gray-400 mb-2">Bloc Citation</h3>
                <p className="text-sm text-gray-600 max-w-sm">Generez un encart auteur pour vos articles de blog</p>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ═══ TAB: E-E-A-T Audit ═══ */}
      {activeTab === 'eeat-audit' && (
        <div className="space-y-6">
          <div className="ninja-card p-6">
            <div className="flex flex-col md:flex-row gap-4">
              <div className="flex-1">
                <label className="block text-sm font-medium text-gray-300 mb-1.5">URL a auditer <span className="text-red-400">*</span></label>
                <div className="relative">
                  <Search size={16} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500" />
                  <input value={auditUrl} onChange={e => setAuditUrl(e.target.value)} placeholder="https://example.com/page"
                    className="w-full bg-[#111111] border border-white/[0.08] rounded-xl pl-11 pr-4 py-3 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50"
                    onKeyDown={e => e.key === 'Enter' && handleAudit()} />
                </div>
              </div>
              <div className="md:w-48">
                <label className="block text-sm font-medium text-gray-300 mb-1.5">Marque (optionnel)</label>
                <input value={auditBrand} onChange={e => setAuditBrand(e.target.value)} placeholder="Ma Marque"
                  className="w-full bg-[#111111] border border-white/[0.08] rounded-xl px-4 py-3 text-sm text-gray-200 focus:outline-none focus:border-purple-500/50" />
              </div>
              <div className="md:self-end">
                <button onClick={handleAudit} disabled={isLoading || !auditUrl}
                  className={`w-full md:w-auto px-6 py-3 rounded-xl font-semibold text-sm flex items-center justify-center gap-2 transition-all ${
                    isLoading || !auditUrl ? 'bg-gray-700/50 text-gray-500 cursor-not-allowed' : 'btn-gradient text-white'
                  }`}>
                  {isLoading ? <Loader2 size={16} className="animate-spin" /> : <BarChart3 size={16} />}
                  {isLoading ? 'Audit...' : `Auditer (${EEAT_CREDITS.audit} Gas)`}
                </button>
              </div>
            </div>
          </div>

          {auditResult && (
            <div className="space-y-6 animate-in fade-in duration-500">
              {/* Scores */}
              <div className="grid md:grid-cols-5 gap-4">
                <div className="ninja-card p-6 flex flex-col items-center justify-center md:row-span-1">
                  <ScoreRing score={auditResult.scores.overall} size={110} />
                  <p className="text-sm font-semibold text-gray-300 mt-3">Score Global</p>
                </div>
                <div className="md:col-span-4 ninja-card p-6 space-y-4">
                  <h3 className="text-sm font-bold text-gray-400 uppercase tracking-wider">Scores par Pilier</h3>
                  <ScoreBar label="Experience" score={auditResult.scores.experience} color="#22c55e" />
                  <ScoreBar label="Expertise" score={auditResult.scores.expertise} color="#3b82f6" />
                  <ScoreBar label="Authoritativeness" score={auditResult.scores.authoritativeness} color="#f59e0b" />
                  <ScoreBar label="Trustworthiness" score={auditResult.scores.trustworthiness} color="#a855f7" />
                </div>
              </div>

              {/* Summary */}
              <div className="ninja-card p-6">
                <h3 className="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3">Resume</h3>
                <p className="text-sm text-gray-300 leading-relaxed">{auditResult.summary}</p>
              </div>

              {/* Findings */}
              <div className="ninja-card p-6">
                <h3 className="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Elements Analyses</h3>
                <div className="space-y-2">
                  {auditResult.findings.map((f, i) => {
                    const StatusIcon = f.status === 'present' ? CheckCircle : f.status === 'incomplete' ? AlertTriangle : XCircle;
                    const statusColor = f.status === 'present' ? 'text-emerald-400' : f.status === 'incomplete' ? 'text-amber-400' : 'text-red-400';
                    const catColors: Record<string, string> = { experience: 'bg-emerald-500/10 text-emerald-400', expertise: 'bg-blue-500/10 text-blue-400', authority: 'bg-amber-500/10 text-amber-400', trust: 'bg-purple-500/10 text-purple-400' };
                    return (
                      <div key={i} className="flex items-start gap-3 p-3 bg-white/[0.02] rounded-lg border border-white/[0.04]">
                        <StatusIcon size={16} className={`${statusColor} mt-0.5 shrink-0`} />
                        <div className="flex-1 min-w-0">
                          <div className="flex items-center gap-2 flex-wrap">
                            <span className="text-sm text-gray-200">{f.element}</span>
                            <span className={`text-[10px] px-2 py-0.5 rounded-full font-medium ${catColors[f.category] || ''}`}>{f.category}</span>
                            <span className={`text-[10px] px-2 py-0.5 rounded-full ${f.impact === 'high' ? 'bg-red-500/10 text-red-400' : f.impact === 'medium' ? 'bg-amber-500/10 text-amber-400' : 'bg-gray-500/10 text-gray-400'}`}>{f.impact}</span>
                          </div>
                          {f.recommendation && f.status !== 'present' && (
                            <p className="text-xs text-gray-500 mt-1">{f.recommendation}</p>
                          )}
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>

              {/* Priority Actions */}
              <div className="ninja-card p-6">
                <h3 className="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Actions Prioritaires</h3>
                <div className="space-y-3">
                  {auditResult.priorityActions.map((a, i) => (
                    <div key={i} className="flex items-start gap-3 p-3 bg-purple-500/[0.03] rounded-lg border border-purple-500/10">
                      <span className="text-purple-400 font-bold text-sm shrink-0">{i + 1}.</span>
                      <div className="flex-1">
                        <p className="text-sm text-gray-200">{a.action}</p>
                        <div className="flex items-center gap-3 mt-1.5">
                          <span className="text-[10px] text-gray-500">Impact: <span className="text-purple-400 font-bold">{a.impact}%</span></span>
                          <span className={`text-[10px] px-2 py-0.5 rounded-full ${a.effort === 'low' ? 'bg-emerald-500/10 text-emerald-400' : a.effort === 'medium' ? 'bg-amber-500/10 text-amber-400' : 'bg-red-500/10 text-red-400'}`}>Effort: {a.effort}</span>
                          <span className="text-[10px] text-gray-600">Outil: {a.tool}</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {!auditResult && !isLoading && (
            <div className="ninja-card p-12 flex flex-col items-center justify-center text-center">
              <BarChart3 size={48} className="text-rose-400/30 mb-4" />
              <h3 className="text-lg font-bold text-gray-400 mb-2">Audit E-E-A-T</h3>
              <p className="text-sm text-gray-600 max-w-md">Analysez une URL pour evaluer ses signaux Experience, Expertise, Authoritativeness et Trustworthiness</p>
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 w-full max-w-lg">
                {['Experience', 'Expertise', 'Authoritativeness', 'Trustworthiness'].map((pillar, i) => (
                  <div key={pillar} className="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-white/[0.02] border border-white/[0.04]">
                    <span className={`text-sm font-bold ${['text-emerald-400', 'text-blue-400', 'text-amber-400', 'text-purple-400'][i]}`}>{pillar.charAt(0)}</span>
                    <span className="text-[10px] text-gray-500 text-center">{pillar}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
};

export default EeatBuilder;
