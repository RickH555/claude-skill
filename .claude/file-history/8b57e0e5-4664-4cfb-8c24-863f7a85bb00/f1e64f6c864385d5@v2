'use client';
import dynamicImport from 'next/dynamic';
import { useAppContext } from '@/lib/app-context';

const CalibrationPage = dynamicImport(
  () => import('@/views/v3/CalibrationPage'),
  { ssr: false }
);

export default function CalibrationPageWrapper() {
  const { goBack, user } = useAppContext();
  return <CalibrationPage onBack={goBack} user={user} />;
}
