import type { AdConnection, AdPlatform, BudgetEstimate, RetargetingOpportunity } from '../types/retargeting.ts'

const AD_CONNECTIONS_KEY = 'citedby_ad_connections'

// ---- Ad Connections ----

function defaultConnections(): AdConnection[] {
  return [
    { platform: 'google_ads', status: 'disconnected', accountName: null, connectedAt: null },
    { platform: 'meta_ads', status: 'disconnected', accountName: null, connectedAt: null },
    { platform: 'linkedin_ads', status: 'disconnected', accountName: null, connectedAt: null },
  ]
}

export function getAdConnections(): AdConnection[] {
  const raw = localStorage.getItem(AD_CONNECTIONS_KEY)
  return raw ? JSON.parse(raw) : defaultConnections()
}

function saveAdConnections(connections: AdConnection[]): void {
  localStorage.setItem(AD_CONNECTIONS_KEY, JSON.stringify(connections))
}

export function connectAdPlatform(platform: AdPlatform): Promise<AdConnection> {
  return new Promise((resolve) => {
    const connections = getAdConnections()
    const conn = connections.find((c) => c.platform === platform)!
    setTimeout(() => {
      conn.status = 'connected'
      conn.accountName = getPlatformLabel(platform) + ' - citedby.ai'
      conn.connectedAt = new Date().toISOString()
      saveAdConnections(connections)
      resolve(conn)
    }, 1500)
  })
}

export function disconnectAdPlatform(platform: AdPlatform): void {
  const connections = getAdConnections()
  const conn = connections.find((c) => c.platform === platform)!
  conn.status = 'disconnected'
  conn.accountName = null
  conn.connectedAt = null
  saveAdConnections(connections)
}

// ---- Retargeting Opportunities ----

export function generateOpportunities(citedUrls: string[]): RetargetingOpportunity[] {
  const engines = ['ChatGPT', 'Perplexity', 'Claude', 'Gemini', 'Copilot']
  return citedUrls.map((url, i) => ({
    id: `rt_${i}_${Date.now()}`,
    url,
    engine: engines[i % engines.length],
    estimatedAudience: Math.floor(1000 + Math.random() * 9000),
    pixelCode: generatePixelCode(url, engines[i % engines.length]),
  }))
}

function generatePixelCode(url: string, engine: string): string {
  const pixelId = Math.random().toString(36).slice(2, 10).toUpperCase()
  return `<!-- CitedBy.ai Retargeting Pixel -->
<script>
  !function(c,b,a){c.CitedByPixel=a;c[a]=c[a]||function(){
  (c[a].q=c[a].q||[]).push(arguments)};var s=b.createElement('script');
  s.async=1;s.src='https://pixel.citedby.ai/p.js';
  b.head.appendChild(s)}(window,document,'cbp');
  cbp('init','${pixelId}');
  cbp('track','AIReferral',{url:'${url}',engine:'${engine}'});
</script>`
}

// ---- Budget Estimator ----

export function estimateBudget(platform: AdPlatform, dailyBudget: number): BudgetEstimate {
  const multipliers: Record<AdPlatform, { cpc: number; cpm: number; ctr: number }> = {
    google_ads: { cpc: 0.85, cpm: 6.5, ctr: 3.2 },
    meta_ads: { cpc: 0.52, cpm: 4.2, ctr: 2.8 },
    linkedin_ads: { cpc: 2.1, cpm: 12.5, ctr: 1.5 },
  }

  const m = multipliers[platform]
  const estimatedClicks = Math.round(dailyBudget / m.cpc)
  const estimatedReach = Math.round((dailyBudget / m.cpm) * 1000)

  return {
    platform,
    dailyBudget,
    estimatedReach,
    estimatedClicks,
    estimatedCPC: m.cpc,
    estimatedCPM: m.cpm,
  }
}

// ---- Export CSV ----

export function exportAudienceCSV(opportunities: RetargetingOpportunity[]): void {
  const headers = ['URL', 'Moteur IA', 'Audience Estimee', 'Pixel ID']
  const rows = opportunities.map((o) => [
    o.url,
    o.engine,
    o.estimatedAudience.toString(),
    o.id,
  ])

  const csv = [headers, ...rows].map((row) => row.join(',')).join('\n')
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' })
  const link = document.createElement('a')
  link.href = URL.createObjectURL(blob)
  link.download = `citedby_retargeting_audience_${new Date().toISOString().slice(0, 10)}.csv`
  link.click()
  URL.revokeObjectURL(link.href)
}

// ---- Labels ----

export function getPlatformLabel(platform: AdPlatform): string {
  const labels: Record<AdPlatform, string> = {
    google_ads: 'Google Ads',
    meta_ads: 'Meta Ads',
    linkedin_ads: 'LinkedIn Ads',
  }
  return labels[platform]
}

export function getPlatformColor(platform: AdPlatform): string {
  const colors: Record<AdPlatform, string> = {
    google_ads: 'bg-blue-100 text-blue-700',
    meta_ads: 'bg-indigo-100 text-indigo-700',
    linkedin_ads: 'bg-sky-100 text-sky-700',
  }
  return colors[platform]
}
