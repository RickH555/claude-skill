              <TextArea label="Mentions presse (1 par ligne, format: Media | Citation)" value={trustPress} onChange={setTrustPress} placeholder="Les Echos | Leader du marche AEO&#10;Forbes | Top 10 startups" />
              <TextArea label="Garanties (1 par ligne)" value={trustGuarantees} onChange={setTrustGuarantees} placeholder="Satisfait ou rembourse 30 jours&#10;Support 24/7" />
              <TextArea label="Preuves sociales (1 par ligne)" value={trustProof} onChange={setTrustProof} placeholder="10,000+ clients&#10;99.9% uptime" />
