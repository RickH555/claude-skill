Donnees brutes:
${raw}

Contexte marche:
${context}

Reponds UNIQUEMENT en JSON.`;
};

const callGemini = async (model: string, prompt: string, apiKey: string): Promise<GeminiAnalysis> => {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 30_000);
  const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`, {
    method: 'POST',
    signal: controller.signal,
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      contents: [{ parts: [{ text: prompt }] }],
      generationConfig: {
        responseMimeType: 'application/json',
        temperature: 0.3,
      },
    }),
  });
  clearTimeout(timeoutId);
  if (!response.ok) {
    throw new Error(`Gemini error: ${response.status}`);
  }
  const payload = (await response.json()) as {
    candidates?: Array<{ content?: { parts?: Array<{ text?: string }> } }>;
  };
  const text = payload.candidates?.[0]?.content?.parts?.[0]?.text ?? '';
  if (!text) {
    throw new Error('Gemini reponse vide');
  }
  return parseGeminiText(text);
};

/**
 * Analyse IA d'un item brut, puis insertion prospect.
 */
Deno.serve(async (request: Request) => {
  if (request.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders });
  }

  const ip = request.headers.get('x-forwarded-for') ?? 'anonymous';
  try {
    enforceRateLimit(`analyze:${ip}`, 100);
    if (request.method !== 'POST') {
      return jsonResponse({ error: 'Method not allowed' }, 405);
    }

    // Auth: service role (appel interne depuis ingest) ou JWT utilisateur
    const auth = await authenticateRequest(request);
    if (auth.error) return auth.error;

    const payload = await parseJsonBody<AnalyzePayload>(request);
    if (!payload.sector || !payload.source || !payload.raw_data) {
      return jsonResponse({ error: 'Payload invalide' }, 400);
    }

    const geminiApiKey = Deno.env.get('GEMINI_API_KEY');
    const supabaseUrl = Deno.env.get('SUPABASE_URL');
    const serviceRoleKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY');
    if (!geminiApiKey || !supabaseUrl || !serviceRoleKey) {
      throw new Error('Variables GEMINI_API_KEY / SUPABASE manquantes');
    }

    const marketContext = {
      timestamp: new Date().toISOString(),
      source: payload.source,
      sector: payload.sector,
    };

    const prompt = buildPrompt(payload.sector, payload.raw_data, marketContext, payload.approach_tone ?? 'professional');
    let analysis = await callGemini('gemini-1.5-flash', prompt, geminiApiKey);
    analysis.score = Math.max(0, Math.min(100, Number(analysis.score ?? 0)));
    analysis.heat = normalizeHeat(analysis.score);

    if (!payload.message_only && analysis.score >= 90) {
      const refined = await callGemini('gemini-1.5-pro', prompt, geminiApiKey);
      refined.score = Math.max(0, Math.min(100, Number(refined.score ?? analysis.score)));
      refined.heat = normalizeHeat(refined.score);
      analysis = refined;
    }

    if (payload.message_only) {
      return jsonResponse({
        approach_message: analysis.approach_message,
        heat: analysis.heat,
        score: analysis.score,
      });
    }

    const admin = createAdminClient();
    const dedupHash =
      payload.dedup_hash ??
      (await sha256Hex(
        [
          String(payload.raw_data.name ?? payload.raw_data.title ?? ''),
          String(payload.raw_data.location ?? payload.raw_data.city ?? ''),
          String(payload.raw_data.date ?? payload.raw_data.created_at ?? ''),
          payload.source,
          payload.sector,
        ]
          .map((value) => value.trim().toLowerCase())
          .join('|'),
      ));

    const signal = String(analysis.signal ?? '').slice(0, 100);
    const sourceUrl = String(payload.raw_data.source_url ?? payload.raw_data.url ?? '');
    const location = String(payload.raw_data.location ?? payload.raw_data.city ?? '');

    const { data: inserted, error: insertError } = await admin
      .from('prospects')
      .insert({
        sector_id: payload.sector,
        source_id: payload.source_id ?? null,
        score: analysis.score,
        heat: analysis.heat,
        signal,
        signal_type: String(payload.raw_data.signal_type ?? ''),
        name: String(payload.raw_data.name ?? payload.raw_data.title ?? 'Prospect detecte'),
        location: location || null,
        location_lat: typeof payload.raw_data.location_lat === 'number' ? payload.raw_data.location_lat : null,
        location_lng: typeof payload.raw_data.location_lng === 'number' ? payload.raw_data.location_lng : null,
        contact_phone: payload.raw_data.contact_phone ? String(payload.raw_data.contact_phone) : null,
        contact_email: payload.raw_data.contact_email ? String(payload.raw_data.contact_email) : null,
        contact_method: payload.raw_data.contact_method ? String(payload.raw_data.contact_method) : null,
        details_json: payload.raw_data.details && typeof payload.raw_data.details === 'object' ? payload.raw_data.details : payload.raw_data,
        market_analysis_json: analysis.market_analysis ?? {},
        approach_message: analysis.approach_message,
        approach_why: analysis.approach_why,
        score_breakdown_json: analysis.score_breakdown ?? {},
        raw_data_json: payload.raw_data,
        source_url: sourceUrl || null,
        dedup_hash: dedupHash,
      })
      .select('id, heat, score')
      .single<{ id: string; heat: Heat; score: number }>();

    if (insertError) {
      throw insertError;
    }

    await logAutomationEvent('prospect_scored', {
      prospect_id: inserted.id,
      sector: payload.sector,
      score: inserted.score,
      heat: inserted.heat,
    }, payload.source_id ?? null);

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 30_000);
    const distributeResponse = await fetch(`${supabaseUrl}/functions/v1/distribute`, {
      method: 'POST',
      signal: controller.signal,
      headers: {
        Authorization: `Bearer ${serviceRoleKey}`,
        apikey: serviceRoleKey,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        prospect_id: inserted.id,
      }),
    });
    clearTimeout(timeoutId);

    if (!distributeResponse.ok) {
      const details = await distributeResponse.text();
      await logAutomationEvent('error', {
        stage: 'analyze->distribute',
        prospect_id: inserted.id,
        reason: details,
      }, payload.source_id ?? null);
    }

    return jsonResponse({
      prospect_id: inserted.id,
      score: inserted.score,
      heat: inserted.heat,
    });
  } catch (error) {
    await logAutomationEvent('error', {
      stage: 'analyze',
      reason: error instanceof Error ? error.message : 'unknown',
    });
    return jsonResponse({ error: error instanceof Error ? error.message : 'Erreur analyze' }, 500);
  }
});
