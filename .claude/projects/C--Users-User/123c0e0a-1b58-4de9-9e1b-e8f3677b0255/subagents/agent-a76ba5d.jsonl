ing(provider)\n    connectProvider(provider).then(() => {\n      setState(getIntegrationState())\n      setConnecting(null)\n    })\n  }\n\n  function handleDisconnect(provider: IntegrationProvider) {\n    disconnectProvider(provider)\n    setState(getIntegrationState())\n  }\n\n  function handlePeriodChange(period: IntegrationPeriod) {\n    setPeriod(period)\n    setState(getIntegrationState())\n  }\n\n  const periods: { value: IntegrationPeriod; label: string }[] = [\n    { value: '7d', label: '7 jours' },\n    { value: '30d', label: '30 jours' },\n    { value: '90d', label: '90 jours' },\n  ]\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex items-center justify-between\">\n        <h2 className=\"text-2xl font-bold text-gray-900\">Integrations</h2>\n        {connected && (\n          <div className=\"flex gap-1 rounded-lg bg-gray-100 p-1\">\n            {periods.map((p) => (\n              <button\n                key={p.value}\n                onClick={() => handlePeriodChange(p.value)}\n                className={`rounded-md px-3 py-1 text-sm font-medium transition-colors ${\n                  state.period === p.value ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-600 hover:text-gray-900'\n                }`}\n              >\n                {p.label}\n              </button>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* Connection Cards */}\n      <div className=\"grid grid-cols-1 gap-4 md:grid-cols-2\">\n        {state.connections.map((conn) => (\n          <div key={conn.provider} className=\"rounded-xl bg-white p-6 shadow-sm\">\n            <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-lg\">\n                  {conn.provider === 'ga4' ? '📊' : '🔍'}\n                </div>\n                <div>\n                  <h3 className=\"font-semibold text-gray-900\">{getProviderLabel(conn.provider)}</h3>\n                  {conn.status === 'connected' && conn.accountName && (\n                    <p className=\"text-sm text-gray-500\">{conn.accountName}</p>\n                  )}\n                </div>\n              </div>\n              <div>\n                {conn.status === 'disconnected' && (\n                  <button\n                    onClick={() => handleConnect(conn.provider)}\n                    disabled={connecting !== null}\n                    className=\"rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50\"\n                  >\n                    Connecter\n                  </button>\n                )}\n                {conn.status === 'connecting' && (\n                  <span className=\"text-sm text-gray-500\">Connexion en cours...</span>\n                )}\n                {conn.status === 'connected' && (\n                  <button\n                    onClick={() => handleDisconnect(conn.provider)}\n                    className=\"rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50\"\n                  >\n                    Deconnecter\n                  </button>\n                )}\n              </div>\n            </div>\n            {conn.status === 'connected' && conn.connectedAt && (\n              <p className=\"mt-3 text-xs text-gray-400\">\n                Connecte le {new Date(conn.connectedAt).toLocaleDateString('fr-FR')}\n              </p>\n            )}\n          </div>\n        ))}\n      </div>\n\n      {/* Dashboard - only visible if connected */}\n      {!connected && (\n        <div className=\"rounded-xl bg-gray-50 p-12 text-center\">\n          <p className=\"text-lg font-medium text-gray-600\">Connectez au moins un service pour voir le dashboard</p>\n          <p className=\"mt-2 text-sm text-gray-400\">Google Analytics 4 ou Search Console</p>\n        