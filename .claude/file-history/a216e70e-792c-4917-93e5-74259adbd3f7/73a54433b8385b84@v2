import React, { useState } from 'react';
import { ArrowLeft, ArrowRight, ChevronDown, ChevronUp, ExternalLink, CheckCircle, AlertTriangle, XCircle, Sparkles, Globe, Bot, BrainCircuit, FileText } from 'lucide-react';
import { AnalysisResult, User } from '../types';
import ScoreRing from '../components/ScoreRing';

interface ResultsProps {
  data: AnalysisResult;
  onBack: () => void;
  user: User | null;
  onDeductCredits: (amount: number) => boolean;
  onNewAnalysis: () => void;
}

const Results: React.FC<ResultsProps> = ({ data, onBack, user, onDeductCredits, onNewAnalysis }) => {
  const [expandedCat, setExpandedCat] = useState<string | null>(null);
  const [showAllRecs, setShowAllRecs] = useState(false);

  const getScoreColor = (score: number) => {
    if (score >= 80) return 'text-amber-300';
    if (score >= 60) return 'text-amber-400';
    if (score >= 40) return 'text-yellow-400';
    return 'text-red-400';
  };

  const getScoreBg = (score: number) => {
    if (score >= 80) return 'bg-amber-400';
    if (score >= 60) return 'bg-amber-500';
    if (score >= 40) return 'bg-yellow-500';
    return 'bg-red-500';
  };

  const getScoreLabel = (score: number) => {
    if (score >= 80) return 'Excellent';
    if (score >= 60) return 'Bon';
    if (score >= 40) return 'Moyen';
    return 'Faible';
  };

  const getPriorityIcon = (priority: string) => {
    switch (priority) {
      case 'critical': return <XCircle size={16} className="text-red-400" />;
      case 'high': return <AlertTriangle size={16} className="text-orange-400" />;
      default: return <CheckCircle size={16} className="text-amber-400" />;
    }
  };

  const visibleRecs = showAllRecs ? data.recommendations : data.recommendations.slice(0, 5);

  return (
    <div className="w-full px-6 py-8 animate-in fade-in duration-500">
      {/* Header */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
          <button onClick={onBack} className="flex items-center gap-2 text-gray-500 hover:text-white text-sm mb-3 transition-colors"><ArrowLeft size={16} /> Retour</button>
          <h1 className="text-3xl font-bold text-white">R\u00e9sultats de <span className="gradient-text">l'audit</span></h1>
          <p className="text-gray-500 text-sm mt-1 flex items-center gap-2"><Globe size={14} /> {data.url}</p>
        </div>
        <button onClick={onNewAnalysis} className="btn-gradient px-6 py-2.5 rounded-full flex items-center gap-2 font-bold whitespace-nowrap">
          <Sparkles size={16} /> Nouvel Audit
        </button>
      </div>

      {/* Global Score */}
      <div className="ninja-card p-8 mb-8">
        <div className="flex flex-col md:flex-row items-center gap-8">
          <div className="flex flex-col items-center gap-3">
            <ScoreRing score={data.globalScore} size={160} strokeWidth={12} />
            <span className={`text-lg font-bold ${getScoreColor(data.globalScore)}`}>{getScoreLabel(data.globalScore)}</span>
          </div>
          <div className="flex-1">
            <h2 className="text-2xl font-bold text-white mb-2">Score Global AEO</h2>
            <p className="text-gray-500 mb-4">Votre site obtient un score de {data.globalScore}/100. {data.globalScore >= 70 ? "Bonne visibilit\u00e9 IA d\u00e9tect\u00e9e." : "Des am\u00e9liorations sont recommand\u00e9es."}</p>
            <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
              <div className="bg-white/[0.03] rounded-xl p-4 border border-white/[0.06]">
                <div className="text-xs text-gray-500 mb-1">Probabilit\u00e9 Citation IA</div>
                <div className="text-xl font-bold text-amber-400">{data.aiCitation.probability}%</div>
              </div>
              <div className="bg-white/[0.03] rounded-xl p-4 border border-white/[0.06]">
                <div className="text-xs text-gray-500 mb-1">Cat\u00e9gories Analys\u00e9es</div>
                <div className="text-xl font-bold text-white">{data.categories.length}</div>
              </div>
              <div className="bg-white/[0.03] rounded-xl p-4 border border-white/[0.06]">
                <div className="text-xs text-gray-500 mb-1">Recommandations</div>
                <div className="text-xl font-bold text-white">{data.recommendations.length}</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* AI Citation Preview */}
      <div className="ninja-card p-6 mb-8">
        <h3 className="text-lg font-bold text-white mb-4 flex items-center gap-2"><Bot size={20} className="text-amber-400" /> Pr\u00e9visualisation Citation IA</h3>
        <div className="bg-white/[0.02] rounded-xl p-5 border border-white/[0.06]">
          <div className="flex items-start gap-3 mb-3">
            <BrainCircuit size={20} className="text-amber-400 shrink-0 mt-0.5" />
            <div>
              <p className="text-sm text-gray-300 leading-relaxed italic">"{data.aiCitation.exampleResponse}"</p>
              <p className="text-xs text-gray-600 mt-2">R\u00e9ponse simul\u00e9e bas\u00e9e sur votre contenu</p>
            </div>
          </div>
        </div>
      </div>

      {/* Categories */}
      <div className="mb-8">
        <h3 className="text-xl font-bold text-white mb-4">Cat\u00e9gories <span className="gradient-text">d\u00e9taill\u00e9es</span></h3>
        <div className="grid md:grid-cols-2 gap-4">
          {data.categories.map(cat => (
            <div key={cat.name} className="ninja-card overflow-hidden">
              <button onClick={() => setExpandedCat(expandedCat === cat.name ? null : cat.name)} className="w-full p-5 flex items-center justify-between text-left">
                <div className="flex items-center gap-3 flex-1">
                  <div className={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold ${cat.score >= 70 ? 'bg-amber-500/20 text-amber-300' : cat.score >= 40 ? 'bg-yellow-500/20 text-yellow-400' : 'bg-red-500/20 text-red-400'}`}>{cat.score}</div>
                  <div><div className="text-sm font-semibold text-white">{cat.name}</div><div className="text-xs text-gray-500">{getScoreLabel(cat.score)}</div></div>
                </div>
                <div className="flex items-center gap-3">
                  <div className="w-24 h-1.5 bg-white/[0.06] rounded-full overflow-hidden"><div className={`h-full rounded-full ${getScoreBg(cat.score)}`} style={{ width: `${cat.score}%` }} /></div>
                  {expandedCat === cat.name ? <ChevronUp size={16} className="text-gray-500" /> : <ChevronDown size={16} className="text-gray-500" />}
                </div>
              </button>
              {expandedCat === cat.name && (
                <div className="px-5 pb-5 border-t border-white/[0.06] pt-4 animate-in slide-in-from-top-1 duration-200">
                  <p className="text-sm text-gray-400 mb-3">{cat.description || 'Analyse d\u00e9taill\u00e9e de cette cat\u00e9gorie.'}</p>
                  {cat.details && cat.details.length > 0 && (
                    <ul className="space-y-2">
                      {cat.details.map((d, i) => (
                        <li key={i} className="flex items-start gap-2 text-sm"><CheckCircle size={14} className="text-amber-400 shrink-0 mt-0.5" /><span className="text-gray-300">{d}</span></li>
                      ))}
                    </ul>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      {/* Recommendations */}
      <div className="ninja-card p-6 mb-8">
        <h3 className="text-xl font-bold text-white mb-4 flex items-center gap-2"><FileText size={20} className="text-amber-400" /> Recommandations</h3>
        <div className="space-y-3">
          {visibleRecs.map((rec, idx) => (
            <div key={idx} className="p-4 bg-white/[0.02] border border-white/[0.06] rounded-xl flex items-start gap-3 hover:bg-white/[0.04] transition-colors">
              {getPriorityIcon(rec.priority)}
              <div className="flex-1">
                <div className="text-sm font-semibold text-white mb-1">{rec.title}</div>
                <p className="text-xs text-gray-500 leading-relaxed">{rec.description}</p>
                {rec.category && <span className="inline-block mt-2 text-[10px] px-2 py-0.5 bg-amber-500/10 text-amber-400 rounded-full border border-amber-500/20">{rec.category}</span>}
              </div>
              <span className={`text-[10px] px-2 py-0.5 rounded-full font-bold ${rec.priority === 'critical' ? 'bg-red-500/20 text-red-400' : rec.priority === 'high' ? 'bg-orange-500/20 text-orange-400' : 'bg-amber-500/20 text-amber-400'}`}>{rec.priority}</span>
            </div>
          ))}
        </div>
        {data.recommendations.length > 5 && (
          <button onClick={() => setShowAllRecs(!showAllRecs)} className="mt-4 text-sm text-amber-400 hover:text-amber-300 font-medium flex items-center gap-1">
            {showAllRecs ? 'Voir moins' : `Voir les ${data.recommendations.length - 5} autres`} {showAllRecs ? <ChevronUp size={14} /> : <ChevronDown size={14} />}
          </button>
        )}
      </div>

      {/* Bottom Actions */}
      <div className="flex flex-col sm:flex-row gap-4 justify-center">
        <button onClick={onNewAnalysis} className="btn-gradient px-8 py-3 font-bold flex items-center justify-center gap-2">
          <Sparkles size={16} /> Lancer un Nouvel Audit
        </button>
        <button onClick={onBack} className="px-8 py-3 rounded-full border border-white/[0.1] text-gray-300 font-medium hover:bg-white/[0.04] transition-all flex items-center justify-center gap-2">
          <ArrowLeft size={16} /> Retour au Dashboard
        </button>
      </div>
    </div>
  );
};

export default Results;
