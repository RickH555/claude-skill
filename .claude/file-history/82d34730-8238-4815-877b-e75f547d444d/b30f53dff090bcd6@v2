<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CitedBy.ai - AEO/GEO Optimizer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;500;600;700&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#050208',
                        surface: '#0c0815',
                        surfaceHighlight: '#150f24',
                        primary: '#a855f7',
                        primaryDark: '#7c3aed',
                        secondary: '#e2d6ff',
                        accent: '#c084fc',
                        danger: '#ef4444',
                    },
                    fontFamily: {
                        sans: ['DM Sans', 'Inter', 'sans-serif'],
                        serif: ['Instrument Serif', 'serif'],
                    },
                    animation: {
                        'spin-slow': 'spin 3s linear infinite',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'shimmer': 'shimmer 2.5s ease-in-out infinite',
                    },
                    keyframes: {
                        shimmer: {
                            '0%, 100%': { opacity: '0.4' },
                            '50%': { opacity: '0.8' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #050208;
            color: #ffffff;
            font-family: 'DM Sans', sans-serif;
            -webkit-font-smoothing: antialiased;
            background-image:
                radial-gradient(ellipse 80% 50% at 50% -10%, rgba(124, 58, 237, 0.15) 0%, transparent 60%),
                radial-gradient(circle at 20% 80%, rgba(168, 85, 247, 0.05) 0%, transparent 40%);
            background-attachment: fixed;
        }
        .glass-panel {
            background: rgba(168, 85, 247, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(168, 85, 247, 0.1);
        }
        /* Metallic reflection effect */
        .metallic-border {
            border-image: linear-gradient(135deg, rgba(192, 132, 252, 0.4), rgba(168, 85, 247, 0.1), rgba(192, 132, 252, 0.3)) 1;
        }
        .metallic-glow {
            box-shadow: 0 0 20px rgba(168, 85, 247, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        .metallic-text {
            background: linear-gradient(135deg, #e9d5ff 0%, #a855f7 50%, #c4b5fd 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        /* Custom Scrollbar - Dark & Purple */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #050208;
        }
        ::-webkit-scrollbar-thumb {
            background: #2d1b4e;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a855f7;
        }
    </style>
<script type="importmap">
{
  "imports": {
    "react": "https://esm.sh/react@^19.2.3",
    "react-dom/": "https://esm.sh/react-dom@^19.2.3/",
    "react/": "https://esm.sh/react@^19.2.3/",
    "lucide-react": "https://esm.sh/lucide-react@^0.562.0",
    "html2canvas": "https://esm.sh/html2canvas@1.4.1",
    "jspdf": "https://esm.sh/jspdf@2.5.1",
    "@google/genai": "https://esm.sh/@google/genai@^1.37.0",
    "tailwindcss": "https://esm.sh/tailwindcss@^4.1.18",
    "tailwind-merge": "https://esm.sh/tailwind-merge@^3.4.0",
    "next/": "https://esm.sh/next@^16.1.4/",
    "next": "https://esm.sh/next@^16.1.4",
    "@supabase/ssr": "https://esm.sh/@supabase/ssr@^0.8.0",
    "clsx": "https://esm.sh/clsx@^2.1.1",
    "@supabase/supabase-js": "https://esm.sh/@supabase/supabase-js@^2.90.1",
    "stripe": "https://esm.sh/stripe@^20.2.0"
  }
}
</script>
<link rel="stylesheet" href="/index.css">
</head>
<body>
    <div id="root"></div>
<script type="module" src="/index.tsx"></script>
</body>
</html>