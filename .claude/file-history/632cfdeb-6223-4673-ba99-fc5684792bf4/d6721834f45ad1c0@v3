import { NextRequest, NextResponse } from "next/server"
import { createClient } from "@/lib/supabase/server"
import { generateContent } from "@/services/content_writer"
import { createGeneratedContent } from "@/lib/db"
import { AuthError, ValidationError, RateLimitError, formatApiError } from "@/lib/errors"
import { checkRateLimit } from "@/lib/rate-limit"
import type { ContentType, ContentVertical } from "@/types"

export const maxDuration = 60

export async function POST(req: NextRequest) {
  try {
    const supabase = createClient()
    const { data: { user } } = await supabase.auth.getUser()
    if (!user) {
      throw new AuthError()
    }

    // Rate limit: 10 content generations per minute per user
    const rl = checkRateLimit(`content:${user.id}`, 10)
    if (!rl.success) throw new RateLimitError()

    const body = await req.json()
    const {
      projectId,
      workspaceId,
      contentType,
      vertical,
      brandName,
      brandUrl,
      productOrService,
      targetAudience,
      tone,
      language,
      additionalContext,
    } = body

    if (!projectId || !workspaceId || !contentType || !brandName || !productOrService) {
      throw new ValidationError("Champs requis : projectId, workspaceId, contentType, brandName, productOrService")
    }

    // Generate content via Gemini
    const result = await generateContent({
      contentType: contentType as ContentType,
      vertical: (vertical || "general") as ContentVertical,
      brandName,
      brandUrl,
      productOrService,
      targetAudience: targetAudience || "Professionnels B2B",
      tone: tone || "professionnel",
      language: language || "fr",
      additionalContext,
    })

    // Save to database
    const saved = await createGeneratedContent({
      project_id: projectId,
      workspace_id: workspaceId,
      created_by: user.id,
      content_type: contentType,
      title: result.title,
      content: result.content,
      meta_description: result.metaDescription,
      aeo_score: result.aeoScore,
      aeo_tips: result.aeoTips,
      schema_markup: result.schemaMarkup,
      metadata: {
        vertical,
        tone,
        language,
        brandName,
        productOrService,
      },
    })

    return NextResponse.json({
      success: true,
      content: saved,
    })
  } catch (error) {
    const { status, body } = formatApiError(error)
    return NextResponse.json(body, { status })
  }
}
