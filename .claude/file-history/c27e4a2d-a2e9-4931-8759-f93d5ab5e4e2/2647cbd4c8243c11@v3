export const dynamic = 'force-dynamic';

import { createServerSupabase } from '@/lib/supabase/server';
import CustomerQrDisplay from './qr-display';

export default async function CustomerQrPage() {
  const supabase = await createServerSupabase();
  const { data: { user } } = await supabase.auth.getUser();

  // Get or create customer QR code
  let { data: qrCode } = await supabase
    .from('customer_qr_codes')
    .select('*')
    .eq('customer_id', user!.id)
    .eq('is_active', true)
    .single();

  if (!qrCode) {
    // Generate a secret key for this customer
    const secretKey = crypto.randomUUID().replace(/-/g, '');

    const { data: newQr } = await supabase
      .from('customer_qr_codes')
      .insert({
        customer_id: user!.id,
        qr_secret: secretKey,
        is_active: true,
      })
      .select()
      .single();

    qrCode = newQr;
  }

  const appUrl = process.env.NEXT_PUBLIC_APP_URL || 'https://royallazz.com';

  return (
    <div className="space-y-4 py-4">
      <h1 className="text-xl font-bold text-[var(--text-primary)]">Mon QR Code</h1>
      {qrCode ? (
        <CustomerQrDisplay
          qrId={qrCode.id}
          secretKey={qrCode.qr_secret}
          appUrl={appUrl}
        />
      ) : (
        <p className="text-[var(--text-secondary)]">Erreur lors de la creation du QR code.</p>
      )}
    </div>
  );
}
