// components/layout/AppShell.tsx
//
// Layout principal assemblant TopNav + AppSidebar + Content area
// Dashboard = full-width (pas de sidebar)
// Toutes les autres sections = sidebar + contenu

import React from 'react';
import TopNav from './TopNav';
import AppSidebar from './AppSidebar';
import type { Section } from './TopNav';
import type { User } from '../../types';

interface AppShellProps {
  user: User | null;
  activeSection: Section;
  activePage: string;
  onSectionChange: (section: Section) => void;
  onNavigate: (view: string) => void;
  animatedCredits: number;
  onOpenCommandPalette: () => void;
  onLogout: () => void;
  isSidebarCollapsed: boolean;
  onToggleSidebar: () => void;
  children: React.ReactNode;
}

export default function AppShell({
  user,
  activeSection,
  activePage,
  onSectionChange,
  onNavigate,
  animatedCredits,
  onOpenCommandPalette,
  onLogout,
  isSidebarCollapsed,
  onToggleSidebar,
  children,
}: AppShellProps) {
  const hasSidebar = user && activeSection !== 'dashboard';

  return (
    <div className="min-h-screen flex flex-col font-sans text-gray-100 bg-[#0F172A]">
      {/* TopNav */}
      <TopNav
        user={user}
        activeSection={activeSection}
        onSectionChange={onSectionChange}
        animatedCredits={animatedCredits}
        onOpenCommandPalette={onOpenCommandPalette}
        onLogout={onLogout}
        onNavigate={onNavigate}
      />

      {/* Spacer for fixed navbar */}
      <div className="h-14 shrink-0" />

      {/* Content area */}
      <div className="flex-1 flex">
        {/* Sidebar */}
        {hasSidebar && (
          <AppSidebar
            activeSection={activeSection}
            activePage={activePage}
            onNavigate={onNavigate}
            isCollapsed={isSidebarCollapsed}
            onToggle={onToggleSidebar}
          />
        )}

        {/* Main content — max-w caps width on large screens only */}
        <main className={`flex-1 min-w-0 min-h-[calc(100vh-3.5rem)] ${hasSidebar ? 'max-w-[1400px]' : ''}`}>
          {children}
        </main>
      </div>
    </div>
  );
}
