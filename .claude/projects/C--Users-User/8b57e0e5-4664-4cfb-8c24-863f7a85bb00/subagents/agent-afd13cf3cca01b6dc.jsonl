{"parentUuid":null,"isSidechain":true,"userType":"external","cwd":"C:\\Users\\User\\citedby-ai","sessionId":"8b57e0e5-4664-4cfb-8c24-863f7a85bb00","version":"2.1.50","gitBranch":"HEAD","agentId":"afd13cf3cca01b6dc","slug":"sharded-tumbling-meadow","type":"user","message":{"role":"user","content":"Create the following Next.js page.tsx wrapper files in C:\\Users\\User\\citedby-ai for the Marketplace and Settings sections. Each page is a 'use client' component that imports useAppContext from '@/lib/app-context'.\n\nCreate these files:\n\n### MARKETPLACE\n\n### 1. app/(app)/marketplace/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Directory from '@/views/Directory';\n\nexport default function MarketplacePage() {\n  const { goBack, handleViewDirectoryEntity, navigateTo, user, monthlyProjectCount, maxProjects, actionPlanStatus, resultsTab } = useAppContext();\n  return (\n    <Directory\n      onBack={goBack}\n      onViewEntity={handleViewDirectoryEntity}\n      onNavigateToPlan={() => navigateTo('account')}\n      user={user}\n      directClientCount={monthlyProjectCount}\n      maxClients={maxProjects}\n      actionPlanComplete={actionPlanStatus.complete}\n      actionPlanProgress={actionPlanStatus}\n      onNavigateToActionPlan={() => { navigateTo('projects'); }}\n    />\n  );\n}\n```\n\n### 2. app/(app)/marketplace/entity/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport DirectoryEntity from '@/views/DirectoryEntity';\n\nexport default function DirectoryEntityPage() {\n  const { analysisData, goBack } = useAppContext();\n  if (!analysisData) return <div className=\"p-8 text-slate-400\">Aucune entite selectionnee.</div>;\n  return <DirectoryEntity data={analysisData} onBack={goBack} />;\n}\n```\n\n### 3. app/(app)/marketplace/publisher/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport PublisherRequest from '@/views/PublisherRequest';\n\nexport default function PublisherRequestPage() {\n  const { goBack, user, publisherRequestData } = useAppContext();\n  return <PublisherRequest onBack={goBack} user={user} data={publisherRequestData} />;\n}\n```\n\n### 4. app/(app)/marketplace/clients/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Clients from '@/views/Clients';\n\nexport default function ClientsPage() {\n  const { goBack, navigateTo, user, monthlyProjectCount, maxProjects } = useAppContext();\n  return (\n    <Clients\n      onBack={goBack}\n      onNavigate={navigateTo}\n      user={user}\n      directClientCount={monthlyProjectCount}\n      maxClients={maxProjects}\n    />\n  );\n}\n```\n\n### 5. app/(app)/marketplace/affiliation/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Affiliation from '@/views/Affiliation';\n\nexport default function AffiliationPage() {\n  const { goBack, user } = useAppContext();\n  return <Affiliation onBack={goBack} user={user} />;\n}\n```\n\n### 6. app/(app)/marketplace/missions/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport MissionOrders from '@/views/MissionOrders';\n\nexport default function MissionOrdersPage() {\n  const { goBack, user, navigateTo } = useAppContext();\n  return (\n    <MissionOrders\n      onBack={goBack}\n      user={user}\n      onNavigate={navigateTo}\n    />\n  );\n}\n```\n\n### 7. app/(app)/marketplace/messages/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Messages from '@/views/Messages';\n\nexport default function MessagesPage() {\n  const { goBack, user } = useAppContext();\n  return <Messages onBack={goBack} user={user} />;\n}\n```\n\n### SETTINGS\n\n### 8. app/(app)/settings/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Account from '@/views/Account';\n\nexport default function SettingsPage() {\n  const { user, handleLogout, navigateTo, handleUpgradePlan, monthlyProjectCount, maxProjects, initialAccountTab } = useAppContext();\n  return (\n    <Account\n      user={user}\n      onLogout={handleLogout}\n      onNavigate={navigateTo}\n      onUpgrade={handleUpgradePlan}\n      projectCount={monthlyProjectCount}\n      maxProjects={maxProjects}\n      initialTab={initialAccountTab}\n    />\n  );\n}\n```\n\n### 9. app/(app)/settings/recharge/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Recharge from '@/views/Recharge';\n\nexport default function RechargePage() {\n  const { goBack, handleRecharge, user, navigateTo, initialRechargePackId } = useAppContext();\n  return (\n    <Recharge\n      onBack={goBack}\n      onRecharge={handleRecharge}\n      user={user}\n      onNavigate={navigateTo}\n      initialPackId={initialRechargePackId}\n    />\n  );\n}\n```\n\n### 10. app/(app)/settings/integrations/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport Integrations from '@/views/Integrations';\n\nexport default function IntegrationsPage() {\n  const { goBack, user, handleDeductCredits } = useAppContext();\n  return <Integrations onBack={goBack} user={user} onDeductCredits={handleDeductCredits} />;\n}\n```\n\n### 11. app/(app)/settings/api-developer/page.tsx\n```typescript\n'use client';\nimport { useAppContext } from '@/lib/app-context';\nimport ApiDeveloper from '@/views/ApiDeveloper';\n\nexport default function ApiDeveloperPage() {\n  const { goBack, user, handleDeductCredits } = useAppContext();\n  return <ApiDeveloper onBack={goBack} user={user} onDeductCredits={handleDeductCredits} />;\n}\n```\n\nWrite all 11 files. Create directories as needed."},"uuid":"05fe5154-661f-482a-9327-f5084e8c2925","timestamp":"2026-02-21T21:40:57.206Z"}
