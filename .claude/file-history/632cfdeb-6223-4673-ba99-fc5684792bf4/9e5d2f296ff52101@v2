import { describe, it, expect } from "vitest"
import {
  AppError,
  AuthError,
  ForbiddenError,
  NotFoundError,
  ValidationError,
  RateLimitError,
  formatApiError,
} from "@/lib/errors"

describe("Error classes", () => {
  it("AppError has correct defaults", () => {
    const err = new AppError("test")
    expect(err.message).toBe("test")
    expect(err.statusCode).toBe(500)
    expect(err.code).toBe("INTERNAL_ERROR")
    expect(err.name).toBe("AppError")
  })

  it("AuthError has status 401", () => {
    const err = new AuthError()
    expect(err.statusCode).toBe(401)
    expect(err.code).toBe("UNAUTHORIZED")
    expect(err.message).toBe("Non authentifie")
  })

  it("ForbiddenError has status 403", () => {
    const err = new ForbiddenError()
    expect(err.statusCode).toBe(403)
    expect(err.code).toBe("FORBIDDEN")
  })

  it("NotFoundError has status 404", () => {
    const err = new NotFoundError()
    expect(err.statusCode).toBe(404)
    expect(err.code).toBe("NOT_FOUND")
  })

  it("ValidationError has status 400", () => {
    const err = new ValidationError("Bad input")
    expect(err.statusCode).toBe(400)
    expect(err.code).toBe("VALIDATION_ERROR")
    expect(err.message).toBe("Bad input")
  })

  it("RateLimitError has status 429", () => {
    const err = new RateLimitError()
    expect(err.statusCode).toBe(429)
    expect(err.code).toBe("RATE_LIMIT_EXCEEDED")
  })

  it("accepts custom messages", () => {
    const err = new AuthError("Token expire")
    expect(err.message).toBe("Token expire")
    expect(err.statusCode).toBe(401)
  })
})

describe("formatApiError", () => {
  it("formats AppError correctly", () => {
    const err = new ValidationError("Email invalide")
    const result = formatApiError(err)
    expect(result.status).toBe(400)
    expect(result.body.error).toBe("Email invalide")
    expect(result.body.code).toBe("VALIDATION_ERROR")
  })

  it("formats unknown errors as 500", () => {
    const result = formatApiError(new Error("Something broke"))
    expect(result.status).toBe(500)
    expect(result.body.code).toBe("INTERNAL_ERROR")
    expect(result.body.error).toBe("Erreur interne du serveur")
  })

  it("formats non-Error objects as 500", () => {
    const result = formatApiError("string error")
    expect(result.status).toBe(500)
    expect(result.body.code).toBe("INTERNAL_ERROR")
  })

  it("formats null/undefined as 500", () => {
    expect(formatApiError(null).status).toBe(500)
    expect(formatApiError(undefined).status).toBe(500)
  })
})
