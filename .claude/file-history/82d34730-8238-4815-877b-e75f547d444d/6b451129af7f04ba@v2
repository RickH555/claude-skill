                    <table className="w-full text-left">
                        <thead>
                            <tr className="bg-[#111111] text-xs text-gray-500 uppercase tracking-wider">
                                <th className="px-6 py-4 font-medium">Filleul</th>
                                <th className="px-6 py-4 font-medium">Plan</th>
                                <th className="px-6 py-4 font-medium">Date Inscription</th>
                                <th className="px-6 py-4 font-medium">Statut</th>
                                <th className="px-6 py-4 font-medium">Historique</th>
                                <th className="px-6 py-4 font-medium text-right">Commission (Mois)</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-white/5">
                            {REFERRALS.map((ref) => (
                                <tr key={ref.id} className="hover:bg-white/[0.02] transition-colors">
                                    <td className="px-6 py-4">
                                        <div className="flex items-center gap-3">
                                            <div className="w-8 h-8 rounded-lg bg-purple-500/5 flex items-center justify-center font-bold text-xs text-gray-300">
                                                {ref.name.charAt(0)}
                                            </div>
                                            <div>
                                                <p className="text-sm font-medium text-white">{ref.name}</p>
                                                <p className="text-xs text-gray-500">{ref.id}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td className="px-6 py-4">
                                        <span className={`text-xs px-2 py-1 rounded border ${
                                            ref.plan === 'Agency' ? 'bg-purple-500/10 border-purple-500/20 text-purple-400' :
                                            ref.plan === 'Pro' ? 'bg-blue-500/10 border-blue-500/20 text-blue-400' :
                                            'bg-gray-500/10 border-gray-500/20 text-gray-400'
                                        }`}>
                                            {ref.plan}
                                        </span>
                                    </td>
                                    <td className="px-6 py-4 text-sm text-gray-400">{ref.date}</td>
                                    <td className="px-6 py-4">
                                        <div className="flex items-center gap-2">
                                            <div className={`w-1.5 h-1.5 rounded-full ${
                                                ref.status === 'active' ? 'bg-purple-400' :
                                                ref.status === 'trial' ? 'bg-purple-500' : 'bg-red-500'
                                            }`}></div>
                                            <span className="text-sm text-gray-300 capitalize">{ref.status === 'trial' ? 'Essai' : ref.status}</span>
                                        </div>
                                    </td>
                                    <td className="px-6 py-4 text-sm text-gray-400">{ref.history}</td>
                                    <td className="px-6 py-4 text-right font-bold text-purple-300">
                                        {ref.commission > 0 ? `+${ref.commission.toFixed(2)} €` : '-'}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
      )}

      {/* 3. PAYOUTS */}
      {activeTab === 'payouts' && (
        <div className="grid md:grid-cols-12 gap-8 animate-in fade-in slide-in-from-right-4">
            <div className="md:col-span-4 space-y-6">
                <div className="ninja-card p-6 rounded-xl border border-white/10 bg-gradient-to-b from-primary/5 to-transparent">
                    <h3 className="font-bold text-white mb-2">Solde disponible</h3>
                    <div className="text-4xl font-sans font-bold text-white mb-6">{AFFILIATE_STATS.pendingCommission.toFixed(2)} €</div>
                    
                    <button 
                        onClick={handleRequestPayout}
                        disabled={AFFILIATE_STATS.pendingCommission < 50 || isRequestingPayout}
                        className="w-full btn-gradient py-3 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        {isRequestingPayout ? 'Traitement...' : 'Demander le virement'}
                    </button>
                    <p className="text-xs text-gray-500 mt-3 text-center">
                        Minimum de retrait : 50.00 €
                    </p>
                </div>

                <div className="ninja-card p-6 rounded-xl border border-white/10">
                    <h3 className="font-bold text-white mb-4 flex items-center gap-2">
                        <CreditCard size={18} className="text-gray-400" /> Mode de paiement
                    </h3>
                    <div className="flex items-center justify-between p-3 bg-purple-500/5 rounded-lg border border-white/10 mb-4">
                        <div className="flex items-center gap-3">
                            <div className="w-10 h-6 bg-white rounded flex items-center justify-center">
                                <span className="text-[10px] font-bold text-blue-800">PayPal</span>
                            </div>
                            <span className="text-sm text-gray-300">user@email.com</span>
                        </div>
                        <button className="text-xs text-primary hover:underline">Modifier</button>
                    </div>
                    <button className="w-full py-2 bg-purple-500/5 hover:bg-purple-500/10 text-gray-300 text-sm font-medium rounded-lg transition-colors border border-white/10">
                        Ajouter un compte bancaire (IBAN)
                    </button>
                </div>
            </div>

            <div className="md:col-span-8">
                <div className="ninja-card rounded-xl border border-white/10 overflow-hidden">
                    <div className="p-6 border-b border-white/10">
                        <h3 className="font-bold text-white">Historique des versements</h3>
                    </div>
                    <div className="overflow-x-auto">
                        <table className="w-full text-left">
                            <thead>
                                <tr className="bg-[#111111] text-xs text-gray-500 uppercase tracking-wider">
                                    <th className="px-6 py-4 font-medium">Référence</th>
                                    <th className="px-6 py-4 font-medium">Date</th>
                                    <th className="px-6 py-4 font-medium">Méthode</th>
                                    <th className="px-6 py-4 font-medium">Statut</th>
                                    <th className="px-6 py-4 font-medium text-right">Montant</th>
                                    <th className="px-6 py-4 font-medium text-right">Reçu</th>
                                </tr>
                            </thead>
                            <tbody className="divide-y divide-white/5">
                                {PAYOUTS.map((pay) => (
                                    <tr key={pay.id} className="hover:bg-white/[0.02] transition-colors">
                                        <td className="px-6 py-4 text-sm text-gray-300 font-mono">{pay.id}</td>
                                        <td className="px-6 py-4 text-sm text-gray-400">{pay.date}</td>
                                        <td className="px-6 py-4 text-sm text-gray-300">{pay.method}</td>
                                        <td className="px-6 py-4">
                                            <span className="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-400/10 text-purple-300 border border-purple-400/20">
                                                <Check size={10} /> Payé
                                            </span>
                                        </td>
                                        <td className="px-6 py-4 text-right text-sm font-bold text-white">
                                            {pay.amount.toFixed(2)} €
                                        </td>
                                        <td className="px-6 py-4 text-right">
                                            <button className="p-1.5 hover:bg-purple-500/10 rounded text-gray-500 hover:text-white transition-colors">
                                                <ExternalLink size={14} />
                                            </button>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
      )}

    </div>
  );
};

export default Affiliation;