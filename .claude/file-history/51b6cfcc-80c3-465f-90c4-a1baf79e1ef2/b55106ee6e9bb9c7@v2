import { describe, it, expect } from 'vitest';
import { calculateAiVisibilityScore, ScoringContext } from '../lib/scoring';

describe('calculateAiVisibilityScore', () => {
  const baseContext: ScoringContext = {
    answer: '',
    brandName: 'CitedBy',
    domain: 'citedby.ai',
    services: ['audit AEO', 'schema.org', 'robots.txt'],
    competitors: ['semrush', 'ahrefs'],
  };

  it('returns 0 for an empty answer', () => {
    const result = calculateAiVisibilityScore({ ...baseContext, answer: '' });
    expect(result.score).toBe(0);
    expect(result.resultType).toBe('none');
    expect(result.details.brandMention).toBe(false);
    expect(result.details.urlMention).toBe(false);
  });

  it('detects brand mention and awards +20', () => {
    const result = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'I recommend CitedBy for AEO optimization.',
    });
    expect(result.details.brandMention).toBe(true);
    expect(result.resultType).toBe('mention');
    expect(result.score).toBeGreaterThanOrEqual(20);
  });

  it('detects URL mention and awards +30 +10 (source quality)', () => {
    const result = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'Visit citedby.ai for more information about AEO tools.',
    });
    expect(result.details.urlMention).toBe(true);
    expect(result.resultType).toBe('citation');
    expect(result.score).toBeGreaterThanOrEqual(40);
  });

  it('detects service mentions and awards +15', () => {
    const result = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'CitedBy offers schema.org generation tools for better AEO results.',
    });
    expect(result.details.serviceMention).toBe(true);
    expect(result.score).toBeGreaterThanOrEqual(35);
  });

  it('applies competitor penalty of -10', () => {
    const withCompetitor = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'CitedBy is good but semrush is also available.',
    });
    const withoutCompetitor = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'CitedBy is good for AEO optimization tasks.',
    });
    expect(withCompetitor.details.competitorMention).toBe(true);
    expect(withCompetitor.score).toBeLessThan(withoutCompetitor.score);
  });

  it('awards relevance score based on answer length', () => {
    const shortAnswer = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'Yes.',
    });
    const longAnswer = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'This is a detailed and comprehensive answer about various topics that spans multiple sentences and provides thorough information about the subject matter at hand, including relevant context and background details.',
    });
    expect(longAnswer.score).toBeGreaterThan(shortAnswer.score);
  });

  it('clamps score between 0 and 100', () => {
    const maxResult = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'CitedBy at citedby.ai offers audit AEO and schema.org and robots.txt services. ' + 'x'.repeat(2000),
    });
    expect(maxResult.score).toBeLessThanOrEqual(100);
    expect(maxResult.score).toBeGreaterThanOrEqual(0);
  });

  it('case-insensitive brand detection', () => {
    const result = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'I use CITEDBY for my SEO needs.',
    });
    expect(result.details.brandMention).toBe(true);
  });

  it('URL mention takes priority over brand for resultType', () => {
    const result = calculateAiVisibilityScore({
      ...baseContext,
      answer: 'Check out CitedBy at citedby.ai for the best AEO tools.',
    });
    expect(result.resultType).toBe('citation');
    expect(result.details.brandMention).toBe(true);
    expect(result.details.urlMention).toBe(true);
  });
});
