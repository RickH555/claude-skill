"use client"

import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, Cell, Legend } from "recharts"

interface CompetitorData {
  name: string
  mentions: number
  isBrand?: boolean
}

interface CompetitorChartProps {
  data: CompetitorData[]
  brandName: string
}

export function CompetitorChart({ data, brandName }: CompetitorChartProps) {
  const chartData = data
    .map((d) => ({
      ...d,
      isBrand: d.name.toLowerCase() === brandName.toLowerCase(),
    }))
    .sort((a, b) => b.mentions - a.mentions)

  return (
    <ResponsiveContainer width="100%" height={250}>
      <BarChart data={chartData} layout="vertical" margin={{ top: 10, right: 20, left: 0, bottom: 0 }}>
        <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.05)" horizontal={false} />
        <XAxis
          type="number"
          stroke="rgba(255,255,255,0.2)"
          tick={{ fill: "rgba(255,255,255,0.4)", fontSize: 12 }}
          axisLine={false}
          tickLine={false}
        />
        <YAxis
          type="category"
          dataKey="name"
          stroke="rgba(255,255,255,0.2)"
          tick={{ fill: "rgba(255,255,255,0.6)", fontSize: 12 }}
          axisLine={false}
          tickLine={false}
          width={120}
        />
        <Tooltip
          contentStyle={{
            backgroundColor: "#1a1d21",
            border: "1px solid rgba(255,255,255,0.1)",
            borderRadius: "12px",
            color: "#fff",
          }}
        />
        <Bar dataKey="mentions" radius={[0, 6, 6, 0]} maxBarSize={30}>
          {chartData.map((entry) => (
            <Cell
              key={entry.name}
              fill={entry.isBrand ? "#10b981" : "rgba(255,255,255,0.15)"}
              fillOpacity={entry.isBrand ? 1 : 0.8}
            />
          ))}
        </Bar>
      </BarChart>
    </ResponsiveContainer>
  )
}
