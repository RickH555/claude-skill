const PATH_TO_VIEW: Record<string, string> = {};
for (const [view, path] of Object.entries(VIEW_TO_PATH)) {
  PATH_TO_VIEW[path] = view;
}

export function getViewNameFromPath(pathname: string): string {
  return PATH_TO_VIEW[pathname] || 'dashboard';
}

export function getSectionFromPath(pathname: string): Section {
  if (pathname === '/' || pathname === '/login') return 'dashboard';
  if (pathname.startsWith('/dashboard')) return 'dashboard';
  if (pathname.startsWith('/analyze') || pathname.startsWith('/projects') || pathname.startsWith('/results') || pathname.startsWith('/history') || pathname.startsWith('/monitoring')) return 'analyse';
  if (pathname.startsWith('/citations')) return 'citations';
  if (pathname.startsWith('/tools')) return 'outils';
  if (pathname.startsWith('/marketplace')) return 'marketplace';
  if (pathname.startsWith('/settings')) return 'parametres';
  return 'dashboard';
}

