import React, { useState, useMemo, useEffect } from 'react';
import { Radar, TrendingUp, ArrowRight, Play, Settings, Target, Trophy, Clock, ArrowUp, ArrowDown, Minus } from 'lucide-react';
import type { User } from '../../types';
import type { CitationCheck, CitationRate, AIEngineId } from '../../types/v3-types';
import { getCitationChecks, getTrackedQueries, getProjectConfig } from '../../services/v3/citation-storage';
import { aggregateCitationRates } from '../../services/v3/citation-checker';
import { runCitationChecks } from '../../services/v3/citation-checker';
import ScoreRing from '../../components/ScoreRing';

interface Props {
  onBack: () => void;
  user: User | null;
  onNavigate: (view: string) => void;
}

const ENGINE_META: Record<AIEngineId, { name: string; icon: string; color: string; bgClass: string; textClass: string }> = {
  chatgpt: { name: 'ChatGPT', icon: '🟢', color: '#10a37f', bgClass: 'bg-emerald-500/10', textClass: 'text-emerald-400' },
  perplexity: { name: 'Perplexity', icon: '🔵', color: '#20b8cd', bgClass: 'bg-cyan-500/10', textClass: 'text-cyan-400' },
  gemini: { name: 'Gemini', icon: '🟣', color: '#8b5cf6', bgClass: 'bg-violet-500/10', textClass: 'text-violet-400' },
};

const CitationDashboardPage: React.FC<Props> = ({ onBack, user, onNavigate }) => {
  const [isRunning, setIsRunning] = useState(false);
  const [progress, setProgress] = useState({ current: 0, total: 0 });

  const projectId = user?.id || 'default';
  const checks = useMemo(() => getCitationChecks(projectId), [projectId]);
  const queries = useMemo(() => getTrackedQueries(projectId), [projectId]);
  const config = useMemo(() => getProjectConfig(projectId), [projectId]);

  // Taux de citation agrégés
  const citationRates = useMemo(() => {
    if (checks.length === 0) return null;
    return aggregateCitationRates(checks);
  }, [checks]);

  // Score de visibilité IA global
  const visibilityScore = useMemo(() => {
    if (!citationRates) return 0;
    const engines: AIEngineId[] = ['chatgpt', 'perplexity', 'gemini'];
    const rates = engines.map(e => citationRates[e]?.citationRatePercent || 0);
    return Math.round(rates.reduce((a, b) => a + b, 0) / rates.length);
  }, [citationRates]);

  // Dernières 10 citations
  const recentCitations = useMemo(() => {
    return checks
      .filter(c => c.detection.urlExactMatch || c.detection.brandExactMatch || c.detection.urlInSource)
      .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
      .slice(0, 10);
  }, [checks]);

  const handleRunVerification = async () => {
    if (queries.length === 0 || !config) return;
    setIsRunning(true);
    setProgress({ current: 0, total: 1 });

    try {
      await runCitationChecks(
        queries.filter(q => q.isActive),
        {
          projectId,
          clientUrl: config.clientUrl,
          clientBrand: config.clientBrand,
          brandVariants: config.brandVariants,
          productKeywords: config.productKeywords,
          competitors: [],
        },
        (current, total) => setProgress({ current, total })
      );
      // Reload - force re-render
      window.location.reload();
    } catch (error) {
      console.error('Erreur vérification:', error);
    } finally {
      setIsRunning(false);
    }
  };

  const getConfidenceBadge = (confidence: 'high' | 'medium' | 'low') => {
    switch (confidence) {
      case 'high': return { label: 'Élevée', class: 'bg-green-500/20 text-green-400' };
      case 'medium': return { label: 'Moyenne', class: 'bg-yellow-500/20 text-yellow-400' };
      case 'low': return { label: 'Faible', class: 'bg-red-500/20 text-red-400' };
    }
  };

  const getTrendIcon = (trend: string) => {
    if (trend === 'improving') return <ArrowUp size={12} className="text-green-400" />;
    if (trend === 'declining') return <ArrowDown size={12} className="text-red-400" />;
    return <Minus size={12} className="text-gray-500" />;
  };

  return (
    <div className="w-full px-4 py-10 animate-in fade-in duration-500 pb-24">
      {/* Header */}
      <div className="mb-8">
        <h1 className="text-3xl font-sans font-bold text-white mb-2 flex items-center gap-3">
          <div className="w-10 h-10 rounded-2xl bg-cyan-500/20 flex items-center justify-center border border-cyan-500/30">
            <Radar size={24} className="text-cyan-400" />
          </div>
          Vos citations dans les moteurs IA
        </h1>
        <p className="text-gray-500">
          Mesurez votre présence réelle dans les réponses de ChatGPT, Perplexity et Gemini.
        </p>
      </div>

      {/* Zone 1 : Score de visibilité IA */}
      <div className="grid grid-cols-1 md:grid-cols-12 gap-6 mb-8">
        <div className="md:col-span-4 ninja-card p-8 rounded-2xl flex flex-col items-center justify-center relative overflow-hidden border-cyan-500/20">
          <div className="absolute top-0 right-0 w-32 h-32 bg-cyan-500/10 blur-3xl rounded-full pointer-events-none" />
          <h3 className="text-gray-500 text-sm font-medium uppercase tracking-wider mb-6">Score de Visibilité IA</h3>
          <ScoreRing score={visibilityScore} size={160} strokeWidth={12} />
          <p className="text-xs text-gray-500 mt-4 text-center">
            Basé sur {checks.length} vérification{checks.length > 1 ? 's' : ''}
          </p>
        </div>

        {/* Zone 2 : Taux de citation par moteur */}
        <div className="md:col-span-8 ninja-card p-6 rounded-2xl border border-white/[0.08]">
          <h3 className="text-sm font-bold text-white mb-6 flex items-center gap-2">
            <Target size={16} className="text-cyan-400" />
            Taux de citation par moteur IA
          </h3>

          {citationRates ? (
            <div className="space-y-5">
              {(['chatgpt', 'perplexity', 'gemini'] as AIEngineId[]).map(engineId => {
                const rate = citationRates[engineId];
                const meta = ENGINE_META[engineId];
                const confidence = getConfidenceBadge(rate.confidence);
                return (
                  <div key={engineId}>
                    <div className="flex items-center justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <span className="text-lg">{meta.icon}</span>
                        <span className="text-sm font-medium text-white">{meta.name}</span>
                      </div>
                      <div className="flex items-center gap-3">
                        <span className="text-sm font-bold text-white">{rate.citationRatePercent}%</span>
                        <span className={`text-[10px] px-2 py-0.5 rounded-full font-medium ${confidence.class}`}>
                          Confiance: {confidence.label}
                        </span>
                        {getTrendIcon(rate.trend)}
                      </div>
                    </div>
                    <div className="w-full h-2.5 bg-white/10 rounded-full overflow-hidden">
                      <div
                        className="h-full rounded-full transition-all duration-700 ease-out"
                        style={{ width: `${rate.citationRatePercent}%`, backgroundColor: meta.color }}
                      />
                    </div>
                    <div className="flex justify-between mt-1">
                      <span className="text-[10px] text-gray-600">{rate.citationsDetected}/{rate.totalChecks} détections</span>
                      <span className="text-[10px] text-gray-600">Score moyen: {rate.avgCitationScore}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <div className="flex flex-col items-center justify-center py-8 text-center">
              <Radar size={40} className="text-gray-600 mb-3" />
              <p className="text-sm text-gray-500 mb-1">Aucune donnée de citation disponible</p>
              <p className="text-xs text-gray-600">Configurez vos requêtes cibles et lancez une vérification.</p>
            </div>
          )}
        </div>
      </div>

      {/* Zone 4 : Dernières détections */}
      <div className="ninja-card rounded-2xl border border-white/[0.08] mb-8 overflow-hidden">
        <div className="p-6 border-b border-white/[0.08] flex justify-between items-center bg-white/[0.04]">
          <h3 className="font-bold text-white flex items-center gap-2">
            <Clock size={18} className="text-gray-500" />
            Dernières citations détectées
          </h3>
          <span className="text-xs text-gray-500">{recentCitations.length} résultat{recentCitations.length > 1 ? 's' : ''}</span>
        </div>

        {recentCitations.length > 0 ? (
          <div className="divide-y divide-white/5">
            {recentCitations.map((check) => {
              const meta = ENGINE_META[check.engine];
              return (
                <div key={check.id} className="px-6 py-4 hover:bg-white/[0.02] transition-colors">
                  <div className="flex items-start gap-3">
                    <span className={`text-xs font-medium px-2 py-1 rounded-full ${meta.bgClass} ${meta.textClass} shrink-0 mt-0.5`}>
                      {meta.icon} {meta.name}
                    </span>
                    <div className="flex-1 min-w-0">
                      <p className="text-sm text-white truncate">&quot;{check.promptSent}&quot;</p>
                      <div className="flex items-center gap-3 mt-1">
                        <span className="text-xs text-gray-500">
                          Score: <span className="text-white font-medium">{check.detection.citationScore}</span>
                        </span>
                        <span className="text-xs text-gray-600">
                          {check.detection.positionInResponse === 'first_paragraph' ? 'Premier paragraphe' :
                           check.detection.positionInResponse === 'middle' ? 'Milieu de réponse' :
                           check.detection.positionInResponse === 'end' ? 'Fin de réponse' : 'Footnote'}
                        </span>
                        <span className={`text-xs ${
                          check.detection.sentiment === 'positive' ? 'text-green-400' :
                          check.detection.sentiment === 'negative' ? 'text-red-400' : 'text-gray-500'
                        }`}>
                          {check.detection.sentiment === 'positive' ? '👍 Positif' :
                           check.detection.sentiment === 'negative' ? '👎 Négatif' : '🔘 Neutre'}
                        </span>
                      </div>
                    </div>
                    <span className="text-[10px] text-gray-600 shrink-0">
                      {new Date(check.createdAt).toLocaleDateString()}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <div className="px-6 py-10 text-center text-gray-500 text-sm">
            Aucune citation détectée pour le moment. Lancez une vérification pour commencer.
          </div>
        )}
      </div>

      {/* Zone 5 : Actions */}
      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <button
          onClick={handleRunVerification}
          disabled={isRunning || queries.length === 0}
          className="ninja-card p-5 rounded-2xl border border-cyan-500/20 hover:border-cyan-500/40 transition-all flex items-center gap-4 group disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <div className="w-10 h-10 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-400 group-hover:scale-110 transition-transform">
            <Play size={18} />
          </div>
          <div className="text-left">
            <p className="text-sm font-bold text-white">
              {isRunning ? `Vérification en cours (${progress.current}/${progress.total})` : 'Lancer une vérification'}
            </p>
            <p className="text-xs text-gray-500">
              {queries.filter(q => q.isActive).length} requêtes actives
            </p>
          </div>
        </button>

        <button
          onClick={() => onNavigate('tracked-queries')}
          className="ninja-card p-5 rounded-2xl border border-white/[0.08] hover:border-purple-500/30 transition-all flex items-center gap-4 group"
        >
          <div className="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center text-purple-400 group-hover:scale-110 transition-transform">
            <Target size={18} />
          </div>
          <div className="text-left">
            <p className="text-sm font-bold text-white">Gérer les requêtes</p>
            <p className="text-xs text-gray-500">{queries.length} requêtes configurées</p>
          </div>
        </button>

        <button
          onClick={() => onNavigate('benchmark')}
          className="ninja-card p-5 rounded-2xl border border-white/[0.08] hover:border-yellow-500/30 transition-all flex items-center gap-4 group"
        >
          <div className="w-10 h-10 rounded-full bg-yellow-500/20 flex items-center justify-center text-yellow-400 group-hover:scale-110 transition-transform">
            <Trophy size={18} />
          </div>
          <div className="text-left">
            <p className="text-sm font-bold text-white">Voir le benchmark</p>
            <p className="text-xs text-gray-500">Comparatif concurrentiel</p>
          </div>
        </button>
      </div>
    </div>
  );
};

export default CitationDashboardPage;
