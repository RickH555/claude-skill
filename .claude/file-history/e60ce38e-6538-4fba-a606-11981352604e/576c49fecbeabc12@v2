import { authenticateRequest, corsHeaders, createAdminClient, enforceRateLimit, escapeHtml, haversineKm, jsonResponse, logAutomationEvent, parseJsonBody } from '../_shared/common.ts';

type Heat = 'burning' | 'hot' | 'warm' | 'cold';

interface DistributePayload {
  prospect_id: string;
}

interface ProspectRow {
  id: string;
  sector_id: string;
  score: number;
  heat: Heat;
  signal: string;
  name: string;
  location: string | null;
  contact_email: string | null;
  approach_message: string | null;
  location_lat: number | null;
  location_lng: number | null;
}

interface ProfileRow {
  id: string;
  full_name: string | null;
  sector_id: string | null;
  target_sector_ids: string[] | null;
  min_score: number;
  location_lat: number | null;
  location_lng: number | null;
  geo_radius_km: number;
  credits_balance: number;
  credits_total_spent: number;
  credit_cost_per_prospect: number;
  low_credit_threshold: number;
  burning_only_alerts: boolean;
  auto_recharge_enabled: boolean;
  auto_recharge_trigger_threshold: number;
  automation_enabled: boolean;
  automation_send_email: boolean;
  automation_min_score: number;
  automation_daily_email_limit: number;
  automation_emails_sent_today: number;
  automation_email_day: string | null;
  automation_email_subject_template: string;
  automation_email_signature: string | null;
}

interface AutoRechargeResponse {
  recharged?: boolean;
  credits_balance?: number;
  credits_added?: number;
  reason?: string;
  error?: string;
}

const currentUtcDate = (): string => new Date().toISOString().slice(0, 10);

const applySubjectTemplate = (
  template: string,
  prospect: ProspectRow,
): string => {
  const safeTemplate = template.trim() || 'Opportunite detectee pour {{prospect_name}}';
  return safeTemplate
    .replaceAll('{{prospect_name}}', prospect.name)
    .replaceAll('{{signal}}', prospect.signal)
    .replaceAll('{{score}}', String(prospect.score))
    .slice(0, 180);
};

const sendAutomatedProspectEmail = async (
  profile: ProfileRow,
  prospect: ProspectRow,
): Promise<boolean> => {
  const resendApiKey = Deno.env.get('RESEND_API_KEY');
  const fromEmail = Deno.env.get('RESEND_FROM_EMAIL') ?? 'LeadRadar <alerts@leadradar.io>';
  if (!resendApiKey) {
    return false;
  }
  if (!prospect.contact_email) {
    return false;
  }

  const subject = applySubjectTemplate(profile.automation_email_subject_template, prospect);
  const signature =
    profile.automation_email_signature?.trim() ||
    `Cordialement,\n${profile.full_name ?? 'Votre equipe'}\nvia LeadRadar`;
  const bodyMessage =
    prospect.approach_message?.trim() ||
    `Bonjour,\n\nNous avons detecte un signal interessant: ${prospect.signal}.\n\nSouhaitez-vous un echange rapide ?`;

  const html = `
  <div style="font-family:Arial,Helvetica,sans-serif;background:#0B0F1A;padding:24px;color:#E2E8F0;">
    <table role="presentation" width="100%" style="max-width:640px;margin:0 auto;background:#111827;border:1px solid #1E293B;border-radius:12px;">
      <tr><td style="padding:24px;">
        <h1 style="margin:0 0 8px 0;color:#10B981;font-size:22px;">LeadRadar</h1>
        <h2 style="margin:0 0 12px 0;color:#F8FAFC;font-size:18px;">${escapeHtml(subject)}</h2>
        <p style="margin:0 0 16px 0;line-height:1.6;color:#CBD5E1;white-space:pre-line;">${escapeHtml(bodyMessage)}</p>
        <p style="margin:0;line-height:1.5;color:#94A3B8;white-space:pre-line;">${escapeHtml(signature)}</p>
      </td></tr>
    </table>
  </div>`;

  const response = await fetch('https://api.resend.com/emails', {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${resendApiKey}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      from: fromEmail,
      to: [prospect.contact_email],
      subject,
      html,
    }),
  });

  return response.ok;
};

const attemptAutoRecharge = async (
  supabaseUrl: string,
  serviceRoleKey: string,
  profileId: string,
  minimumRequiredCredits: number,
): Promise<AutoRechargeResponse> => {
  const response = await fetch(`${supabaseUrl}/functions/v1/auto-recharge`, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${serviceRoleKey}`,
      apikey: serviceRoleKey,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      user_id: profileId,
      minimum_required_credits: minimumRequiredCredits,
      reason: 'distribution_low_balance',
    }),
  });

  const data = (await response.json()) as AutoRechargeResponse;
  if (!response.ok) {
    return {
      recharged: false,
      error: data.error ?? 'Erreur auto-recharge',
    };
  }
  return data;
};

/**
 * Distribution user-level d'un prospect nouvellement analyse.
 * Chaque assignment consomme des credits prepaid.
 */
Deno.serve(async (request: Request) => {
  if (request.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders });
  }

  const ip = request.headers.get('x-forwarded-for') ?? 'anonymous';
  try {
    enforceRateLimit(`distribute:${ip}`, 100);
    if (request.method !== 'POST') {
      return jsonResponse({ error: 'Method not allowed' }, 405);
    }
    // Auth: service role (appel interne depuis analyze) ou JWT utilisateur
    const auth = await authenticateRequest(request);
    if (auth.error) return auth.error;

    const payload = await parseJsonBody<DistributePayload>(request);
    if (!payload.prospect_id) {
      return jsonResponse({ error: 'prospect_id requis' }, 400);
    }

    const admin = createAdminClient();
    const { data: prospect, error: prospectError } = await admin
      .from('prospects')
      .select('id, sector_id, score, heat, signal, name, location, contact_email, approach_message, location_lat, location_lng')
      .eq('id', payload.prospect_id)
      .single<ProspectRow>();
    if (prospectError || !prospect) {
      throw new Error('Prospect introuvable');
    }
    const safeSectorFilterValue = prospect.sector_id.replaceAll(',', '').replaceAll('{', '').replaceAll('}', '');

    const { data: profiles, error: profilesError } = await admin
      .from('profiles')
      .select(
        'id, full_name, sector_id, target_sector_ids, min_score, location_lat, location_lng, geo_radius_km, credits_balance, credits_total_spent, credit_cost_per_prospect, low_credit_threshold, burning_only_alerts, auto_recharge_enabled, auto_recharge_trigger_threshold, automation_enabled, automation_send_email, automation_min_score, automation_daily_email_limit, automation_emails_sent_today, automation_email_day, automation_email_subject_template, automation_email_signature',
      )
      .or(`sector_id.eq.${safeSectorFilterValue},target_sector_ids.cs.{${safeSectorFilterValue}}`);
    if (profilesError) {
      throw profilesError;
    }

    const supabaseUrl = Deno.env.get('SUPABASE_URL');
    const serviceRoleKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY');
    if (!supabaseUrl || !serviceRoleKey) {
      throw new Error('Variables Supabase manquantes');
    }

    let assigned = 0;
    let skipped = 0;
    let creditWarnings = 0;
    let autoRecharged = 0;
    let autoEmailsSent = 0;
    const nowIso = new Date().toISOString();
    const today = currentUtcDate();

    for (const profile of (profiles ?? []) as ProfileRow[]) {
      const targetSectorIds = Array.isArray(profile.target_sector_ids) ? profile.target_sector_ids : [];
      const sectorMatch =
        targetSectorIds.length > 0 ? targetSectorIds.includes(prospect.sector_id) : profile.sector_id === prospect.sector_id;
      if (!sectorMatch) {
        skipped += 1;
        continue;
      }

      if (prospect.score < profile.min_score) {
        skipped += 1;
        continue;
      }

      if (
        profile.location_lat !== null &&
        profile.location_lng !== null &&
        prospect.location_lat !== null &&
        prospect.location_lng !== null
      ) {
        const distance = haversineKm(profile.location_lat, profile.location_lng, prospect.location_lat, prospect.location_lng);
        if (distance > profile.geo_radius_km) {
          skipped += 1;
          continue;
        }
      }

      const creditCost = Math.max(1, profile.credit_cost_per_prospect || 1);
      let currentBalance = profile.credits_balance;

      if (currentBalance < creditCost && profile.auto_recharge_enabled) {
        const rechargeResponse = await attemptAutoRecharge(
          supabaseUrl,
          serviceRoleKey,
          profile.id,
          Math.max(creditCost, profile.auto_recharge_trigger_threshold),
        );
        if (rechargeResponse.recharged && typeof rechargeResponse.credits_balance === 'number') {
          currentBalance = rechargeResponse.credits_balance;
          autoRecharged += 1;
        } else if (rechargeResponse.error) {
          await logAutomationEvent('error', {
            stage: 'distribute-auto-recharge',
            user_id: profile.id,
            reason: rechargeResponse.error,
          });
        }
      }

      if (currentBalance < creditCost) {
        creditWarnings += 1;
        await fetch(`${supabaseUrl}/functions/v1/notify`, {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${serviceRoleKey}`,
            apikey: serviceRoleKey,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            user_id: profile.id,
            prospect_id: null,
            type: 'credit_warning',
          }),
        });
        continue;
      }

      const { data: insertedAssignment, error: assignmentError } = await admin
        .from('prospect_assignments')
        .insert({
          prospect_id: prospect.id,
          user_id: profile.id,
          status: 'new',
          created_at: nowIso,
          updated_at: nowIso,
        })
        .select('id')
        .maybeSingle<{ id: string }>();

      if (assignmentError) {
        if (!assignmentError.message.toLowerCase().includes('duplicate')) {
          await logAutomationEvent('error', {
            stage: 'distribute-assignment',
            user_id: profile.id,
            reason: assignmentError.message,
          });
        }
        continue;
      }

      if (!insertedAssignment?.id) {
        continue;
      }

      assigned += 1;
      const nextBalance = Math.max(0, currentBalance - creditCost);
      const nextSpent = profile.credits_total_spent + creditCost;

      let nextAutomationDay = profile.automation_email_day ?? today;
      let nextAutomationCount = profile.automation_emails_sent_today;
      if (nextAutomationDay !== today) {
        nextAutomationDay = today;
        nextAutomationCount = 0;
      }

      let emailSent = false;
      const canAutoEmail =
        profile.automation_enabled &&
        profile.automation_send_email &&
        Boolean(prospect.contact_email) &&
        prospect.score >= profile.automation_min_score &&
        nextAutomationCount < profile.automation_daily_email_limit;

      if (canAutoEmail) {
        emailSent = await sendAutomatedProspectEmail(profile, prospect);
        if (emailSent) {
          nextAutomationCount += 1;
          autoEmailsSent += 1;
          await logAutomationEvent('notification_sent', {
            stage: 'automation_email',
            user_id: profile.id,
            prospect_id: prospect.id,
            assignment_id: insertedAssignment.id,
            to: prospect.contact_email,
          });

          await admin
            .from('prospect_assignments')
            .update({
              status: 'contacted',
              contacted_at: nowIso,
              updated_at: nowIso,
            })
            .eq('id', insertedAssignment.id);
        }
      }

      const { error: debitError } = await admin
        .from('profiles')
        .update({
          credits_balance: nextBalance,
          credits_total_spent: nextSpent,
          automation_email_day: nextAutomationDay,
          automation_emails_sent_today: nextAutomationCount,
          updated_at: nowIso,
        })
        .eq('id', profile.id);

      if (debitError) {
        await logAutomationEvent('error', {
          stage: 'distribute-debit',
          user_id: profile.id,
          reason: debitError.message,
        });
      } else {
        await admin.from('credit_transactions').insert({
          user_id: profile.id,
          transaction_type: 'consume',
          credits_delta: -creditCost,
          credits_balance_after: nextBalance,
          description: `Generation fiche prospect ${prospect.id}`,
          metadata_json: {
            prospect_id: prospect.id,
            assignment_id: insertedAssignment.id,
          },
        });
      }

      const notificationType = prospect.heat === 'burning' ? 'burning_alert' : 'new_prospect';
      const shouldNotifyNow = prospect.heat === 'burning' || !profile.burning_only_alerts;
      if (shouldNotifyNow) {
        await fetch(`${supabaseUrl}/functions/v1/notify`, {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${serviceRoleKey}`,
            apikey: serviceRoleKey,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            user_id: profile.id,
            prospect_id: prospect.id,
            type: notificationType,
          }),
        });
      }

      if (nextBalance <= profile.low_credit_threshold) {
        creditWarnings += 1;
        await fetch(`${supabaseUrl}/functions/v1/notify`, {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${serviceRoleKey}`,
            apikey: serviceRoleKey,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            user_id: profile.id,
            prospect_id: prospect.id,
            type: 'credit_warning',
          }),
        });
      }
    }

    await logAutomationEvent('scan_completed', {
      stage: 'distribution',
      prospect_id: prospect.id,
      assigned,
      skipped,
      credit_warnings: creditWarnings,
      auto_recharged: autoRecharged,
      automation_emails_sent: autoEmailsSent,
    });

    return jsonResponse({
      prospect_id: prospect.id,
      assigned,
      skipped,
      credit_warnings: creditWarnings,
      auto_recharged: autoRecharged,
      automation_emails_sent: autoEmailsSent,
    });
  } catch (error) {
    await logAutomationEvent('error', {
      stage: 'distribute',
      reason: error instanceof Error ? error.message : 'unknown',
    });
    return jsonResponse({ error: error instanceof Error ? error.message : 'Erreur distribute' }, 500);
  }
});
