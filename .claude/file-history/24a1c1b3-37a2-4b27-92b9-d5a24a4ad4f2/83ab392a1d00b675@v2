          {currentView === 'bot-tracking' && (
            <BotTracking
              key={`bot-tracking-${refreshKey}`}
              onBack={goBack}
              user={user}
            />
          )}

          {/* Placeholders pour les nouvelles sections */}
          {currentView === 'messages' && <PlaceholderView title="Messagerie" icon={MessageSquare} />}
          {currentView === 'alerts' && <PlaceholderView title="Alertes AEO" icon={Bell} />}
