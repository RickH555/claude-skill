  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: #06060F;
      color: #C8C5D6;
      line-height: 1.65;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; cursor: pointer; border: none; background: none; }
    ul { list-style: none; }
    img, svg { display: block; max-width: 100%; }

    ::selection { background: rgba(139,92,246,0.35); color: #fff; }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(139,92,246,0.25); border-radius: 10px; }

    /* ── TOKENS ── */
    :root {
      --bg: #06060F;
      --text: #E4E2F0;
      --text-dim: #9794A8;
      --text-faint: #5E5C6E;
      --accent: #8B5CF6;
      --accent-light: #A78BFA;
      --accent-glow: rgba(139,92,246,0.25);
      --blue: #3B82F6;
      --emerald: #34D399;
      --rose: #F472B6;
      --glass-bg: rgba(255,255,255,0.04);
      --glass-bg-hover: rgba(255,255,255,0.07);
      --glass-border: rgba(255,255,255,0.08);
      --glass-border-hover: rgba(255,255,255,0.14);
      --glass-strong: rgba(255,255,255,0.06);
      --glass-strong-border: rgba(255,255,255,0.12);
      --radius: 20px;
      --radius-sm: 14px;
      --radius-full: 100px;
      --blur: blur(20px);
      --blur-strong: blur(32px);
      --max-w: 1100px;
      --font-display: 'Fraunces', Georgia, serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }

    /* ── GLASS UTILITIES ── */
    .glass {
      background: var(--glass-bg);
      backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
    }
    .glass-strong {
      background: var(--glass-strong);
      backdrop-filter: var(--blur-strong); -webkit-backdrop-filter: var(--blur-strong);
      border: 1px solid var(--glass-strong-border);
      border-radius: var(--radius);
    }
    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      transition: all 0.35s ease;
    }
    .glass-card:hover {
      background: var(--glass-bg-hover);
      border-color: var(--glass-border-hover);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.25), 0 0 0 1px rgba(139,92,246,0.06);
    }

    /* ── ORB BACKGROUNDS ── */
    .orb {
      position: absolute; border-radius: 50%; pointer-events: none;
      filter: blur(100px); opacity: 0.35;
    }

    /* ── ANIMATIONS ── */
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }

    .anim { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .anim.slide-left { transform: translateX(-36px); }
    .anim.slide-right { transform: translateX(36px); }
    .anim.scale { transform: scale(0.96); }
    .anim.visible { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.08s; } .d2 { transition-delay: 0.16s; } .d3 { transition-delay: 0.24s; }
    .d4 { transition-delay: 0.32s; } .d5 { transition-delay: 0.4s; } .d6 { transition-delay: 0.48s; }

    /* ── NAV ── */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 16px 24px; transition: all 0.4s; }
    .nav.scrolled .nav-inner { background: rgba(6,6,15,0.7); backdrop-filter: var(--blur-strong); border-color: var(--glass-border); }
    .nav-inner {
      max-width: var(--max-w); margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 20px; border-radius: var(--radius-full);
      border: 1px solid transparent; transition: all 0.4s;
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 15px; color: var(--text); }
    .nav-logo-icon {
      width: 30px; height: 30px; border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), var(--blue));
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 800; color: #fff;
    }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-link { font-size: 13px; font-weight: 500; color: var(--text-dim); transition: color 0.2s; }
    .nav-link:hover { color: var(--text); }
    .nav-cta {
      font-size: 13px; font-weight: 600; color: #fff; padding: 8px 20px;
      border-radius: var(--radius-full);
      background: linear-gradient(135deg, var(--accent), var(--blue));
      box-shadow: 0 0 20px var(--accent-glow);
      transition: all 0.25s;
    }
    .nav-cta:hover { transform: scale(1.04); box-shadow: 0 0 28px rgba(139,92,246,0.35); }
    .nav-mobile { display: none; color: var(--text-dim); font-size: 13px; font-weight: 600; }
    .mobile-menu {
      display: none; position: fixed; top: 72px; left: 16px; right: 16px;
      background: rgba(6,6,15,0.92); backdrop-filter: var(--blur-strong);
      border: 1px solid var(--glass-border); border-radius: var(--radius);
      padding: 24px; flex-direction: column; gap: 16px; z-index: 99;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 15px; color: var(--text-dim); padding: 6px 0; }
    .mobile-menu .nav-cta { text-align: center; margin-top: 8px; display: block; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-mobile { display: block; }
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      padding: 140px 24px 80px; position: relative; overflow: hidden;
    }
    .hero-orb-1 { width: 600px; height: 600px; background: rgba(139,92,246,0.18); top: -10%; left: 20%; }
    .hero-orb-2 { width: 500px; height: 500px; background: rgba(59,130,246,0.12); top: 20%; right: 10%; }
    .hero-orb-3 { width: 400px; height: 400px; background: rgba(244,114,182,0.08); bottom: 10%; left: 40%; }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 32px 32px; mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 20%, transparent 70%);
    }

    .hero-content { position: relative; z-index: 2; max-width: 820px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 7px 16px; border-radius: var(--radius-full);
      background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.2);
      font-size: 13px; font-weight: 500; color: var(--accent-light);
    }
    .hero-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--emerald); box-shadow: 0 0 10px rgba(52,211,153,0.6); }
    .hero h1 {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(34px, 5.5vw, 68px); line-height: 1.08;
      letter-spacing: -0.03em; color: #fff; margin-top: 32px;
    }
    .hero .gradient {
      background: linear-gradient(135deg, #A78BFA, #60A5FA, #34D399);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    .hero-sub {
      font-size: clamp(15px, 1.8vw, 18px); color: var(--text-dim);
      max-width: 580px; margin: 24px auto 0; line-height: 1.75;
    }
    .hero-ctas { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 36px; flex-wrap: wrap; }
    .btn-glow {
      font-size: 15px; font-weight: 600; color: #fff; padding: 14px 32px;
      border-radius: var(--radius-sm);
      background: linear-gradient(135deg, var(--accent), var(--blue));
      box-shadow: 0 0 24px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,0.1);
      transition: all 0.25s;
    }
    .btn-glow:hover { transform: translateY(-1px); box-shadow: 0 0 36px rgba(139,92,246,0.4); }
    .btn-ghost {
      font-size: 15px; font-weight: 500; color: var(--text-dim); padding: 14px 24px;
      border-radius: var(--radius-sm); border: 1px solid var(--glass-border);
      backdrop-filter: var(--blur); transition: all 0.25s;
    }
    .btn-ghost:hover { color: var(--text); border-color: var(--glass-border-hover); background: var(--glass-bg); }
    .btn-ghost .arr { display: inline-block; transition: transform 0.2s; }
    .btn-ghost:hover .arr { transform: translateX(3px); }

    .hero-trust {
      display: flex; align-items: center; justify-content: center; gap: 20px;
      margin-top: 32px; flex-wrap: wrap;
    }
    .hero-trust span { font-size: 13px; color: var(--text-faint); }
    .hero-trust .ck { color: var(--emerald); }

    /* ── MOCKUP ── */
    .mockup-section { padding: 0 24px; margin-top: -20px; position: relative; z-index: 3; }
    .mockup {
      max-width: 920px; margin: 0 auto;
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px; overflow: hidden;
      box-shadow: 0 32px 80px -20px rgba(0,0,0,0.5), 0 0 0 1px rgba(139,92,246,0.04);
    }
    .mockup-bar { display: flex; align-items: center; gap: 7px; padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: rgba(248,113,113,0.5); } .dot-y { background: rgba(250,204,21,0.5); } .dot-g { background: rgba(74,222,128,0.5); }
    .mockup-url { font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); margin-left: 10px; }
    .mockup-body { padding: 20px; }
    .m-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .m-stat { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; padding: 16px; }
    .m-stat-label { font-size: 11px; color: var(--text-faint); }
    .m-stat-val { font-family: var(--font-mono); font-size: 26px; font-weight: 700; color: #fff; margin-top: 4px; }
    .m-stat-val small { font-size: 14px; color: var(--text-faint); }
    .m-stat-delta { font-size: 11px; color: var(--emerald); margin-top: 3px; }
    .m-engines { margin-top: 12px; }
    .m-engine { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .m-engine:last-child { border: none; }
    .m-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .m-name { font-size: 12px; font-weight: 600; color: var(--text); width: 80px; flex-shrink: 0; }
    .m-track { flex: 1; height: 5px; border-radius: 3px; background: rgba(255,255,255,0.04); overflow: hidden; }
    .m-fill { height: 100%; border-radius: 3px; width: 0; transition: width 1.4s cubic-bezier(0.16,1,0.3,1); }
    .m-score { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--text-dim); width: 46px; text-align: right; flex-shrink: 0; }

    @media (max-width: 640px) { .m-grid { grid-template-columns: 1fr; } }

    /* ── SECTION COMMONS ── */
    .section { padding: 100px 24px; position: relative; }
    .section-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent-light); text-align: center; }
    .section-title {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(28px, 4vw, 46px); color: #fff;
      text-align: center; letter-spacing: -0.02em; margin-top: 12px; line-height: 1.15;
    }
    .section-sub { font-size: 16px; color: var(--text-dim); text-align: center; max-width: 600px; margin: 16px auto 0; line-height: 1.75; }

    /* ── ERA SECTION (SEO vs AEO) ── */
    .era-section { padding: 120px 24px; position: relative; overflow: hidden; }
    .era-orb { width: 500px; height: 500px; background: rgba(59,130,246,0.1); bottom: -20%; right: 10%; }
    .era-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: var(--max-w); margin: 48px auto 0; }
    .era-card { padding: 32px; position: relative; overflow: hidden; }
    .era-card .era-label {
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
      padding: 5px 12px; border-radius: var(--radius-full); display: inline-block; margin-bottom: 16px;
    }
    .era-card.old .era-label { background: rgba(255,255,255,0.06); color: var(--text-faint); }
    .era-card.new .era-label { background: rgba(139,92,246,0.15); color: var(--accent-light); }
    .era-card h3 { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 12px; }
    .era-card.old h3 { color: var(--text-dim); }
    .era-card p { font-size: 15px; color: var(--text-dim); line-height: 1.7; }
    .era-card ul { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .era-card li { display: flex; gap: 10px; font-size: 14px; color: var(--text-dim); align-items: flex-start; }
    .era-card.old li .ico { color: var(--text-faint); }
    .era-card.new li .ico { color: var(--accent-light); }
    .era-divider {
      position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%);
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(139,92,246,0.15); border: 1px solid rgba(139,92,246,0.25);
      display: flex; align-items: center; justify-content: center;
      color: var(--accent-light); font-size: 18px; z-index: 2;
    }

    @media (max-width: 768px) {
      .era-grid { grid-template-columns: 1fr; }
      .era-divider { position: relative; left: auto; top: auto; transform: none; margin: 12px auto; }
    }

    /* ── TIMING / WHY NOW ── */
    .timing-section { padding: 100px 24px; overflow: hidden; position: relative; }
    .timing-orb { width: 450px; height: 450px; background: rgba(244,114,182,0.08); top: 20%; left: -10%; }
    .timing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: var(--max-w); margin: 48px auto 0; }
    .timing-card { padding: 28px; }
    .timing-icon {
      width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
      font-size: 20px; margin-bottom: 16px;
    }
    .timing-card h3 { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .timing-card p { font-size: 14px; color: var(--text-dim); line-height: 1.7; }

    @media (max-width: 768px) { .timing-grid { grid-template-columns: 1fr; } }

    /* ── FEATURES (3 piliers) ── */
    .features-section { padding: 100px 24px; position: relative; overflow: hidden; }
    .features-orb { width: 500px; height: 500px; background: rgba(139,92,246,0.12); top: 30%; right: -15%; }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: var(--max-w); margin: 48px auto 0; }
    .f-card { padding: 32px; }
    .f-icon {
      width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: 20px;
    }
    .f-icon.v { background: rgba(139,92,246,0.12); }
    .f-icon.b { background: rgba(59,130,246,0.12); }
    .f-icon.e { background: rgba(52,211,153,0.12); }
    .f-card h3 { font-size: 18px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .f-card p { font-size: 14px; color: var(--text-dim); line-height: 1.7; }

    @media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }

    /* ── STEPS ── */
    .steps-section { padding: 100px 24px; position: relative; }
    .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; max-width: var(--max-w); margin: 48px auto 0; }
    .step-card { padding: 28px; text-align: center; }
    .step-num {
      font-family: var(--font-mono); font-size: 32px; font-weight: 700;
      background: linear-gradient(135deg, var(--accent), var(--blue));
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    .step-card h3 { font-size: 16px; font-weight: 600; color: var(--text); margin-top: 12px; }
    .step-card p { font-size: 13px; color: var(--text-dim); margin-top: 8px; line-height: 1.65; }
    .step-connector { display: none; align-self: center; text-align: center; color: var(--text-faint); font-size: 16px; }

    @media (min-width: 769px) { .step-connector { display: block; } }
    @media (max-width: 768px) {
      .steps-grid { grid-template-columns: 1fr; }
      .step-connector { display: none; }
    }

    /* ── SCORING ── */
    .scoring-section { padding: 100px 24px; position: relative; overflow: hidden; }
    .scoring-orb { width: 400px; height: 400px; background: rgba(52,211,153,0.08); bottom: 0; left: 20%; }
    .scoring-card { max-width: 680px; margin: 48px auto 0; padding: 32px; }
    .sc-row { display: flex; align-items: center; gap: 14px; padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .sc-row:last-of-type { border: none; }
    .sc-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .sc-name { font-size: 14px; font-weight: 600; color: var(--text); width: 96px; flex-shrink: 0; }
    .sc-track { flex: 1; height: 7px; border-radius: 4px; background: rgba(255,255,255,0.05); overflow: hidden; }
    .sc-fill { height: 100%; border-radius: 4px; width: 0; transition: width 1.4s cubic-bezier(0.16,1,0.3,1); }
    .sc-val { font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--text); width: 58px; text-align: right; flex-shrink: 0; }
    .sc-hint { font-size: 12px; color: var(--text-faint); padding-left: 120px; padding-bottom: 8px; }

    @media (max-width: 640px) {
      .sc-row { flex-wrap: wrap; }
      .sc-track { width: 100%; order: 5; }
      .sc-hint { padding-left: 0; }
    }

    /* ── METRICS ── */
    .metrics-section { padding: 80px 24px; }
    .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; max-width: var(--max-w); margin: 0 auto; }
    .metric { text-align: center; padding: 28px; }
    .metric-val { font-family: var(--font-mono); font-size: clamp(30px, 4vw, 44px); font-weight: 700; color: #fff; }
    .metric-val small { font-size: 0.5em; color: var(--text-faint); }
    .metric-label { font-size: 12px; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }

    @media (max-width: 640px) { .metrics-grid { grid-template-columns: repeat(2, 1fr); } }

    /* ── PRICING ── */
    .pricing-section { padding: 100px 24px; position: relative; overflow: hidden; }
    .pricing-orb { width: 500px; height: 500px; background: rgba(139,92,246,0.1); top: 40%; left: 50%; transform: translateX(-50%); }
    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: var(--max-w); margin: 48px auto 0; align-items: start; }
    .p-card { padding: 32px; position: relative; }
    .p-card.featured {
      background: rgba(139,92,246,0.06);
      border-color: rgba(139,92,246,0.2);
      box-shadow: 0 0 40px rgba(139,92,246,0.08);
    }
    .p-popular {
      position: absolute; top: -11px; left: 50%; transform: translateX(-50%);
