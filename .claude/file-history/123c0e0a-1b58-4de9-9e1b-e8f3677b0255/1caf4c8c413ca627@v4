// ---- Usage Data ----

export function getUsageKPIs(): ApiUsageKPI {
  return {
    requestsPerDay: Math.floor(120 + Math.random() * 80),
    errorRate: +(1.2 + Math.random() * 0.8).toFixed(1),
    avgLatency: Math.floor(180 + Math.random() * 60),
  }
}

export function getUsageHistory(): ApiUsageDay[] {
  const data: ApiUsageDay[] = []
  const now = new Date()
  for (let i = 29; i >= 0; i--) {
    const d = new Date(now)
    d.setDate(d.getDate() - i)
    data.push({
      date: d.toISOString().slice(0, 10),
      success: Math.floor(100 + Math.random() * 150),
      errors: Math.floor(Math.random() * 15),
    })
  }
  return data
}

