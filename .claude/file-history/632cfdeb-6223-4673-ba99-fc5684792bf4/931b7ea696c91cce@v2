import { GoogleGenAI } from "@google/genai"
import { calculateAiVisibilityScore, type ScoringResult } from "@/lib/scoring"

// ============================================================
// AI Monitoring Service
// Simulates queries to multiple AI engines via Gemini
// Each engine is simulated with a different system prompt personality
// ============================================================

export type AIEngine = "ChatGPT" | "Perplexity" | "Claude" | "Gemini" | "Copilot"

export interface MonitoringPrompt {
  text: string
  category?: string
  language?: "fr" | "en" | "es"
}

export interface ProjectContext {
  brandName: string
  domain: string
  industry: string
  services: string[]
  competitors: string[]
  keywords: string[]
}

export interface MonitoringResult {
  engine: AIEngine
  prompt: string
  response: string
  score: number
  resultType: "citation" | "mention" | "none"
  brandMentioned: boolean
  urlMentioned: boolean
  competitorMentioned: boolean
  sentiment: "positive" | "neutral" | "negative"
  sentimentScore: number
  competitorsMentioned: string[]
}

export interface RunSummary {
  globalScore: number
  totalPrompts: number
  citationsFound: number
  mentionsFound: number
  engineScores: Record<AIEngine, { score: number; mentions: number; citations: number }>
  competitorComparison: Array<{ name: string; mentions: number; sentiment: number }>
  alerts: Array<{ severity: "critical" | "warning" | "info"; message: string; action: string }>
}

