import { useState, useEffect, useCallback } from 'react'
import { motion } from 'framer-motion'
import Card from '../../components/ui/Card.tsx'
import Button from '../../components/ui/Button.tsx'
import type { MonitoringSchedule, ScheduleFrequency, ScheduledScanResult } from '../../types/scheduling.ts'
import type { AdPlatform } from '../../types/retargeting.ts'
import type { RetargetingOpportunity } from '../../types/retargeting.ts'
import {
  getSchedules,
  createSchedule,
  toggleSchedule,
  deleteSchedule,
  getScanHistory,
  checkAndRunPendingScans,
  getFrequencyLabel,
  getFrequencyColor,
} from '../../services/scheduling.ts'
import {
  getAdConnections,
  connectAdPlatform,
  disconnectAdPlatform,
  generateOpportunities,
  estimateBudget,
  exportAudienceCSV,
  getPlatformLabel,
  getPlatformColor,
} from '../../services/retargeting.ts'

// ---- Local mock citations data ----

interface Citation {
  id: number
  model: string
  query: string
  cited: boolean
  date: string
  url?: string
}

const citations: Citation[] = [
  { id: 1, model: 'ChatGPT', query: 'Meilleur outil SEO IA', cited: true, date: '2025-01-15', url: 'https://citedby.ai/seo-tools' },
  { id: 2, model: 'Claude', query: 'Alternatives a Semrush', cited: true, date: '2025-01-14', url: 'https://citedby.ai/alternatives' },
  { id: 3, model: 'Perplexity', query: 'Outils de marketing digital', cited: false, date: '2025-01-13' },
  { id: 4, model: 'Gemini', query: 'Suivi de marque en ligne', cited: true, date: '2025-01-12', url: 'https://citedby.ai/brand-tracking' },
  { id: 5, model: 'ChatGPT', query: 'Visibilite marque IA', cited: false, date: '2025-01-11' },
  { id: 6, model: 'Copilot', query: 'AEO optimisation', cited: true, date: '2025-01-10', url: 'https://citedby.ai/aeo' },
]

type ResultTab = 'overview' | 'retargeting'

export default function MonitoringPage() {
  // ---- Scheduling State (F1) ----
  const [schedules, setSchedules] = useState<MonitoringSchedule[]>([])
  const [scanHistory, setScanHistory] = useState<ScheduledScanResult[]>([])
  const [schFreq, setSchFreq] = useState<ScheduleFrequency>('daily')
  const [schHour, setSchHour] = useState('09:00')
  const [schDay, setSchDay] = useState(1)
  const [schBrand, setSchBrand] = useState('')
  const [schUrl, setSchUrl] = useState('')
  const [schEmail, setSchEmail] = useState(false)

  // ---- Results Tab (F3 retargeting) ----
  const [resultTab, setResultTab] = useState<ResultTab>('overview')

  // ---- Retargeting State (F3) ----
  const [adConnections, setAdConnections] = useState(getAdConnections)
  const [adLoading, setAdLoading] = useState<string | null>(null)
  const [rtPlatform, setRtPlatform] = useState<AdPlatform>('google_ads')
  const [rtBudget, setRtBudget] = useState(50)
  const [expandedPixel, setExpandedPixel] = useState<string | null>(null)
  const [copiedPixel, setCopiedPixel] = useState<string | null>(null)

  const citedUrls = citations.filter((c) => c.cited && c.url).map((c) => c.url!)
  const opportunities: RetargetingOpportunity[] = generateOpportunities(citedUrls)
  const budget = estimateBudget(rtPlatform, rtBudget)

  const refreshSchedules = useCallback(() => {
    setSchedules(getSchedules())
    setScanHistory(getScanHistory())
  }, [])

  useEffect(() => {
    const results = checkAndRunPendingScans()
    if (results.length > 0) {
      console.log(`[Scheduling] ${results.length} scan(s) en retard execute(s)`)
    }
    refreshSchedules()
  }, [refreshSchedules])

  function handleCreateSchedule() {
    if (!schBrand.trim() || !schUrl.trim()) return
    createSchedule(
      schBrand.trim(),
      schUrl.trim(),
      schFreq,
      schHour,
      schEmail,
      schFreq === 'weekly' ? schDay : undefined,
      schFreq === 'monthly' ? schDay : undefined,
    )
    refreshSchedules()
    setSchBrand('')
    setSchUrl('')
  }

  function handleToggleSchedule(id: string) {
    toggleSchedule(id)
    refreshSchedules()
  }

  function handleDeleteSchedule(id: string) {
    deleteSchedule(id)
    refreshSchedules()
  }

  async function handleConnectAd(platform: AdPlatform) {
    setAdLoading(platform)
    await connectAdPlatform(platform)
    setAdConnections(getAdConnections())
    setAdLoading(null)
  }

  function handleDisconnectAd(platform: AdPlatform) {
    disconnectAdPlatform(platform)
    setAdConnections(getAdConnections())
  }

  function handleCopyPixel(id: string, code: string) {
    navigator.clipboard.writeText(code)
    setCopiedPixel(id)
    setTimeout(() => setCopiedPixel(null), 2000)
  }

  return (
    <div className="space-y-6">
      <h2 className="text-2xl font-bold text-gray-900">Monitoring</h2>

      {/* ============ RESULTS TABLE with Tab Bar ============ */}
      <div className="rounded-xl bg-white shadow-sm">
        {/* Tab Bar */}
        <div className="flex border-b border-gray-200">
          <button
            onClick={() => setResultTab('overview')}
            className={`px-6 py-3 text-sm font-medium transition-colors ${
              resultTab === 'overview'
                ? 'border-b-2 border-blue-600 text-blue-600'
                : 'text-gray-500 hover:text-gray-700'
            }`}
          >
            Vue d'ensemble
          </button>
          <button
            onClick={() => setResultTab('retargeting')}
            className={`px-6 py-3 text-sm font-medium transition-colors ${
              resultTab === 'retargeting'
                ? 'border-b-2 border-blue-600 text-blue-600'
                : 'text-gray-500 hover:text-gray-700'
            }`}
          >
            Retargeting IA
          </button>
        </div>

        {/* Overview Tab */}
        {resultTab === 'overview' && (
          <div className="overflow-x-auto">
            <table className="w-full text-left text-sm">
              <thead className="border-b border-gray-200 bg-gray-50">
                <tr>
                  <th className="px-6 py-3 font-medium text-gray-600">Modele IA</th>
                  <th className="px-6 py-3 font-medium text-gray-600">Requete</th>
                  <th className="px-6 py-3 font-medium text-gray-600">Cite</th>
                  <th className="px-6 py-3 font-medium text-gray-600">Date</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-gray-100">
                {citations.map((citation) => (
                  <tr key={citation.id} className="hover:bg-gray-50">
                    <td className="px-6 py-4 font-medium text-gray-900">{citation.model}</td>
                    <td className="px-6 py-4 text-gray-700">{citation.query}</td>
                    <td className="px-6 py-4">
                      <span
                        className={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                          citation.cited
                            ? 'bg-green-100 text-green-700'
                            : 'bg-red-100 text-red-700'
                        }`}
                      >
                        {citation.cited ? 'Oui' : 'Non'}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-gray-500">{citation.date}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {/* Retargeting Tab (F3) */}
        {resultTab === 'retargeting' && (
          <div className="space-y-6 p-6">
            {/* Ad Platform Connections */}
            <div>
              <h3 className="mb-3 text-sm font-semibold text-gray-900">Connexions publicitaires</h3>
              <div className="grid grid-cols-1 gap-3 md:grid-cols-3">
                {adConnections.map((conn) => (
                  <div key={conn.platform} className="flex items-center justify-between rounded-lg border border-gray-200 p-3">
                    <div className="flex items-center gap-2">
                      <span className={`inline-block h-2 w-2 rounded-full ${conn.status === 'connected' ? 'bg-green-500' : 'bg-gray-300'}`} />
                      <span className="text-sm font-medium text-gray-900">{getPlatformLabel(conn.platform)}</span>
                    </div>
                    {conn.status === 'connected' ? (
                      <button
                        onClick={() => handleDisconnectAd(conn.platform)}
                        className="text-xs text-red-600 hover:text-red-800"
                      >
                        Deconnecter
                      </button>
                    ) : (
                      <Button size="sm" onClick={() => handleConnectAd(conn.platform)} disabled={adLoading === conn.platform}>
                        {adLoading === conn.platform ? '...' : 'Connecter'}
                      </Button>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {/* Retargeting Opportunities Table */}
            <div>
              <div className="mb-3 flex items-center justify-between">
                <h3 className="text-sm font-semibold text-gray-900">URLs citees — Opportunites retargeting</h3>
                <Button variant="secondary" size="sm" onClick={() => exportAudienceCSV(opportunities)}>
                  Export CSV
                </Button>
              </div>
              <div className="overflow-x-auto">
                <table className="w-full text-left text-sm">
                  <thead className="border-b border-gray-200 bg-gray-50">
                    <tr>
                      <th className="px-4 py-3 font-medium text-gray-600">URL</th>
                      <th className="px-4 py-3 font-medium text-gray-600">Moteur</th>
                      <th className="px-4 py-3 font-medium text-gray-600">Audience est.</th>
                      <th className="px-4 py-3 font-medium text-gray-600">Pixel</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-gray-100">
                    {opportunities.map((opp) => (
                      <tr key={opp.id} className="hover:bg-gray-50">
                        <td className="px-4 py-3">
                          <span className="text-xs text-blue-600">{opp.url}</span>
                        </td>
                        <td className="px-4 py-3 text-gray-700">{opp.engine}</td>
                        <td className="px-4 py-3 font-medium text-gray-900">
                          {opp.estimatedAudience.toLocaleString('fr-FR')}
                        </td>
                        <td className="px-4 py-3">
                          <div className="flex items-center gap-2">
                            <button
                              onClick={() => handleCopyPixel(opp.id, opp.pixelCode)}
                              className="rounded bg-gray-100 px-2 py-1 text-xs text-gray-700 hover:bg-gray-200"
                            >
                              {copiedPixel === opp.id ? 'Copie !' : 'Copier le pixel'}
                            </button>
                            <button
                              onClick={() => setExpandedPixel(expandedPixel === opp.id ? null : opp.id)}
                              className="text-xs text-gray-400 hover:text-gray-600"
                            >
                              {expandedPixel === opp.id ? 'Masquer' : 'Voir'}
                            </button>
                          </div>
                          {expandedPixel === opp.id && (
                            <pre className="mt-2 max-w-md overflow-x-auto rounded bg-gray-900 p-3 text-xs text-green-400">
                              <code>{opp.pixelCode}</code>
                            </pre>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            {/* Budget Estimator */}
            <div className="rounded-lg border border-gray-200 p-4">
              <h3 className="mb-3 text-sm font-semibold text-gray-900">Estimateur de budget</h3>
              <div className="flex flex-wrap items-end gap-4">
                <div>
                  <label className="mb-1 block text-xs font-medium text-gray-600">Plateforme</label>
                  <select
                    value={rtPlatform}
                    onChange={(e) => setRtPlatform(e.target.value as AdPlatform)}
                    className="rounded-lg border border-gray-300 px-3 py-2 text-sm"
                  >
                    <option value="google_ads">Google Ads</option>
                    <option value="meta_ads">Meta Ads</option>
                    <option value="linkedin_ads">LinkedIn Ads</option>
                  </select>
                </div>
                <div className="flex-1">
                  <label className="mb-1 block text-xs font-medium text-gray-600">
                    Budget quotidien : {rtBudget} EUR
                  </label>
                  <input
                    type="range"
                    min={10}
                    max={500}
                    step={10}
                    value={rtBudget}
                    onChange={(e) => setRtBudget(Number(e.target.value))}
                    className="w-full"
                  />
                </div>
              </div>
              <div className="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
                <div className="rounded-lg bg-blue-50 p-3">
                  <p className="text-xs text-gray-500">Portee</p>
                  <p className="text-lg font-bold text-blue-600">{budget.estimatedReach.toLocaleString('fr-FR')}</p>
                </div>
                <div className="rounded-lg bg-emerald-50 p-3">
                  <p className="text-xs text-gray-500">Clics est.</p>
                  <p className="text-lg font-bold text-emerald-600">{budget.estimatedClicks.toLocaleString('fr-FR')}</p>
                </div>
                <div className="rounded-lg bg-amber-50 p-3">
                  <p className="text-xs text-gray-500">CPC</p>
                  <p className="text-lg font-bold text-amber-600">{budget.estimatedCPC.toFixed(2)} EUR</p>
                </div>
                <div className="rounded-lg bg-purple-50 p-3">
                  <p className="text-xs text-gray-500">CPM</p>
                  <p className="text-lg font-bold text-purple-600">{budget.estimatedCPM.toFixed(2)} EUR</p>
                </div>
              </div>
              <p className="mt-2 text-xs text-gray-400">
                <span className={`mr-1 inline-block rounded px-1.5 py-0.5 text-xs font-medium ${getPlatformColor(rtPlatform)}`}>
                  {getPlatformLabel(rtPlatform)}
                </span>
                Estimations basees sur les moyennes du secteur
              </p>
            </div>

            <p className="text-xs text-gray-400">0 Gas — derive des donnees du scan deja paye</p>
          </div>
        )}
      </div>

      {/* ============ SCHEDULING SECTION (F1) ============ */}
      <Card title="Planification automatique">
        <p className="mb-4 text-xs text-gray-500">
          Planifiez des scans recurrents. 0 Gas a la creation, chaque execution consomme 5 Gas.
        </p>
        <div className="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          <div>
            <label className="mb-1 block text-sm font-medium text-gray-700">Marque</label>
            <input
              type="text"
              value={schBrand}
              onChange={(e) => setSchBrand(e.target.value)}
              placeholder="Nom de la marque"
              className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
          </div>
          <div>
            <label className="mb-1 block text-sm font-medium text-gray-700">URL</label>
            <input
              type="url"
              value={schUrl}
              onChange={(e) => setSchUrl(e.target.value)}
              placeholder="https://..."
              className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
          </div>
          <div>
            <label className="mb-1 block text-sm font-medium text-gray-700">Frequence</label>
            <select
              value={schFreq}
              onChange={(e) => setSchFreq(e.target.value as ScheduleFrequency)}
              className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            >
              <option value="daily">Quotidien</option>
              <option value="weekly">Hebdomadaire</option>
              <option value="monthly">Mensuel</option>
            </select>
          </div>
          <div>
            <label className="mb-1 block text-sm font-medium text-gray-700">Heure</label>
            <input
              type="time"
              value={schHour}
              onChange={(e) => setSchHour(e.target.value)}
              className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            />
          </div>
          {schFreq === 'weekly' && (
            <div>
              <label className="mb-1 block text-sm font-medium text-gray-700">Jour de la semaine</label>
              <select
                value={schDay}
                onChange={(e) => setSchDay(Number(e.target.value))}
                className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
              >
                {['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'].map((d, i) => (
                  <option key={i} value={i}>{d}</option>
                ))}
              </select>
            </div>
          )}
          {schFreq === 'monthly' && (
            <div>
              <label className="mb-1 block text-sm font-medium text-gray-700">Jour du mois</label>
              <select
                value={schDay}
                onChange={(e) => setSchDay(Number(e.target.value))}
                className="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
              >
                {Array.from({ length: 28 }, (_, i) => i + 1).map((d) => (
                  <option key={d} value={d}>{d}</option>
                ))}
              </select>
            </div>
          )}
          <div className="flex items-end gap-3">
            <label className="flex items-center gap-2 text-sm text-gray-700">
              <input
                type="checkbox"
                checked={schEmail}
                onChange={(e) => setSchEmail(e.target.checked)}
                className="rounded border-gray-300"
              />
              Notification email
              <span className="rounded bg-gray-100 px-1 py-0.5 text-xs text-gray-400">Backend a venir</span>
            </label>
          </div>
        </div>
        <div className="mt-4">
          <Button onClick={handleCreateSchedule} disabled={!schBrand.trim() || !schUrl.trim()}>
            Planifier ce scan
          </Button>
        </div>
      </Card>

      {/* ---- Scheduled Brands Grid ---- */}
      {schedules.length > 0 && (
        <div>
          <h3 className="mb-3 text-lg font-semibold text-gray-900">Marques planifiees</h3>
          <motion.div
            className="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3"
            initial="hidden"
            animate="visible"
            variants={{ hidden: {}, visible: { transition: { staggerChildren: 0.08 } } }}
          >
            {schedules.map((sch) => (
              <motion.div
                key={sch.id}
                initial={{ opacity: 0, y: 12 }}
                animate={{ opacity: 1, y: 0 }}
              >
                <Card className={`border ${sch.active ? 'border-gray-200' : 'border-gray-100 opacity-60'}`}>
                  <div className="flex items-start justify-between">
                    <div>
                      <h4 className="font-semibold text-gray-900">{sch.brandName}</h4>
                      <p className="text-xs text-gray-400 break-all">{sch.brandUrl}</p>
                    </div>
                    <span className={`rounded-full px-2 py-0.5 text-xs font-medium ${getFrequencyColor(sch.frequency)}`}>
                      {getFrequencyLabel(sch.frequency)}
                    </span>
                  </div>
                  <div className="mt-3 space-y-1 text-xs text-gray-500">
                    <p>Prochaine execution : {new Date(sch.nextRun).toLocaleString('fr-FR')}</p>
                    {sch.lastRun && (
                      <p>Derniere execution : {new Date(sch.lastRun).toLocaleString('fr-FR')}</p>
                    )}
                  </div>
                  <div className="mt-3 flex items-center gap-2">
                    <button
                      onClick={() => handleToggleSchedule(sch.id)}
                      className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${
                        sch.active ? 'bg-blue-600' : 'bg-gray-300'
                      }`}
                    >
                      <span
                        className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${
                          sch.active ? 'translate-x-6' : 'translate-x-1'
                        }`}
                      />
                    </button>
                    <span className="text-xs text-gray-400">{sch.active ? 'Actif' : 'Pause'}</span>
                    <button
                      onClick={() => handleDeleteSchedule(sch.id)}
                      className="ml-auto text-xs text-red-500 hover:text-red-700"
                    >
                      Supprimer
                    </button>
                  </div>
                </Card>
              </motion.div>
            ))}
          </motion.div>
        </div>
      )}

      {/* ---- Scan History Timeline ---- */}
      {scanHistory.length > 0 && (
        <Card title="Historique des scans automatiques">
          <div className="space-y-3">
            {scanHistory.slice(0, 20).map((scan) => (
              <div key={scan.id} className="flex items-center gap-3 rounded-lg bg-gray-50 px-4 py-3">
                <div className={`h-2 w-2 rounded-full ${scan.status === 'completed' ? 'bg-green-500' : 'bg-red-500'}`} />
                <div className="flex-1">
                  <p className="text-sm font-medium text-gray-900">{scan.brandName}</p>
                  <p className="text-xs text-gray-500">
                    {scan.citationsFound} citations trouvees, {scan.citedCount} positives
                  </p>
                </div>
                <span className="text-xs text-gray-400">
                  {new Date(scan.executedAt).toLocaleString('fr-FR')}
                </span>
              </div>
            ))}
          </div>
        </Card>
      )}
    </div>
  )
}
