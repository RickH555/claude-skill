export interface RobotRule {
  agent: string;
  allow: boolean;
  comment: string;
  category: 'ai' | 'seo' | 'standard';
}

interface PlatformConfig {
  name: string;
  disallow: string[];
  sitemaps: string[];
}

const AI_BOTS: RobotRule[] = [
  { agent: 'GPTBot', allow: true, comment: 'OpenAI (ChatGPT) - Essential for citation', category: 'ai' },
  { agent: 'ChatGPT-User', allow: true, comment: 'OpenAI (Live Browsing)', category: 'ai' },
  { agent: 'Google-Extended', allow: true, comment: 'Google Gemini/Vertex AI training', category: 'ai' },
  { agent: 'CCBot', allow: true, comment: 'Common Crawl - Used by most LLMs foundation', category: 'ai' },
  { agent: 'ClaudeBot', allow: true, comment: 'Anthropic (Claude)', category: 'ai' },
  { agent: 'anthropic-ai', allow: true, comment: 'Anthropic (New agent)', category: 'ai' },
  { agent: 'Applebot', allow: true, comment: 'Apple Intelligence / Siri', category: 'ai' },
  { agent: 'PerplexityBot', allow: true, comment: 'Perplexity AI (Answer Engine)', category: 'ai' },
  { agent: 'Amazonbot', allow: true, comment: 'Amazon Alexa / Q answers', category: 'ai' },
  { agent: 'FacebookBot', allow: true, comment: 'Meta AI (Llama training)', category: 'ai' }
];

// Heuristics to detect platform based on URL pattern (Simulation)
const detectPlatform = (url: string): PlatformConfig => {
  const lowerUrl = url.toLowerCase();
  
  if (lowerUrl.includes('shopify') || lowerUrl.includes('store') || lowerUrl.includes('shop')) {
    return {
      name: 'Shopify / E-commerce',
      disallow: ['/cart', '/orders', '/checkouts', '/account', '/collections/*+*', '/blogs/*+*', '/*design_theme_id'],
      sitemaps: ['/sitemap.xml', '/sitemap_products_1.xml']
    };
  }
  
  if (lowerUrl.includes('wordpress') || lowerUrl.includes('blog') || lowerUrl.includes('wp-')) {
    return {
      name: 'WordPress',
      disallow: ['/wp-admin/', '/wp-includes/', '/wp-content/plugins/', '/xmlrpc.php', '/readme.html', '/?s='],
      sitemaps: ['/sitemap_index.xml', '/post-sitemap.xml']
    };
  }

  if (lowerUrl.includes('app.') || lowerUrl.includes('dashboard') || lowerUrl.includes('portal')) {
    return {
      name: 'SaaS / Web App',
      disallow: ['/api/', '/dashboard/', '/settings/', '/user/', '/private/', '/auth/'],
      sitemaps: ['/sitemap.xml']
    };
  }

  // Default / Generic
  return {
    name: 'Site Général',
    disallow: ['/admin/', '/login/', '/tmp/', '/private/', '/search'],
    sitemaps: ['/sitemap.xml']
  };
};

export const generateOptimizedRobotsTxt = (urlStr: string): string => {
  let hostname = urlStr;
  let protocol = 'https';
  
  try {
    const urlObj = new URL(urlStr.startsWith('http') ? urlStr : `https://${urlStr}`);
    hostname = urlObj.hostname;
    protocol = urlObj.protocol.replace(':', '');
  } catch (e) {
    // Fallback if URL is invalid
  }

  const platform = detectPlatform(urlStr);
  const date = new Date().toISOString().split('T')[0];

  let content = `# Robots.txt Optimized for AEO (Answer Engine Optimization)
# Generated by CitedBy.ai on ${date}
# Domain: ${hostname}
# Detected Architecture: ${platform.name}

# ==========================================
# PART 1: AI & LLM AGENTS (ALLOW LIST)
# ==========================================
# We explicitly allow these bots to ensure your content feeds 
# the knowledge graphs of ChatGPT, Gemini, Claude, and Perplexity.
`;

  AI_BOTS.forEach(bot => {
    content += `\nUser-agent: ${bot.agent}\n`;
    content += `Allow: /\n`;
    content += `# Purpose: ${bot.comment}\n`;
  });

  content += `
# ==========================================
# PART 2: GENERAL CRAWLERS & SEO
# ==========================================
User-agent: *
Allow: /

# --- Security & Privacy Protection ---
# Rules adapted for ${platform.name} structure
`;

  platform.disallow.forEach(path => {
    content += `Disallow: ${path}\n`;
  });

  content += `
# --- Sitemaps ---
# Provide clear paths for deep indexing
`;

  platform.sitemaps.forEach(map => {
    content += `Sitemap: ${protocol}://${hostname}${map}\n`;
  });

  content += `
# End of file
`;

  return content;
};

export const parseCurrentRobotsTxt = (url: string): string => {
  // We simulate what a "standard" unoptimized file looks like based on platform
  const platform = detectPlatform(url);
  
  let content = `User-agent: *\n`;
  
  if (platform.name === 'WordPress') {
    content += `Disallow: /wp-admin/\nAllow: /wp-admin/admin-ajax.php\n`;
  } else if (platform.name.includes('Shopify')) {
    content += `Disallow: /cart\nDisallow: /orders\n`;
  } else {
    content += `Disallow: /admin/\nDisallow: /tmp/\n`;
  }

  content += `\nSitemap: ${url}/sitemap.xml`;
  
  return content;
};

export const getDetectedPlatformName = (url: string): string => {
    return detectPlatform(url).name;
};

// AI-enhanced robots.txt generation using Google Gemini
export const generateRobotsWithAI = async (url: string): Promise<{ content: string; platformDetected: string }> => {
  let apiKey: string | null = null;
  if (typeof process !== 'undefined' && process.env && process.env.API_KEY) {
    apiKey = process.env.API_KEY;
  }

  const platform = detectPlatform(url);

  if (!apiKey) {
    // Fallback: use local generation
    await new Promise(resolve => setTimeout(resolve, 1200));
    return { content: generateOptimizedRobotsTxt(url), platformDetected: platform.name };
  }

  try {
    const { GoogleGenAI } = await import("@google/genai");
    const ai = new GoogleGenAI({ apiKey });

    const prompt = `
      You are an expert in SEO and AEO (Answer Engine Optimization). Generate an optimized robots.txt file for the following website.

      URL: ${url}
      Detected Platform: ${platform.name}

      Requirements:
      - Allow AI bots (GPTBot, ChatGPT-User, Google-Extended, CCBot, ClaudeBot, anthropic-ai, Applebot, PerplexityBot, Amazonbot, FacebookBot) with explicit Allow: / rules
      - Include standard crawlers section (User-agent: *)
      - Add security/privacy Disallow rules adapted to the ${platform.name} platform
      - Include Sitemap directives
      - Add professional comments explaining each section
      - Format as a valid robots.txt file

      Return ONLY the robots.txt content, no markdown fences, no extra text.
    `;

    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash',
      contents: prompt,
      config: { temperature: 0.2 }
    });

    const output = response.text;
    if (!output) throw new Error("Empty response from AI");

    return { content: output.replace(/```\n?/g, '').trim(), platformDetected: platform.name };
  } catch (error) {
    console.error("Robots.txt AI generation failed:", error);
    return { content: generateOptimizedRobotsTxt(url), platformDetected: platform.name };
  }
};