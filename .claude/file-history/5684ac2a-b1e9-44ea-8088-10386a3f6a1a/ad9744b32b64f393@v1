import React, { useState, useRef } from 'react';
import { User } from '../types';
import {
  SiteConfig, QueryPageConfig, ProductConfig,
  HubOutput, QueryPageOutput, RecommendJsonOutput, SitemapAiOutput,
  AI_LAYER_CREDITS,
} from '../types/ai-response-layer';
import { generateHub, generateQueryPage, generateRecommendJson, generateSitemapAi } from '../services/ai-response-layer';
import {
  ArrowLeft, Globe, FileQuestion, ShoppingBag, MapPin,
  Loader2, Copy, Check, Download, Plus, Trash2, ChevronRight,
  Sparkles, Zap, Eye, Code, FileText, AlertCircle,
} from 'lucide-react';

interface Props {
