import React, { useState, useRef, useCallback } from 'react';
import { Sparkles, TrendingUp, Target, Award, ArrowRight, ScanLine, Globe2, Fuel, Zap, Star, Check, Search, Bot, BrainCircuit, Database, Share2, Layers, Loader2, Gift, Shield, UserCheck, GraduationCap, BadgeCheck } from 'lucide-react';
import { User } from '../types';
import ScoreRing from '../components/ScoreRing';
import { auditAnswerFirst, AnswerFirstAuditResult } from '../services/answer-first-audit';

interface HomeProps {
  onNavigate: (view: 'analyze' | 'login' | 'recharge' | 'marketplace') => void;
  user: User | null;
  onDirectRecharge?: (packId: number) => void;
}

const Home: React.FC<HomeProps> = ({ onNavigate, user, onDirectRecharge }) => {
  const [brandName, setBrandName] = useState('');
  const [siteUrl, setSiteUrl] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [auditResult, setAuditResult] = useState<AnswerFirstAuditResult | null>(null);
  const [auditError, setAuditError] = useState<string | null>(null);
  const resultsRef = useRef<HTMLDivElement>(null);

  const eeatPillars = auditResult ? [
    { label: 'Experience', icon: <UserCheck size={16} />, score: Math.round((auditResult.categories.contentFreshness.score + auditResult.categories.answerFirst.score) / 2) },
    { label: 'Expertise', icon: <GraduationCap size={16} />, score: Math.round((auditResult.categories.faqStructure.score + auditResult.categories.semanticHtml.score) / 2) },
    { label: 'Authority', icon: <BadgeCheck size={16} />, score: Math.round((auditResult.categories.schemaOrg.score + auditResult.categories.metaOptimization.score) / 2) },
    { label: 'Trust', icon: <Shield size={16} />, score: Math.round((auditResult.categories.metaOptimization.score + auditResult.categories.schemaOrg.score + auditResult.categories.answerFirst.score) / 3) },
  ] : [];

  const handleFreeAudit = useCallback(async () => {
    if (!brandName.trim() || !siteUrl.trim()) { setAuditError('Veuillez remplir les deux champs.'); return; }
    let finalUrl = siteUrl.trim();
    if (!/^https?:\/\//i.test(finalUrl)) finalUrl = 'https://' + finalUrl;
    try { new URL(finalUrl); } catch { setAuditError('URL invalide. Exemple : https://www.example.com'); return; }
    setAuditError(null);
    setAuditResult(null);
    setIsAnalyzing(true);
    try {
      const result = await auditAnswerFirst(finalUrl, brandName.trim());
      setAuditResult(result);
      setTimeout(() => { resultsRef.current?.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 150);
    } catch { setAuditError("Une erreur est survenue lors de l'analyse. Veuillez r\u00e9essayer."); }
    finally { setIsAnalyzing(false); }
  }, [brandName, siteUrl]);

  const getScoreLabel = (score: number): string => {
    if (score >= 80) return 'Excellent';
    if (score >= 60) return 'Bon';
    if (score >= 40) return 'Moyen';
    if (score >= 20) return 'Faible';
    return 'Critique';
  };

  const getScoreColor = (score: number): string => {
    if (score >= 80) return 'text-amber-300';
    if (score >= 60) return 'text-amber-400';
    if (score >= 40) return 'text-yellow-400';
    return 'text-red-400';
  };

  const getBarColor = (score: number): string => {
    if (score >= 80) return 'bg-amber-400';
    if (score >= 60) return 'bg-amber-500';
    if (score >= 40) return 'bg-yellow-500';
    return 'bg-red-500';
  };

  const handleStartAnalysis = () => { user ? onNavigate('analyze') : onNavigate('login'); };

  const handleSelectPlan = (packId: number) => {
    if (user) { onDirectRecharge ? onDirectRecharge(packId) : onNavigate('recharge'); } else { onNavigate('login'); }
  };

  const plans = [
    { id: 1, name: "Le Jerrican", credits: 50, price: 15, icon: <Fuel size={24} />, popular: false, features: ["Id\u00e9al pour tester", "1 Audit complet", "Valable 1 an"] },
    { id: 2, name: "La Pompe", credits: 200, price: 49, icon: <Fuel size={24} />, popular: true, features: ["Pour optimiser s\u00e9rieusement", "Support prioritaire", "+10% Bonus offert"] },
    { id: 3, name: "La Citerne", credits: 1000, price: 199, icon: <Database size={24} />, popular: false, features: ["Usage intensif / Agence", "Acc\u00e8s API Beta", "+20% Bonus offert"] },
  ];

  return (
    <div className="w-full px-6 pt-16 pb-32 overflow-hidden">

      {/* HERO */}
      <div className="text-center mb-32 relative">
        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-amber-500/[0.06] blur-[150px] rounded-full -z-10 pointer-events-none" />
        <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.04] border border-amber-500/20 text-gray-400 text-xs font-medium tracking-wide uppercase mb-10">
          <Sparkles size={12} className="text-amber-400" /><span>Plateforme AEO / GEO</span>
        </div>
        <h1 className="text-5xl sm:text-6xl md:text-[5.5rem] font-sans font-bold tracking-tight text-white leading-[1.05] mb-8">
          Faites-vous citer<br className="hidden md:block" /> par les <span className="gradient-text">IA G{'\u00e9'}n{'\u00e9'}ratives</span>
        </h1>
        <p className="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed mb-12 font-light">
          La premi{'\u00e8'}re plateforme d'optimisation AEO. Analysez et influencez la fa{'\u00e7'}on dont ChatGPT, Claude, Gemini et AI Overviews per{'\u00e7'}oivent votre marque.
        </p>
        <div className="flex flex-col sm:flex-row items-center justify-center gap-4">
          <button onClick={handleStartAnalysis} className="btn-gradient text-base px-8 py-3.5 flex items-center gap-2.5 shadow-lg shadow-amber-900/20 hover:shadow-amber-900/30">
            Lancer un Audit Gratuit <ArrowRight size={18} />
          </button>
          <button onClick={() => onNavigate('marketplace')} className="px-8 py-3.5 rounded-full border border-white/[0.1] text-gray-300 text-base font-medium hover:bg-white/[0.04] hover:border-amber-500/20 transition-all">
            Explorer la Marketplace
          </button>
        </div>
      </div>

      {/* FREE AUDIT WIDGET */}
      <div className="mb-32 relative" id="score-gratuit">
        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-amber-500/[0.04] blur-[180px] rounded-full -z-10 pointer-events-none" />
        <div className="text-center mb-12">
          <div className="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-r from-amber-500/20 to-amber-700/20 border border-amber-500/30 text-white text-sm font-bold tracking-wide uppercase mb-8 shadow-lg shadow-amber-900/10">
            <Gift size={16} className="text-amber-400" /><span>100% GRATUIT</span><span className="text-amber-400">&mdash;</span><span className="text-amber-300">Sans inscription</span>
          </div>
          <h2 className="text-3xl md:text-5xl font-sans font-bold text-white tracking-tight mb-5">Votre Score de <span className="gradient-text">Visibilit{'\u00e9'} IA</span></h2>
          <p className="text-gray-500 max-w-2xl mx-auto text-lg">D{'\u00e9'}couvrez en 30 secondes comment les IA g{'\u00e9'}n{'\u00e9'}ratives per{'\u00e7'}oivent votre marque. Aucun compte requis.</p>
        </div>
        <div className="max-w-3xl mx-auto">
          <div className="ninja-card p-8 md:p-10 relative overflow-hidden">
            <div className="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-amber-500 to-transparent" />
            <form onSubmit={(e) => { e.preventDefault(); handleFreeAudit(); }} className="space-y-5">
              <div className="grid md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-2">Nom de marque</label>
                  <input type="text" value={brandName} onChange={(e) => setBrandName(e.target.value)} placeholder="Ex: CitedBy" className="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-600 outline-none transition-all focus:border-amber-500/50 focus:bg-white/[0.06] focus:shadow-[0_0_20px_rgba(218,165,32,0.08)]" disabled={isAnalyzing} />
                </div>
                <div>
                  <label className="block text-sm font-medium text-gray-300 mb-2">URL du site</label>
                  <input type="text" value={siteUrl} onChange={(e) => setSiteUrl(e.target.value)} placeholder="Ex: https://www.citedby.ai" className="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-gray-600 outline-none transition-all focus:border-amber-500/50 focus:bg-white/[0.06] focus:shadow-[0_0_20px_rgba(218,165,32,0.08)]" disabled={isAnalyzing} />
                </div>
              </div>
              {auditError && <p className="text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-2.5">{auditError}</p>}
              <button type="submit" disabled={isAnalyzing} className="w-full btn-gradient py-4 text-base font-bold flex items-center justify-center gap-3 shadow-lg shadow-amber-900/20 hover:shadow-amber-900/30 disabled:opacity-60 disabled:cursor-not-allowed transition-all">
                {isAnalyzing ? <><Loader2 size={20} className="animate-spin" /> Analyse en cours...</> : <><Sparkles size={20} /> Analyser gratuitement</>}
              </button>
              <p className="text-center text-xs text-gray-600">Aucune carte bancaire requise. 0 GTO Gas consomm{'\u00e9'}. R{'\u00e9'}sultat instantan{'\u00e9'}.</p>
            </form>
          </div>

          {isAnalyzing && (
            <div className="mt-8 ninja-card p-10 flex flex-col items-center justify-center gap-5">
              <div className="relative">
                <div className="w-24 h-24 rounded-full border-4 border-white/[0.06]" />
                <div className="absolute inset-0 w-24 h-24 rounded-full border-4 border-transparent border-t-amber-500 animate-spin" />
                <div className="absolute inset-0 flex items-center justify-center"><ScanLine size={28} className="text-amber-400 animate-pulse" /></div>
              </div>
              <div className="text-center"><p className="text-white font-semibold mb-1">Scan en cours...</p><p className="text-sm text-gray-500">Nous interrogeons les LLMs pour {'\u00e9'}valuer votre marque</p></div>
              <div className="flex flex-wrap justify-center gap-2">
                {['Answer-First', 'Schema.org', 'FAQ', 'S\u00e9mantique', 'Fra\u00eecheur', 'Meta'].map((label, i) => (
                  <div key={label} className="px-3 py-1 rounded-full text-[10px] font-medium bg-white/[0.04] border border-white/[0.06] text-gray-500" style={{ animation: `pulse 1.5s ease-in-out ${i * 0.25}s infinite` }}>{label}</div>
                ))}
              </div>
            </div>
          )}

          {auditResult && !isAnalyzing && (
            <div ref={resultsRef} className="mt-8 space-y-6">
              <div className="ninja-card p-8 md:p-10 relative overflow-hidden">
                <div className="absolute top-0 right-0 px-5 py-1.5 bg-gradient-to-r from-amber-500 to-amber-700 text-xs font-bold rounded-bl-2xl rounded-tr-[1rem] text-white uppercase tracking-wider">GRATUIT</div>
                <div className="flex flex-col md:flex-row items-center gap-8 md:gap-12">
                  <div className="flex flex-col items-center gap-3 shrink-0">
                    <ScoreRing score={auditResult.globalScore} size={140} strokeWidth={10} />
                    <span className={`text-lg font-bold ${getScoreColor(auditResult.globalScore)}`}>{getScoreLabel(auditResult.globalScore)}</span>
                  </div>
                  <div className="flex-1 w-full">
                    <h3 className="text-xl font-bold text-white mb-1">Score de Visibilit{'\u00e9'} IA</h3>
                    <p className="text-gray-500 text-sm mb-6">pour <span className="text-amber-400 font-semibold">{brandName}</span></p>
                    <div className="space-y-3">
                      {Object.entries(auditResult.categories).map(([key, cat]) => (
                        <div key={key}>
                          <div className="flex justify-between text-sm mb-1"><span className="text-gray-300">{cat.label}</span><span className={`font-bold ${getScoreColor(cat.score)}`}>{cat.score}/100</span></div>
                          <div className="w-full h-1.5 bg-white/[0.06] rounded-full overflow-hidden"><div className={`h-full rounded-full ${getBarColor(cat.score)} transition-all duration-700`} style={{ width: `${cat.score}%` }} /></div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              {/* E-E-A-T Pillars */}
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                {eeatPillars.map(p => (
                  <div key={p.label} className="ninja-card p-5 flex flex-col items-center text-center gap-2">
                    <div className="w-10 h-10 rounded-full bg-amber-500/20 flex items-center justify-center text-amber-400">{p.icon}</div>
                    <span className="text-xs text-gray-500 uppercase tracking-wider">{p.label}</span>
                    <span className={`text-2xl font-bold ${getScoreColor(p.score)}`}>{p.score}</span>
                  </div>
                ))}
              </div>

              <div className="ninja-card p-6 text-center">
                <p className="text-gray-400 text-sm mb-4">Pour un audit complet avec recommandations d\u00e9taill\u00e9es et plan d'action :</p>
                <button onClick={handleStartAnalysis} className="btn-gradient px-8 py-3 text-base font-bold inline-flex items-center gap-2">Lancer l'Audit Complet <ArrowRight size={18} /></button>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* STATS */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-6 mb-32 max-w-5xl mx-auto">
        {[
          { value: '50+', label: 'Crit\u00e8res AEO', icon: <Target size={20} /> },
          { value: '5', label: 'Moteurs IA', icon: <Bot size={20} /> },
          { value: '10k+', label: 'Audits R\u00e9alis\u00e9s', icon: <TrendingUp size={20} /> },
          { value: '98%', label: 'Satisfaction', icon: <Star size={20} /> },
        ].map(s => (
          <div key={s.label} className="text-center">
            <div className="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center text-amber-400 mx-auto mb-3">{s.icon}</div>
            <div className="text-3xl font-bold text-white mb-1">{s.value}</div>
            <div className="text-sm text-gray-500">{s.label}</div>
          </div>
        ))}
      </div>

      {/* FEATURES */}
      <div className="mb-32 max-w-5xl mx-auto">
        <div className="text-center mb-12">
          <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">Tout pour <span className="gradient-text">dominer l'AEO</span></h2>
          <p className="text-gray-500 max-w-xl mx-auto">9 modules essentiels pour analyser, optimiser et monitorer votre visibilit\u00e9 sur les IA g\u00e9n\u00e9ratives.</p>
        </div>
        <div className="grid md:grid-cols-3 gap-6">
          {[
            { icon: <Search size={24} />, title: 'Audit AEO Instantan\u00e9', desc: 'Analysez votre visibilit\u00e9 sur ChatGPT, Claude et Gemini en quelques secondes.' },
            { icon: <BrainCircuit size={24} />, title: 'Monitoring 5 Moteurs IA', desc: 'Suivez votre pr\u00e9sence sur tous les moteurs de r\u00e9ponse IA en temps r\u00e9el.' },
            { icon: <Layers size={24} />, title: 'Marketplace Agences', desc: 'Acc\u00e9dez \u00e0 des agences certifi\u00e9es et services AEO professionnels.' },
            { icon: <Zap size={24} />, title: 'Alertes AEO', desc: 'Soyez notifi\u00e9 en temps r\u00e9el des changements de visibilit\u00e9 IA.' },
            { icon: <Share2 size={24} />, title: 'Programme Affiliation', desc: 'G\u00e9n\u00e9rez des revenus en recommandant CitedBy.ai.' },
            { icon: <Globe2 size={24} />, title: 'Dashboard Complet', desc: 'Visualisez vos scores, citations et tendances en un coup d\u2019\u0153il.' },
          ].map(f => (
            <div key={f.title} className="ninja-card p-6 group hover:-translate-y-1 transition-all">
              <div className="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 mb-4 group-hover:bg-amber-500/20 transition-colors">{f.icon}</div>
              <h3 className="text-lg font-bold text-white mb-2">{f.title}</h3>
              <p className="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>

      {/* PRICING */}
      <div className="mb-32 max-w-4xl mx-auto">
        <div className="text-center mb-12">
          <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">Cr\u00e9dits <span className="gradient-text">GTO Gas</span></h2>
          <p className="text-gray-500">Rechargez votre compte en cr\u00e9dits pour lancer des audits et utiliser les outils.</p>
        </div>
        <div className="grid md:grid-cols-3 gap-6">
          {plans.map(plan => (
            <div key={plan.id} className={`ninja-card p-8 relative flex flex-col ${plan.popular ? 'border-amber-500/30 shadow-lg shadow-amber-900/10' : ''}`}>
              {plan.popular && <div className="absolute top-0 right-6 px-3 py-1 bg-gradient-to-r from-amber-500 to-amber-700 text-xs font-bold rounded-b-lg text-white">POPULAIRE</div>}
              <div className="text-amber-400 mb-4">{plan.icon}</div>
              <h3 className="text-xl font-bold text-white mb-1">{plan.name}</h3>
              <p className="text-amber-400 font-bold text-sm mb-4">{plan.credits} cr\u00e9dits</p>
              <div className="text-3xl font-bold text-white mb-6">{plan.price}\u20ac</div>
              <ul className="space-y-2 mb-8 flex-1">
                {plan.features.map(f => (
                  <li key={f} className="flex items-center gap-2 text-sm text-gray-400"><Check size={14} className="text-amber-400 shrink-0" />{f}</li>
                ))}
              </ul>
              <button onClick={() => handleSelectPlan(plan.id)} className={plan.popular ? 'btn-gradient w-full py-3 font-bold' : 'w-full py-3 rounded-full border border-white/[0.1] text-gray-300 font-medium hover:bg-white/[0.04] transition-all'}>
                Acheter
              </button>
            </div>
          ))}
        </div>
      </div>

      {/* TESTIMONIALS */}
      <div className="mb-32 max-w-4xl mx-auto">
        <div className="text-center mb-12">
          <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">Ce qu'ils en <span className="gradient-text">disent</span></h2>
        </div>
        <div className="grid md:grid-cols-3 gap-6">
          {[
            { name: 'Marie L.', role: 'CMO, TechStartup', quote: "CitedBy.ai a transform\u00e9 notre strat\u00e9gie de visibilit\u00e9 IA. Nos citations sur ChatGPT ont augment\u00e9 de 340%." },
            { name: 'Thomas B.', role: 'CEO, AgenceDigitale', quote: "L'outil le plus complet pour l'AEO. Le monitoring temps r\u00e9el est un game-changer." },
            { name: 'Sarah K.', role: 'Head of SEO, E-commerce', quote: "Le marketplace nous a permis de trouver l'agence parfaite pour notre optimisation AEO." },
          ].map(t => (
            <div key={t.name} className="ninja-card p-6">
              <div className="flex gap-1 mb-4">{[...Array(5)].map((_, i) => <Star key={i} size={14} className="text-amber-400 fill-amber-400" />)}</div>
              <p className="text-gray-400 text-sm leading-relaxed mb-4">"{t.quote}"</p>
              <div><div className="text-sm font-bold text-white">{t.name}</div><div className="text-xs text-gray-500">{t.role}</div></div>
            </div>
          ))}
        </div>
      </div>

      {/* CTA */}
      <div className="text-center max-w-2xl mx-auto">
        <div className="ninja-card p-12 relative overflow-hidden">
          <div className="absolute inset-0 bg-gradient-to-br from-amber-500/[0.05] to-transparent" />
          <div className="relative">
            <Award size={40} className="text-amber-400 mx-auto mb-6" />
            <h2 className="text-3xl font-bold text-white mb-4">Pr\u00eat \u00e0 \u00eatre cit\u00e9 par les IA ?</h2>
            <p className="text-gray-500 mb-8">Commencez avec 50 cr\u00e9dits offerts. Aucune carte bancaire requise.</p>
            <button onClick={handleStartAnalysis} className="btn-gradient px-10 py-4 text-lg font-bold inline-flex items-center gap-3">
              Commencer Gratuitement <ArrowRight size={20} />
            </button>
          </div>
        </div>
      </div>
    </div>
  );
};

export default Home;
