// ── Toast Notification System ──
interface Toast {
  id: string;
  type: 'success' | 'error' | 'info';
  message: string;
}

const ToastContext = createContext<{
  showToast: (type: Toast['type'], message: string) => void;
}>({ showToast: () => {} });

export const useToast = () => useContext(ToastContext);

const ToastContainer: React.FC<{ toasts: Toast[]; onRemove: (id: string) => void }> = ({ toasts, onRemove }) => {
  return (
    <div className="fixed bottom-6 right-6 z-[200] flex flex-col gap-2.5 pointer-events-none">
      {toasts.map((toast) => {
        const styles = {
          success: 'bg-emerald-500/15 border-emerald-500/30 text-emerald-300',
          error: 'bg-red-500/15 border-red-500/30 text-red-300',
          info: 'bg-blue-500/15 border-blue-500/30 text-blue-300',
        };
        const icons = { success: '✓', error: '✕', info: 'ℹ' };
        return (
          <div
            key={toast.id}
            className={`pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl border backdrop-blur-xl shadow-2xl shadow-black/40 animate-in slide-in-from-right fade-in duration-300 ${styles[toast.type]}`}
            onClick={() => onRemove(toast.id)}
          >
            <span className="text-sm font-bold">{icons[toast.type]}</span>
            <span className="text-sm font-medium">{toast.message}</span>
          </div>
        );
      })}
    </div>
  );
};

// Command Palette Panel component
const CommandPalettePanel: React.FC<{ onClose: () => void; onNavigate: (view: string) => void }> = ({ onClose, onNavigate }) => {
  const [query, setQuery] = useState('');
  const inputRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
    setTimeout(() => inputRef.current?.focus(), 100);
  }, []);

  const commands = [
    { id: 'analyze', label: 'Nouvel Audit AEO', icon: '🔍', category: 'Navigation' },
    { id: 'dashboard', label: 'Dashboard Pro', icon: '📊', category: 'Navigation' },
    { id: 'projects', label: 'Monitoring AEO', icon: '📈', category: 'Navigation' },
    { id: 'generative-tools', label: 'Outils Génératifs', icon: '✨', category: 'Outils' },
    { id: 'smc-studio', label: 'SMC Studio', icon: '✏️', category: 'Outils' },
    { id: 'content-writer', label: 'AI Content Writer', icon: '📝', category: 'Outils' },
    { id: 'reputation', label: 'Réputation IA', icon: '🛡️', category: 'Outils' },
    { id: 'source-of-truth', label: 'Source of Truth', icon: '📄', category: 'Outils' },
    { id: 'schema-org', label: 'Schema.org Generator', icon: '🔧', category: 'Outils' },
    { id: 'robots-txt', label: 'Robots.txt Optimizer', icon: '🤖', category: 'Outils' },
    { id: 'bot-tracking', label: 'Suivi Bots IA', icon: '👁️', category: 'Outils' },
    { id: 'blog-optimizer', label: 'Blog Optimiser', icon: '📰', category: 'Outils' },
    { id: 'directory', label: 'Annuaire Indexé', icon: '📚', category: 'Navigation' },
    { id: 'recharge', label: 'GTO Gas Station', icon: '⛽', category: 'Navigation' },
