import React, { useState } from 'react';
import { User } from '../types';
import { ArrowLeft, Globe, MapPin, Target, Zap, Shield, RefreshCw, BarChart3, CheckCircle2, TrendingUp, Layers, Newspaper, HeartPulse, Cpu, Briefcase, Coffee, Lock, Play, ShieldCheck, FileText } from 'lucide-react';

interface PublisherRequestProps {
  onBack: () => void;
  user: User | null;
  data: {
    topic: string;
    url: string;
    brief: string;
  } | null;
}

type Step = 'targeting' | 'authority' | 'lifecycle' | 'success';
type Scope = 'local' | 'national' | 'global';
type NicheID = 'tech' | 'finance' | 'health' | 'lifestyle' | 'business' | 'other';

const PublisherRequest: React.FC<PublisherRequestProps> = ({ onBack, user, data }) => {
  const [step, setStep] = useState<Step>('targeting');
  
  // Selection State
  const [selectedNiche, setSelectedNiche] = useState<NicheID | null>(null);
  const [scope, setScope] = useState<Scope>('national');
  const [location, setLocation] = useState(''); // For local/national
  
  // Authority State
  const [authorityLevel, setAuthorityLevel] = useState<number>(1); // 1, 2, 3 (Standard, Premium, Elite)

  // Lifecycle Options
  const [freshnessOption, setFreshnessOption] = useState(false);
  const [mediaOption, setMediaOption] = useState(false);

  if (!data) return null;

  // Configuration Data
  const niches = [
    { id: 'tech', label: 'Tech & SaaS', icon: <Cpu size={24} />, desc: 'Innovation, Software, AI' },
    { id: 'finance', label: 'Finance & Crypto', icon: <TrendingUp size={24} />, desc: 'Investissement, Banque' },
    { id: 'health', label: 'Santé & Bien-être', icon: <HeartPulse size={24} />, desc: 'Médical, Sport, Bio' },
    { id: 'business', label: 'B2B & Services', icon: <Briefcase size={24} />, desc: 'Management, RH, Marketing' },
    { id: 'lifestyle', label: 'Lifestyle & Maison', icon: <Coffee size={24} />, desc: 'Déco, Voyage, Mode' },
    { id: 'other', label: 'Généraliste', icon: <Newspaper size={24} />, desc: 'Actualités diverses' },
  ];

  const authorityTiers = [
    { level: 1, name: 'Standard', da: 'DA 20-40', price: 150, desc: 'Blogs thématiques actifs. Bon pour la longue traîne.' },
    { level: 2, name: 'Premium', da: 'DA 40-60', price: 350, desc: 'Sites reconnus et médias spécialisés. Signal fort.' },
    { level: 3, name: 'Elite', da: 'DA 60+', price: 800, desc: 'Grands médias nationaux. Autorité maximale.' },
  ];

  const calculateTotal = () => {
    const base = authorityTiers.find(t => t.level === authorityLevel)?.price || 0;
    const freshCost = freshnessOption ? 45 : 0; // Coût du rappel/update
    const mediaCost = mediaOption ? 80 : 0; // Coût de l'infographie
    return base + freshCost + mediaCost;
  };

  const handleNext = () => {
    if (step === 'targeting') setStep('authority');
    else if (step === 'authority') setStep('lifecycle');
    else if (step === 'lifecycle') {
        // Submit logic here
        setTimeout(() => setStep('success'), 1000);
    }
  };

  const renderTargeting = () => (
    <div className="space-y-8 animate-in slide-in-from-right duration-300">
        <div>
            <h3 className="text-xl font-bold text-white mb-4 flex items-center gap-2">
                <Target size={20} className="text-purple-400" />
                1. Choisissez votre Niche Sémantique
            </h3>
            <p className="text-sm text-gray-500 mb-6">
                Pour qu'une IA valide votre expertise, le lien doit provenir d'un site thématiquement proche (Topical Trust Flow).
            </p>
            <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                {niches.map((n) => (
                    <button
                        key={n.id}
                        onClick={() => setSelectedNiche(n.id as NicheID)}
                        className={`p-4 rounded-2xl border text-left transition-all group ${
                            selectedNiche === n.id 
                            ? 'bg-purple-500/10 border-primary text-white shadow-[0_0_15px_rgba(16,185,129,0.2)]' 
                            : 'bg-white/[0.04] border-white/[0.08] hover:border-white/20 text-gray-500 hover:text-gray-200'
                        }`}
                    >
                        <div className={`mb-3 ${selectedNiche === n.id ? 'text-purple-400' : 'text-gray-500 group-hover:text-gray-300'}`}>
                            {n.icon}
                        </div>
                        <div className="font-bold text-sm">{n.label}</div>
                        <div className="text-xs opacity-70 mt-1">{n.desc}</div>
                    </button>
                ))}
            </div>
        </div>

        <div className="pt-6 border-t border-white/[0.08]">
            <h3 className="text-xl font-bold text-white mb-4 flex items-center gap-2">
                <Globe size={20} className="text-purple-400" />
                2. Portée Géographique (GEO)
            </h3>
            <div className="grid md:grid-cols-3 gap-4 mb-4">
                {[
                    { id: 'local', label: 'Local', icon: <MapPin size={18}/>, desc: 'Ville / Région' },
                    { id: 'national', label: 'National', icon: <Shield size={18}/>, desc: 'Pays entier' },
                    { id: 'global', label: 'International', icon: <Globe size={18}/>, desc: 'Multi-langues' }
                ].map((s) => (
                    <button
                        key={s.id}
                        onClick={() => setScope(s.id as Scope)}
                        className={`px-4 py-3 rounded-full border flex items-center gap-3 transition-all ${
                            scope === s.id 
                            ? 'bg-white/[0.08] border-white text-white' 
                            : 'bg-transparent border-white/[0.08] text-gray-500 hover:text-gray-300'
                        }`}
                    >
                        {s.icon}
                        <div className="text-left">
                            <div className="font-bold text-sm">{s.label}</div>
                            <div className="text-[10px] opacity-70">{s.desc}</div>
                        </div>
                    </button>
                ))}
            </div>
            
            {scope !== 'global' && (
                <div className="animate-in fade-in">
                    <label className="text-xs text-gray-500 block mb-2">
                        {scope === 'local' ? 'Ville cible (ex: Bordeaux)' : 'Pays cible (ex: France)'}
                    </label>
                    <input 
                        type="text" 
                        value={location}
                        onChange={(e) => setLocation(e.target.value)}
                        placeholder={scope === 'local' ? "Ex: Lyon, France" : "Ex: France"}
                        className="w-full bg-black/40 border border-white/[0.08] rounded-xl p-3 text-white focus:border-purple-500/50 outline-none"
                    />
                </div>
            )}
        </div>
    </div>
  );

  const renderAuthority = () => (
    <div className="space-y-8 animate-in slide-in-from-right duration-300">
        <div>
            <h3 className="text-xl font-bold text-white mb-2 flex items-center gap-2">
                <Shield size={20} className="text-purple-400" />
                Puissance de l'Autorité
            </h3>
            <p className="text-sm text-gray-500 mb-6">
                Le "Domain Authority" (DA) détermine la probabilité que ce lien influence les réponses des LLMs.
            </p>

            <div className="space-y-4">
                {authorityTiers.map((tier) => (
                    <div 
                        key={tier.level}
                        onClick={() => setAuthorityLevel(tier.level)}
                        className={`p-5 rounded-2xl border cursor-pointer transition-all flex items-center justify-between group ${
                            authorityLevel === tier.level
                            ? 'bg-purple-500/10 border-purple-500/50 shadow-[0_0_20px_rgba(168,85,247,0.1)]'
                            : 'bg-white/[0.04] border-white/[0.08] hover:bg-purple-500/10'
                        }`}
                    >
                        <div className="flex items-center gap-4">
                            <div className={`w-6 h-6 rounded-full border flex items-center justify-center ${
                                authorityLevel === tier.level ? 'border-purple-500 bg-purple-500' : 'border-gray-600'
                            }`}>
                                {authorityLevel === tier.level && <div className="w-2 h-2 bg-white rounded-full"></div>}
                            </div>
                            <div>
                                <div className="flex items-center gap-3">
                                    <span className={`font-bold text-lg ${authorityLevel === tier.level ? 'text-white' : 'text-gray-300'}`}>
                                        {tier.name}
                                    </span>
                                    <span className="text-xs font-bold bg-white/[0.08] px-2 py-0.5 rounded text-white border border-white/[0.08]">
                                        {tier.da}
                                    </span>
                                </div>
                                <p className="text-sm text-gray-500 mt-1">{tier.desc}</p>
                            </div>
                        </div>
                        <div className="text-right">
                            <span className="block text-xl font-bold text-white">{tier.price}€</span>
                            <span className="text-[10px] text-gray-500">/publication</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
  );

  const renderLifecycle = () => (
    <div className="space-y-8 animate-in slide-in-from-right duration-300">
        <div>
            <h3 className="text-xl font-bold text-white mb-2 flex items-center gap-2">
                <RefreshCw size={20} className="text-purple-300" />
                Cycle de Vie AEO
            </h3>
            <p className="text-sm text-gray-500 mb-6">
                Les IA privilégient le contenu vivant. Ne laissez pas votre article devenir obsolète.
            </p>

            <div className="grid md:grid-cols-2 gap-4">
                {/* Freshness Option */}
                <div 
                    onClick={() => setFreshnessOption(!freshnessOption)}
                    className={`p-5 rounded-2xl border cursor-pointer transition-all ${
                        freshnessOption ? 'bg-purple-500/10 border-purple-500 text-white' : 'bg-white/[0.04] border-white/[0.08] text-gray-500 hover:bg-purple-500/10'
                    }`}
                >
                    <div className="flex justify-between items-start mb-3">
                        <RefreshCw size={24} className={freshnessOption ? 'text-purple-300' : 'text-gray-500'} />
                        <span className="text-xs font-bold border border-current px-2 py-1 rounded">+45€</span>
                    </div>
                    <h4 className="font-bold mb-2">Freshness Ping™</h4>
                    <p className="text-xs opacity-80 leading-relaxed">
                        Nous planifions une mise à jour mineure (dates, chiffres) dans 6 mois pour signaler aux bots que le contenu est toujours d'actualité.
                    </p>
                </div>

                {/* Media Option */}
                <div 
                    onClick={() => setMediaOption(!mediaOption)}
                    className={`p-5 rounded-2xl border cursor-pointer transition-all ${
                        mediaOption ? 'bg-purple-500/10 border-purple-500 text-white' : 'bg-white/[0.04] border-white/[0.08] text-gray-500 hover:bg-purple-500/10'
                    }`}
                >
                    <div className="flex justify-between items-start mb-3">
                        <Layers size={24} className={mediaOption ? 'text-purple-400' : 'text-gray-500'} />
                        <span className="text-xs font-bold border border-current px-2 py-1 rounded">+80€</span>
                    </div>
                    <h4 className="font-bold mb-2">Media Injection</h4>
                    <p className="text-xs opacity-80 leading-relaxed">
                        Création et insertion d'une infographie de données optimisée (Alt-Text AEO) pour capter le trafic via Google Lens et Gemini Vision.
                    </p>
                </div>
            </div>
        </div>

        <div className="p-4 bg-blue-500/10 border border-blue-500/20 rounded-2xl flex gap-3">
            <ShieldCheck size={20} className="text-blue-400 shrink-0 mt-0.5" />
            <div>
                <h4 className="text-sm font-bold text-blue-100">Garantie Indexation & Sentiment</h4>
                <p className="text-xs text-blue-200/70 mt-1">
                    Si l'article n'est pas indexé sous 30 jours, nous le republions gratuitement. Nous surveillons aussi le sentiment des commentaires pour protéger votre marque.
                </p>
            </div>
        </div>
    </div>
  );

  if (step === 'success') {
    return (
      <div className="max-w-2xl mx-auto px-4 py-20 text-center animate-in zoom-in duration-300">
        <div className="w-24 h-24 bg-gradient-to-br from-purple-500 to-violet-900 rounded-full flex items-center justify-center mx-auto mb-8 shadow-lg shadow-purple-500/20">
          <CheckCircle2 size={48} className="text-white" />
        </div>
        <h2 className="text-4xl font-sans font-bold text-white mb-4">Campagne Publisher Lancée !</h2>
        <p className="text-xl text-gray-300 mb-8 leading-relaxed">
          Votre stratégie de publication pour <strong>"{data.topic}"</strong> est en cours de déploiement sur notre réseau {scope === 'global' ? 'international' : 'national'}.
        </p>
        
        <div className="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-6 text-left mb-8 max-w-lg mx-auto">
            <div className="flex justify-between mb-2">
                <span className="text-gray-500">Niche</span>
                <span className="text-white font-medium capitalize">{selectedNiche}</span>
            </div>
            <div className="flex justify-between mb-2">
                <span className="text-gray-500">Autorité</span>
                <span className="text-white font-medium">Niveau {authorityLevel} (Elite)</span>
            </div>
            {freshnessOption && (
                <div className="flex justify-between mb-2">
                    <span className="text-gray-500">Maintenance</span>
                    <span className="text-purple-300 font-medium flex items-center gap-1"><RefreshCw size={12}/> Freshness Ping</span>
                </div>
            )}
            <div className="border-t border-white/[0.08] mt-4 pt-4 flex justify-between">
                <span className="text-gray-500">Total Facturé</span>
                <span className="text-xl font-bold text-white">{calculateTotal()} €</span>
            </div>
        </div>

        <button 
          onClick={onBack}
          className="px-8 py-3 bg-gradient-to-r from-purple-500 to-violet-600 text-white font-bold rounded-2xl hover:from-purple-600 hover:to-violet-700 transition-colors"
        >
          Retour au Studio
        </button>
      </div>
    );
  }

  return (
    <div className="max-w-6xl mx-auto px-4 py-8 animate-in fade-in duration-500 min-h-screen">
      <button onClick={onBack} className="flex items-center text-gray-500 hover:text-white mb-8 transition-colors">
        <ArrowLeft size={18} className="mr-2" /> Retour au brief
      </button>

      <div className="grid lg:grid-cols-12 gap-12">
        
        {/* Left: Wizard Steps */}
        <div className="lg:col-span-8">
            <div className="mb-8">
                <h1 className="text-4xl font-sans font-bold text-white mb-2">Publisher Network</h1>
                <p className="text-gray-500 text-lg">Déployez votre contenu sur des sites d'autorité pour forcer la citation par les IA.</p>
            </div>

            {/* Progress Bar */}
            <div className="flex items-center gap-2 mb-10">
                <div className={`h-1 flex-1 rounded-full transition-all ${step === 'targeting' || step === 'authority' || step === 'lifecycle' ? 'bg-primary' : 'bg-white/[0.08]'}`}></div>
                <div className={`h-1 flex-1 rounded-full transition-all ${step === 'authority' || step === 'lifecycle' ? 'bg-primary' : 'bg-white/[0.08]'}`}></div>
                <div className={`h-1 flex-1 rounded-full transition-all ${step === 'lifecycle' ? 'bg-primary' : 'bg-white/[0.08]'}`}></div>
            </div>

            {step === 'targeting' && renderTargeting()}
            {step === 'authority' && renderAuthority()}
            {step === 'lifecycle' && renderLifecycle()}

            <div className="mt-10 pt-6 border-t border-white/[0.08] flex justify-between">
                {step !== 'targeting' && (
                    <button 
                        onClick={() => setStep(step === 'lifecycle' ? 'authority' : 'targeting')}
                        className="text-gray-500 hover:text-white font-medium"
                    >
                        Précédent
                    </button>
                )}
                <div className="ml-auto"> {/* Spacer if no back button */}
                    <button 
                        onClick={handleNext}
                        disabled={step === 'targeting' && !selectedNiche}
                        className="px-8 py-3 bg-gradient-to-r from-purple-500 to-violet-600 hover:from-purple-600 hover:to-violet-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-purple-500/20 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        {step === 'lifecycle' ? 'Valider et Publier' : 'Étape suivante'}
                        <Play size={16} className="fill-black" />
                    </button>
                </div>
            </div>
        </div>

        {/* Right: Summary Card */}
        <div className="lg:col-span-4">
            <div className="bg-[#0f1115] border border-white/[0.08] rounded-2xl p-6 sticky top-6 shadow-2xl">
                <div className="flex items-center gap-3 mb-6 pb-6 border-b border-white/[0.08]">
                    <div className="w-12 h-12 bg-white/[0.04] rounded-full flex items-center justify-center text-gray-300">
                        <FileText size={24} />
                    </div>
                    <div>
                        <h4 className="font-bold text-white line-clamp-1">{data.topic}</h4>
                        <p className="text-xs text-gray-500">Brief AEO inclus</p>
                    </div>
                </div>

                <div className="space-y-4 text-sm">
                    <div className="flex justify-between">
                        <span className="text-gray-500">Niche</span>
                        <span className={`font-medium ${selectedNiche ? 'text-white capitalize' : 'text-gray-600 italic'}`}>
                            {selectedNiche || 'À définir'}
                        </span>
                    </div>
                    <div className="flex justify-between">
                        <span className="text-gray-500">Portée</span>
                        <span className="text-white font-medium capitalize">{scope}</span>
                    </div>
                    {step !== 'targeting' && (
                        <div className="flex justify-between animate-in fade-in">
                            <span className="text-gray-500">Autorité</span>
                            <span className="text-purple-400 font-medium">Niveau {authorityLevel}</span>
                        </div>
                    )}
                    {mediaOption && (
                        <div className="flex justify-between animate-in fade-in">
                            <span className="text-gray-500">Option Media</span>
                            <span className="text-purple-400 font-medium">Incluse</span>
                        </div>
                    )}
                    {freshnessOption && (
                        <div className="flex justify-between animate-in fade-in">
                            <span className="text-gray-500">Maintenance</span>
                            <span className="text-purple-300 font-medium">Active</span>
                        </div>
                    )}
                </div>

                <div className="mt-8 pt-6 border-t border-white/[0.08]">
                    <div className="flex justify-between items-end mb-1">
                        <span className="text-gray-500 text-sm">Total Estimé</span>
                        <span className="text-3xl font-sans font-bold text-white">{calculateTotal()}€</span>
                    </div>
                    <p className="text-right text-[10px] text-gray-500">Paiement unique • Facture Pro</p>
                </div>
            </div>
        </div>

      </div>
    </div>
  );
};

export default PublisherRequest;
