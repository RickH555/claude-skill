"use client";

import { useState } from "react";
import { Card, CardHeader, CardTitle, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import {
  Link2,
  ExternalLink,
  CheckCircle,
  AlertCircle,
  BarChart3,
  TrendingUp,
  ArrowUpRight,
  ArrowDownRight,
  Zap,
} from "lucide-react";
import { toast } from "sonner";
import type { GSCOverview } from "@/services/gsc_service";

type ConnectionStatus = "disconnected" | "connecting" | "connected";

const CORRELATION_COLORS = {
  strong: "text-emerald-400",
  moderate: "text-amber-400",
  weak: "text-red-400",
};

export default function IntegrationsPage() {
  const [gscStatus, setGscStatus] = useState<ConnectionStatus>("disconnected");
  const [gscData, setGscData] = useState<GSCOverview | null>(null);

  const handleConnectGSC = async () => {
    setGscStatus("connecting");
    toast.loading("Connexion a Google Search Console...", { id: "gsc" });

    try {
      // In production, this would trigger Google OAuth flow
      // For now, fetch mock data to demonstrate the integration
      const { fetchGSCOverview } = await import("@/services/gsc_service");
      const data = await fetchGSCOverview("citedby.ai");

      setGscData(data);
      setGscStatus("connected");
      toast.success("Connecte a Google Search Console", { id: "gsc" });
    } catch {
      setGscStatus("disconnected");
      toast.error("Erreur de connexion", { id: "gsc" });
    }
  };

  const handleDisconnect = () => {
    setGscStatus("disconnected");
    setGscData(null);
    toast.success("Deconnecte de Google Search Console");
  };

  return (
    <div>
      <div className="mb-8">
        <h2 className="text-2xl font-serif font-bold text-white mb-2">Integrations</h2>
        <p className="text-white/40">
          Connectez vos outils pour enrichir vos analyses AEO
        </p>
      </div>

      {/* Google Search Console Card */}
      <Card className="mb-8">
        <CardHeader>
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                <svg viewBox="0 0 24 24" className="w-6 h-6" fill="none">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <div>
                <CardTitle className="text-base">Google Search Console</CardTitle>
                <p className="text-xs text-white/40 mt-0.5">
                  Correlation entre positions SEO et citations IA
                </p>
              </div>
            </div>
            <div className="flex items-center gap-3">
              {gscStatus === "connected" ? (
                <>
                  <Badge variant="success">
                    <CheckCircle size={10} className="mr-1" /> Connecte
                  </Badge>
                  <Button variant="ghost" size="sm" onClick={handleDisconnect}>
                    Deconnecter
                  </Button>
                </>
              ) : (
                <Button
                  onClick={handleConnectGSC}
                  isLoading={gscStatus === "connecting"}
                >
                  <Link2 size={14} /> Connecter GSC
                </Button>
              )}
            </div>
          </div>
        </CardHeader>

        {gscStatus === "disconnected" && (
          <CardContent>
            <div className="rounded-xl bg-white/[0.02] border border-white/5 p-6 text-center">
              <AlertCircle size={32} className="text-white/20 mx-auto mb-3" />
              <p className="text-sm text-white/50 mb-1">
                Connectez Google Search Console pour voir la correlation entre vos positions SEO
                et vos citations IA.
              </p>
              <p className="text-xs text-white/30">
                Les donnees GSC permettent d&apos;identifier les pages les plus citees par les moteurs IA
                et de mesurer l&apos;impact AEO sur votre trafic organique.
              </p>
            </div>
          </CardContent>
        )}
      </Card>

      {/* GSC Data Dashboard (shown when connected) */}
      {gscData && (
        <>
          {/* GSC KPIs */}
          <div className="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <Card className="p-5">
              <p className="text-xs text-white/40 uppercase mb-1">Clics totaux</p>
              <p className="text-3xl font-bold text-white">
                {(gscData.totalClicks / 1000).toFixed(1)}K
              </p>
              <span className="text-xs text-emerald-400 flex items-center gap-0.5">
                <ArrowUpRight size={10} /> +8%
              </span>
            </Card>
            <Card className="p-5">
              <p className="text-xs text-white/40 uppercase mb-1">Impressions</p>
              <p className="text-3xl font-bold text-white">
                {(gscData.totalImpressions / 1000).toFixed(0)}K
              </p>
              <span className="text-xs text-emerald-400 flex items-center gap-0.5">
                <ArrowUpRight size={10} /> +15%
              </span>
            </Card>
            <Card className="p-5">
              <p className="text-xs text-white/40 uppercase mb-1">CTR moyen</p>
              <p className="text-3xl font-bold text-primary">{gscData.averageCTR}%</p>
            </Card>
            <Card className="p-5">
              <p className="text-xs text-white/40 uppercase mb-1">Position moyenne</p>
              <p className="text-3xl font-bold text-amber-400">{gscData.averagePosition}</p>
              <span className="text-xs text-emerald-400 flex items-center gap-0.5">
                <ArrowUpRight size={10} /> -1.3
              </span>
            </Card>
          </div>

          {/* AEO/SEO Correlation Table */}
          <Card className="mb-8">
            <CardHeader>
              <CardTitle className="text-base flex items-center gap-2">
                <Zap size={16} className="text-primary" />
                Correlation AEO / SEO
              </CardTitle>
            </CardHeader>
            <CardContent>
              <p className="text-xs text-white/40 mb-4">
                Comparaison entre les positions Google et les citations IA pour vos requetes cles
              </p>
              <div className="overflow-x-auto">
                <table className="w-full text-sm">
                  <thead>
                    <tr className="border-b border-white/10">
                      <th className="text-left py-2 text-xs text-white/40 font-medium">Requete</th>
                      <th className="text-center py-2 text-xs text-white/40 font-medium">Position Google</th>
                      <th className="text-center py-2 text-xs text-white/40 font-medium">Score AEO</th>
                      <th className="text-center py-2 text-xs text-white/40 font-medium">Citations IA</th>
                      <th className="text-center py-2 text-xs text-white/40 font-medium">Correlation</th>
                    </tr>
                  </thead>
                  <tbody>
                    {gscData.aeoCorrelations.map((row, i) => (
                      <tr key={i} className="border-b border-white/5 hover:bg-white/[0.02]">
                        <td className="py-3 text-white/70">{row.query}</td>
                        <td className="py-3 text-center">
                          <span className="text-white font-medium">#{row.gscPosition.toFixed(1)}</span>
                        </td>
                        <td className="py-3 text-center">
                          <span className={`font-medium ${
                            row.aeoScore >= 70 ? "text-emerald-400" :
                            row.aeoScore >= 50 ? "text-amber-400" : "text-red-400"
                          }`}>
                            {row.aeoScore}/100
                          </span>
                        </td>
                        <td className="py-3 text-center text-primary font-medium">
                          {row.aiCitations}
                        </td>
                        <td className="py-3 text-center">
                          <Badge variant={
                            row.correlation === "strong" ? "success" :
                            row.correlation === "moderate" ? "warning" : "destructive"
                          }>
                            {row.correlation === "strong" ? "Forte" :
                             row.correlation === "moderate" ? "Moyenne" : "Faible"}
                          </Badge>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>

          {/* Top Queries & Pages */}
          <div className="grid lg:grid-cols-2 gap-6">
            <Card>
              <CardHeader>
                <CardTitle className="text-base flex items-center gap-2">
                  <TrendingUp size={16} className="text-primary" />
                  Top requetes Google
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-2">
                  {gscData.topQueries.map((q, i) => (
                    <div
                      key={i}
                      className="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-white/5 transition-colors"
                    >
                      <div className="flex items-center gap-2">
                        <span className="text-xs text-white/20 font-bold w-5">{i + 1}</span>
                        <span className="text-sm text-white/70">{q.query}</span>
                      </div>
                      <div className="flex items-center gap-4 text-xs">
                        <span className="text-white/40">{q.clicks} clics</span>
                        <span className="text-primary font-medium">#{q.position.toFixed(1)}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="text-base flex items-center gap-2">
                  <BarChart3 size={16} className="text-primary" />
                  Top pages
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-2">
                  {gscData.topPages.map((p, i) => (
                    <div
                      key={i}
                      className="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-white/5 transition-colors"
                    >
                      <div className="flex items-center gap-2 min-w-0">
                        <span className="text-xs text-white/20 font-bold w-5">{i + 1}</span>
                        <span className="text-sm text-white/70 truncate">{p.page}</span>
                      </div>
                      <div className="flex items-center gap-4 text-xs shrink-0">
                        <span className="text-white/40">{p.clicks} clics</span>
                        <span className="text-primary font-medium">{p.ctr}% CTR</span>
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          </div>
        </>
      )}

      {/* Other Integrations (Coming Soon) */}
      <h3 className="text-lg font-semibold text-white mt-10 mb-4">Prochainement</h3>
      <div className="grid md:grid-cols-3 gap-4">
        {[
          { name: "Google Analytics 4", desc: "Trafic, conversions, comportement utilisateur" },
          { name: "Slack", desc: "Alertes et notifications en temps reel" },
          { name: "Zapier", desc: "Automatisation avec 5000+ applications" },
        ].map((integration) => (
          <Card key={integration.name} className="p-5 opacity-50">
            <p className="text-sm font-medium text-white mb-1">{integration.name}</p>
            <p className="text-xs text-white/40">{integration.desc}</p>
            <Badge variant="secondary" className="mt-3">Bientot disponible</Badge>
          </Card>
        ))}
      </div>
    </div>
  );
}
