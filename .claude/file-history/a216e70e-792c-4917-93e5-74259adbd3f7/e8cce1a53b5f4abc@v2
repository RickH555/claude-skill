import React, { useState, useEffect } from 'react';
import { Fuel, Droplet, Database, Zap, Check, ArrowRight, Sparkles, Gift, Shield, Star } from 'lucide-react';
import { User } from '../types';
import StripeCheckout from '../components/StripeCheckout';

interface RechargeProps {
  onBack: () => void;
  onRecharge: (amount: number, planLevel: 'free' | 'pro' | 'enterprise') => void;
  user: User | null;
  onNavigate: (view: string) => void;
  initialPackId: number | null;
}

const Recharge: React.FC<RechargeProps> = ({ onBack, onRecharge, user, onNavigate, initialPackId }) => {
  const [selectedPack, setSelectedPack] = useState<number | null>(initialPackId);
  const [showCheckout, setShowCheckout] = useState(false);
  const [showSuccess, setShowSuccess] = useState(false);

  useEffect(() => {
    if (initialPackId) {
      setSelectedPack(initialPackId);
      setShowCheckout(true);
    }
  }, [initialPackId]);

  const packs = [
    {
      id: 1,
      name: "Le Jerrican",
      credits: 50,
      price: 15,
      icon: <Droplet size={28} />,
      popular: false,
      color: 'from-amber-700 to-amber-900',
      features: ["50 cr\u00e9dits GTO Gas", "1 Audit complet inclus", "Valable 12 mois", "Support email"],
      bestFor: "Id\u00e9al pour tester",
    },
    {
      id: 2,
      name: "La Pompe",
      credits: 200,
      price: 49,
      icon: <Fuel size={28} />,
      popular: true,
      color: 'from-amber-500 to-amber-700',
      features: ["200 cr\u00e9dits GTO Gas", "+10% Bonus (220 total)", "Support prioritaire", "Acc\u00e8s monitoring avanc\u00e9"],
      bestFor: "Pour optimiser s\u00e9rieusement",
    },
    {
      id: 3,
      name: "La Citerne",
      credits: 1000,
      price: 199,
      icon: <Database size={28} />,
      popular: false,
      color: 'from-amber-400 to-amber-600',
      features: ["1000 cr\u00e9dits GTO Gas", "+20% Bonus (1200 total)", "Acc\u00e8s API Beta", "Support d\u00e9di\u00e9 + formation"],
      bestFor: "Usage intensif / Agences",
    },
  ];

  const handleSelectPack = (packId: number) => {
    setSelectedPack(packId);
    setShowCheckout(true);
  };

  const handlePaymentSuccess = () => {
    const pack = packs.find(p => p.id === selectedPack);
    if (pack) {
      const bonus = pack.id === 2 ? 20 : pack.id === 3 ? 200 : 0;
      onRecharge(pack.credits + bonus, 'free');
    }
    setShowCheckout(false);
    setShowSuccess(true);
  };

  if (showSuccess) {
    const pack = packs.find(p => p.id === selectedPack);
    return (
      <div className="w-full px-6 py-16 flex flex-col items-center justify-center text-center animate-in fade-in zoom-in duration-500">
        <div className="w-24 h-24 rounded-full bg-gradient-to-br from-amber-500/20 to-amber-700/20 border border-amber-500/30 flex items-center justify-center mb-8">
          <Sparkles size={40} className="text-amber-400" />
        </div>
        <h2 className="text-3xl font-bold text-white mb-3">Recharge r\u00e9ussie !</h2>
        <p className="text-gray-400 text-lg mb-2">Vous avez re\u00e7u <span className="text-amber-400 font-bold">{pack ? pack.credits : 0} cr\u00e9dits</span></p>
        {selectedPack === 2 && <p className="text-amber-400 text-sm mb-6"><Gift size={14} className="inline mr-1" /> +20 cr\u00e9dits bonus offerts !</p>}
        {selectedPack === 3 && <p className="text-amber-400 text-sm mb-6"><Gift size={14} className="inline mr-1" /> +200 cr\u00e9dits bonus offerts !</p>}
        <div className="flex gap-4">
          <button onClick={() => onNavigate('analyze')} className="btn-gradient px-8 py-3 font-bold flex items-center gap-2">Lancer un Audit <ArrowRight size={16} /></button>
          <button onClick={() => onNavigate('dashboard')} className="px-8 py-3 rounded-full border border-white/[0.1] text-gray-300 font-medium hover:bg-white/[0.04] transition-all">Dashboard</button>
        </div>
      </div>
    );
  }

  if (showCheckout && selectedPack) {
    const pack = packs.find(p => p.id === selectedPack)!;
    return (
      <div className="w-full px-6 py-8 max-w-lg mx-auto animate-in fade-in duration-300">
        <button onClick={() => setShowCheckout(false)} className="text-gray-500 hover:text-white text-sm mb-6 transition-colors">&larr; Retour aux packs</button>
        <div className="ninja-card p-6 mb-6">
          <div className="flex items-center gap-4 mb-4">
            <div className={`w-12 h-12 rounded-xl bg-gradient-to-br ${pack.color} flex items-center justify-center text-white`}>{pack.icon}</div>
            <div>
              <h3 className="text-lg font-bold text-white">{pack.name}</h3>
              <p className="text-sm text-amber-400">{pack.credits} cr\u00e9dits</p>
            </div>
            <div className="ml-auto text-2xl font-bold text-white">{pack.price}\u20ac</div>
          </div>
        </div>
        <StripeCheckout
          amount={pack.price}
          label={`Acheter ${pack.name}`}
          onSuccess={handlePaymentSuccess}
          onCancel={() => setShowCheckout(false)}
        />
      </div>
    );
  }

  return (
    <div className="w-full px-6 py-8 animate-in fade-in duration-500">
      <div className="text-center mb-10">
        <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-sm font-medium mb-4">
          <Fuel size={14} /> GTO Gas Station
        </div>
        <h1 className="text-3xl md:text-4xl font-bold text-white mb-3">Rechargez vos <span className="gradient-text">cr\u00e9dits</span></h1>
        <p className="text-gray-500 max-w-lg mx-auto">Chaque audit et outil consomme des cr\u00e9dits GTO Gas. Choisissez le pack adapt\u00e9 \u00e0 vos besoins.</p>
        {user && <p className="text-sm text-amber-400 mt-3"><Zap size={14} className="inline mr-1" /> Solde actuel : {user.credits} cr\u00e9dits</p>}
      </div>

      <div className="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
        {packs.map(pack => (
          <div key={pack.id} className={`ninja-card p-8 relative flex flex-col transition-all hover:-translate-y-1 ${pack.popular ? 'border-amber-500/30 shadow-lg shadow-amber-900/10' : ''}`}>
            {pack.popular && <div className="absolute top-0 right-6 px-3 py-1 bg-gradient-to-r from-amber-500 to-amber-700 text-xs font-bold rounded-b-lg text-white uppercase">Populaire</div>}
            <div className={`w-14 h-14 rounded-xl bg-gradient-to-br ${pack.color} flex items-center justify-center text-white mb-4`}>{pack.icon}</div>
            <h3 className="text-xl font-bold text-white mb-1">{pack.name}</h3>
            <p className="text-xs text-gray-500 mb-4">{pack.bestFor}</p>
            <div className="text-3xl font-bold text-white mb-6">{pack.price}<span className="text-base text-gray-500 font-normal">\u20ac</span></div>
            <ul className="space-y-2.5 mb-8 flex-1">
              {pack.features.map(f => (
                <li key={f} className="flex items-center gap-2 text-sm text-gray-400"><Check size={14} className="text-amber-400 shrink-0" />{f}</li>
              ))}
            </ul>
            <button onClick={() => handleSelectPack(pack.id)} className={pack.popular ? 'btn-gradient w-full py-3 font-bold' : 'w-full py-3 rounded-full border border-white/[0.1] text-gray-300 font-medium hover:bg-white/[0.04] transition-all'}>
              Acheter
            </button>
          </div>
        ))}
      </div>

      <div className="max-w-2xl mx-auto ninja-card p-6 flex items-center gap-4">
        <Shield size={24} className="text-amber-400 shrink-0" />
        <div>
          <h4 className="text-sm font-bold text-white">Paiement 100% s\u00e9curis\u00e9</h4>
          <p className="text-xs text-gray-500">Paiement via Stripe. Vos donn\u00e9es bancaires ne sont jamais stock\u00e9es sur nos serveurs.</p>
        </div>
      </div>
    </div>
  );
};

export default Recharge;
