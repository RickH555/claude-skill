de-gray-100\">\n                    {attributionData.map((row) => (\n                      <tr key={row.source} className=\"hover:bg-gray-50\">\n                        <td className=\"px-4 py-3 font-medium text-gray-900\">{row.source}</td>\n                        <td className=\"px-4 py-3 text-gray-700\">{row.visits.toLocaleString('fr-FR')}</td>\n                        <td className=\"px-4 py-3 text-gray-700\">{row.pageViews.toLocaleString('fr-FR')}</td>\n                        <td className=\"px-4 py-3 text-gray-700\">{row.avgDuration}</td>\n                        <td className=\"px-4 py-3 text-gray-700\">{row.bounceRate}%</td>\n                        <td className=\"px-4 py-3 text-gray-700\">{row.conversions}</td>\n                        <td className=\"px-4 py-3\">\n                          <span className={`text-sm ${row.trend === 'up' ? 'text-green-600' : row.trend === 'down' ? 'text-red-600' : 'text-gray-500'}`}>\n                            {row.trend === 'up' ? '↑' : row.trend === 'down' ? '↓' : '→'}\n                          </span>\n                        </td>\n                      </tr>\n                    ))}\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          )}\n\n          {/* AI Queries */}\n          {aiQueries && (\n            <div className=\"rounded-xl bg-white p-6 shadow-sm\">\n              <h3 className=\"mb-4 text-lg font-semibold text-gray-900\">Top requetes IA (Search Console)</h3>\n              <div className=\"overflow-x-auto\">\n                <table className=\"w-full text-left text-sm\">\n                  <thead className=\"border-b border-gray-200 bg-gray-50\">\n                    <tr>\n                      <th className=\"px-4 py-3 font-medium text-gray-600\">Requete</th>\n                      <th className=\"px-4 py-3 font-medium text-gray-600\">Impressions</th>\n                      <th className=\"px-4 py-3 font-medium text-gray-600\">Clics</th>\n         