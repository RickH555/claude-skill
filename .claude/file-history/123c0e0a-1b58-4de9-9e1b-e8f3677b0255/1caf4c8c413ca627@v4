// ---- Code Examples ----

export function getCurlExample(endpoint: ApiEndpoint): string {
  const baseUrl = 'https://api.citedby.ai'
  if (endpoint.method === 'GET') {
    const params = endpoint.params
      .filter((p) => p.required)
      .map((p) => `${p.name}=VALEUR`)
      .join('&')
    return `curl -X GET "${baseUrl}${endpoint.path}?${params}" \\
  -H "Authorization: Bearer cb_live_VOTRE_CLE_API" \\
  -H "Content-Type: application/json"`
  }
  const body = Object.fromEntries(endpoint.params.filter((p) => p.required).map((p) => [p.name, 'VALEUR']))
  return `curl -X POST "${baseUrl}${endpoint.path}" \\
  -H "Authorization: Bearer cb_live_VOTRE_CLE_API" \\
  -H "Content-Type: application/json" \\
  -d '${JSON.stringify(body, null, 2)}'`
}

export function getJsExample(endpoint: ApiEndpoint): string {
  const params = endpoint.params.filter((p) => p.required).map((p) => `${p.name}: 'VALEUR'`)
  if (endpoint.method === 'GET') {
    return `const params = new URLSearchParams({ ${params.join(', ')} })
const response = await fetch(
  \`https://api.citedby.ai${endpoint.path}?\${params}\`,
  {
